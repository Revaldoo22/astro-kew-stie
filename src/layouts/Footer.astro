---
const { websiteInfo } = Astro.props;
import { MapPin, Phone, Mail, Heart, ArrowUp } from "@lucide/astro";


// Quick Links
const quickLinks = [
  { label: "Home", href: "/" },
  { label: "Biaya Kelas Karyawan", href: "/biaya-kelas-karyawan" },
  {
    label: "Program Studi Kelas Karyawan",
    href: "/program-studi-kelas-karyawan",
  },
  { label: "Hubungi Kami", href: "/hubungi-kami" },
  { label: "Blog", href: "/artikel" },
];
---

<footer
  class="text-white relative overflow-hidden bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900"
>
  <!-- Background Pattern -->
  <div class="absolute inset-0 opacity-10">
    <div
      class="absolute top-0 left-0 w-full h-full bg-gradient-to-r from-[#1055C9]/20 to-transparent"
    >
    </div>
    <div
      class="absolute bottom-0 right-0 w-96 h-96 bg-gradient-to-l from-[#1055C9]/15 to-transparent rounded-full blur-3xl"
    >
    </div>
  </div>

  <!-- Main Footer Content -->
  <div class="relative z-10">
    <!-- Top Section -->
    <div class="max-w-screen-xl mx-auto px-4 py-16">
      <div
        class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12"
      >
        <!-- About Section -->
        <div>
          <h4 class="text-xl font-bold text-white mb-4">
            {websiteInfo.name || "Kuliah Kelas Karyawan"}
          </h4>
          <p class="text-sm text-gray-300 mb-6 leading-relaxed">
            Program kuliah fleksibel untuk karyawan yang ingin meningkatkan
            karir sambil bekerja. Kuliah Sabtu & Minggu dengan biaya terjangkau
            dan sistem pembelajaran hybrid.
          </p>
          <div class="flex items-center text-sm text-gray-400 mb-4">
            <Heart class="w-4 h-4 mr-2 text-[#1055C9]" />
            <span>Pendidikan untuk Semua</span>
          </div>

        </div>

        <!-- Quick Links -->
        <div>
          <h4 class="text-xl font-bold text-white mb-4">Menu</h4>
          <ul class="space-y-3">
            {
              quickLinks.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="text-gray-300 hover:text-[#1055C9] transition-colors duration-200 text-sm flex items-center group"
                  >
                    <span class="w-1.5 h-1.5 bg-[#1055C9] rounded-full mr-3 opacity-100 transition-opacity" />
                    {link.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>

        <!-- Program Info -->
        <div>
          <h4 class="text-xl font-bold text-white mb-4">Program Studi</h4>
          <ul class="space-y-3 text-sm text-gray-300">
            <li class="flex items-start">
              <span
                class="w-1.5 h-1.5 bg-[#1055C9] rounded-full mr-3 mt-1.5 flex-shrink-0"
              ></span>
              <span>S1 Manajemen</span>
            </li>
            <li class="flex items-start">
              <span
                class="w-1.5 h-1.5 bg-[#1055C9] rounded-full mr-3 mt-1.5 flex-shrink-0"
              ></span>
              <span>S1 Akuntansi</span>
            </li>
            <li class="flex items-start">
              <span
                class="w-1.5 h-1.5 bg-[#1055C9] rounded-full mr-3 mt-1.5 flex-shrink-0"
              ></span>
              <span>S1 Teknik Informatika</span>
            </li>
            <li class="flex items-start">
              <span
                class="w-1.5 h-1.5 bg-[#1055C9] rounded-full mr-3 mt-1.5 flex-shrink-0"
              ></span>
              <span>S1 Sistem Informasi</span>
            </li>
            <li class="flex items-start">
              <span
                class="w-1.5 h-1.5 bg-[#1055C9] rounded-full mr-3 mt-1.5 flex-shrink-0"
              ></span>
              <span>D3 Teknik Informatika</span>
            </li>
          </ul>

        </div>

        <!-- Contact Info -->
        <div>
          <h4 class="text-lg font-bold text-white mb-4">Kontak Kami</h4>
          <div class="space-y-3">
            <div class="flex items-start space-x-3">
              <div
                class="w-8 h-8 bg-[#1055C9]/20 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5"
              >
                <MapPin class="w-4 h-4 text-[#1055C9]" />
              </div>
              <div>
                <p class="text-gray-300 text-sm leading-relaxed">
                  {websiteInfo.address.street}<br />
                  {websiteInfo.address.district}<br />
                  {websiteInfo.address.city}<br />
                  {websiteInfo.address.country}
                </p>
              </div>
            </div>

            <div class="flex items-center space-x-3">
              <div
                class="w-8 h-8 bg-[#1055C9]/20 rounded-lg flex items-center justify-center flex-shrink-0"
              >
                <Phone class="w-4 h-4 text-[#1055C9]" />
              </div>
              <div>
                <a
                  href={`tel:${websiteInfo.phone}`}
                  class="text-gray-300 hover:text-[#1055C9] transition-colors text-sm"
                >
                  {websiteInfo.phone}
                </a>
              </div>
            </div>

            <div class="flex items-center space-x-3">
              <div
                class="w-8 h-8 bg-[#1055C9]/20 rounded-lg flex items-center justify-center flex-shrink-0"
              >
                <Mail class="w-4 h-4 text-[#1055C9]" />
              </div>
              <div>
                <a
                  href={`mailto:${websiteInfo.email}`}
                  class="text-gray-300 hover:text-[#1055C9] transition-colors text-sm"
                >
                  {websiteInfo.email}
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Bottom Section -->
    <div class="border-t border-gray-700/50">
      <div class="max-w-screen-xl mx-auto px-4 py-6">
        <div
          class="flex flex-col md:flex-row items-center justify-between space-y-3 md:space-y-0"
        >
          <!-- Copyright -->
          <div class="text-center md:text-left">
            <p class="text-gray-400 text-sm">
              © {new Date().getFullYear()}
              {websiteInfo.name || "Kuliah Kelas Karyawan"}. All rights
              reserved.
            </p>
          </div>

          <!-- Additional Links -->
          <div class="flex space-x-6 text-sm">
            <a
              href="/privacy-policy"
              class="text-gray-400 hover:text-[#1055C9] transition-colors"
            >
              Privacy Policy
            </a>
            <a
              href="/terms-of-service"
              class="text-gray-400 hover:text-[#1055C9] transition-colors"
            >
              Terms of Service
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Floating Back to Top Button -->
  <button
    id="back-to-top"
    class="fixed cursor-pointer bottom-6 right-6 z-50 flex items-center justify-center w-12 h-12 text-white rounded-full shadow-lg hover:shadow-xl transition-all duration-300 hover:scale-110 opacity-0 pointer-events-none"
    style="background-color: #1055C9;"
    aria-label="Kembali ke atas"
  >
    <ArrowUp class="w-5 h-5" />
  </button>
</footer>

<script>
  // Back to top functionality
  document.addEventListener("DOMContentLoaded", function () {
    const backToTopButton = document.getElementById(
      "back-to-top",
    ) as HTMLButtonElement | null;

    if (backToTopButton) {
      // Show/hide button based on scroll position
      window.addEventListener("scroll", function () {
        if (window.pageYOffset > 300) {
          backToTopButton.classList.remove("opacity-0", "pointer-events-none");
          backToTopButton.classList.add("opacity-100");
        } else {
          backToTopButton.classList.add("opacity-0", "pointer-events-none");
          backToTopButton.classList.remove("opacity-100");
        }
      });

      // Smooth scroll to top
      backToTopButton.addEventListener("click", function () {
        window.scrollTo({
          top: 0,
          behavior: "smooth",
        });
      });
    }
  });
</script>

<style>
  /* Hover effects for links */
  footer a {
    position: relative;
  }
</style>
