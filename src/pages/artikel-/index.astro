---
import ListContent from "@components/content/ListContent.astro";

const titlePost = "Artikel";
const linkPost = "artikel";
const groupPost = "article";
const enPost = 0;   
const limit = 25;
---
<ListContent 
    titlePost={titlePost} 
    linkPost={linkPost} 
    groupPost={groupPost} 
    enPost={enPost} 
    limit={limit}
    type="latest"
    orderBy="post_date"
/>

