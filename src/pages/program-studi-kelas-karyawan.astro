---
import Layout from "@layouts/Layout.astro";
import Breadcrumb from "@components/Breadcrumb.astro";

const breadcrumbs = [
    { label: "Home", href: "/" },
    {
        label: "Program Studi Kelas Karyawan",
        href: "/program-studi-kelas-karyawan",
    },
];

const metaTags = {
    title: "Program Studi Kelas Karyawan - Kuliah Sambil Kerja",
    description:
        "Pilihan program studi S1 dan D3/D4 untuk kelas karyawan. Upgrade diri, gaji, jabatan, dan karir untuk masa depan yang lebih cerah!",
    keywords:
        "program studi kelas karyawan, kuliah sambil kerja, S1 karyawan, D3 karyawan",
    image: "",
};

// Program Studi S1
const s1Programs = [
    {
        name: "S1 Manajemen",
        degree: "S.M.",
        description:
            "Pelajari strategi bisnis, kepemimpinan, dan manajemen organisasi modern",
    },
    {
        name: "S1 Akuntansi",
        degree: "S.Ak.",
        description:
            "Kuasai pencatatan keuangan, audit, dan pelaporan akuntansi profesional",
    },
    {
        name: "S1 Bisnis",
        degree: "S.Bns.",
        description:
            "Kembangkan keterampilan kewirausahaan dan strategi bisnis global",
    },
    {
        name: "S1 Hukum",
        degree: "S.H.",
        description:
            "Pahami sistem hukum, perundangan, dan praktik hukum Indonesia",
    },
    {
        name: "S1 Teknik Sipil",
        degree: "S.T.",
        description:
            "Rancang dan bangun infrastruktur untuk pembangunan berkelanjutan",
    },
    {
        name: "S1 Teknik Informatika",
        degree: "S.Kom.",
        description:
            "Ciptakan solusi teknologi dengan programming dan software engineering",
    },
    {
        name: "S1 Desain Komunikasi Visual",
        degree: "S.Ds.",
        description:
            "Wujudkan kreativitas melalui desain grafis dan komunikasi visual",
    },
    {
        name: "S1 Ilmu Komputer",
        degree: "S.Kom.",
        description: "Dalami algoritma, AI, dan teknologi komputasi masa depan",
    },
    {
        name: "S1 Sistem Informasi",
        degree: "S.Kom.",
        description:
            "Integrasikan teknologi informasi dengan proses bisnis perusahaan",
    },
];

// Program Studi D3/D4
const vokasiPrograms = [
    {
        name: "D4 Akuntansi Perpajakan",
        degree: "S.Tr.Ak.",
        description:
            "Spesialisasi akuntansi dengan fokus perpajakan dan kepatuhan fiskal",
    },
    {
        name: "D3 Teknik Informatika",
        degree: "A.Md.Kom.",
        description:
            "Program vokasi praktis untuk menjadi teknisi IT profesional",
    },
];
---

<Layout metaTags={metaTags}>
    <div class="min-h-screen bg-gray-50 dark:bg-gray-900">
        <!-- Breadcrumb Section -->
        <div
            class="bg-white dark:bg-gray-800 border-b border-gray-200 dark:border-gray-700"
        >
            <div class="max-w-screen-xl mx-auto px-4 py-4">
                <Breadcrumb breadcrumbs={breadcrumbs} />
            </div>
        </div>

        <!-- Hero Section -->
        <div
            class="bg-gradient-to-br from-[#1055C9] to-[#05339C] text-white py-16 md:py-24"
        >
            <div class="max-w-screen-xl mx-auto px-4">
                <div class="text-center max-w-4xl mx-auto">
                    <div
                        class="inline-flex items-center gap-2 bg-white/20 backdrop-blur-sm px-4 py-2 rounded-full mb-6 border border-white/30"
                    >
                        <svg
                            class="w-5 h-5"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"
                            ></path>
                        </svg>
                        <span class="text-sm font-semibold"
                            >KULIAH KELAS KARYAWAN</span
                        >
                    </div>

                    <h1
                        class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6 leading-tight"
                    >
                        Upgrade Diri, Gaji, Jabatan,<br />dan Karir untuk Masa
                        Depan!
                    </h1>

                    <p class="text-lg md:text-xl mb-10 opacity-90">
                        Pilih program studi yang sesuai dengan passion dan
                        tujuan karir Anda
                    </p>

                    <div class="flex flex-col sm:flex-row gap-4 justify-center">
                        <a
                            href="/hubungi-kami"
                            class="bg-white text-[#1055C9] hover:bg-gray-100 px-8 py-4 rounded-lg font-semibold transition-all duration-300 shadow-lg hover:shadow-xl inline-flex items-center justify-center gap-2"
                        >
                            <svg
                                class="w-5 h-5"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
                                ></path>
                            </svg>
                            Daftar Sekarang
                        </a>
                        <a
                            href="/hubungi-kami"
                            class="bg-transparent border-2 border-white text-white hover:bg-white hover:text-[#1055C9] px-8 py-4 rounded-lg font-semibold transition-all duration-300 inline-flex items-center justify-center gap-2"
                        >
                            <svg
                                class="w-5 h-5"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                                ></path>
                            </svg>
                            Hubungi Kami
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Main Content -->
        <div class="max-w-screen-xl mx-auto px-4 py-16">
            <!-- Fakultas Akademik (S1) -->
            <div class="mb-20">
                <div class="text-center mb-12">
                    <div
                        class="inline-flex items-center gap-2 bg-[#1055C9]/10 text-[#1055C9] dark:bg-[#1055C9]/20 px-4 py-2 rounded-full mb-4"
                    >
                        <svg
                            class="w-5 h-5"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"
                            ></path>
                        </svg>
                        <span class="font-semibold">Fakultas Akademik</span>
                    </div>
                    <h2
                        class="text-3xl md:text-4xl font-bold mb-4 text-gray-900 dark:text-white"
                    >
                        Program Sarjana (S1)
                    </h2>
                    <p class="text-lg text-gray-600 dark:text-gray-400">
                        9 Program Studi Sarjana untuk mengembangkan karir Anda
                    </p>
                </div>

                <div
                    class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6"
                >
                    {
                        s1Programs.map((program) => (
                            <div class="group bg-white dark:bg-gray-800 rounded-xl shadow-lg border border-gray-200 dark:border-gray-700 p-6 hover:shadow-2xl hover:-translate-y-2 transition-all duration-300">
                                <div class="mb-3">
                                    <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-2 group-hover:text-[#1055C9] dark:group-hover:text-[#1055C9] transition-colors">
                                        {program.name}
                                    </h3>
                                    <div class="inline-flex items-center gap-2 bg-[#1055C9]/10 text-[#1055C9] px-3 py-1 rounded-full text-sm font-semibold">
                                        <svg
                                            class="w-4 h-4"
                                            fill="none"
                                            stroke="currentColor"
                                            viewBox="0 0 24 24"
                                        >
                                            <path
                                                stroke-linecap="round"
                                                stroke-linejoin="round"
                                                stroke-width="2"
                                                d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"
                                            />
                                        </svg>
                                        {program.degree}
                                    </div>
                                </div>
                                <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed">
                                    {program.description}
                                </p>
                            </div>
                        ))
                    }
                </div>
            </div>

            <!-- Fakultas Vokasi (D3/D4) -->
            <div class="mb-20">
                <div class="text-center mb-12">
                    <div
                        class="inline-flex items-center gap-2 bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-400 px-4 py-2 rounded-full mb-4"
                    >
                        <svg
                            class="w-5 h-5"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                            ></path>
                        </svg>
                        <span class="font-semibold">Fakultas Vokasi</span>
                    </div>
                    <h2
                        class="text-3xl md:text-4xl font-bold mb-4 text-gray-900 dark:text-white"
                    >
                        Program Diploma (D3 & D4)
                    </h2>
                    <p class="text-lg text-gray-600 dark:text-gray-400">
                        Program vokasi dengan fokus praktis dan siap kerja
                    </p>
                </div>

                <div
                    class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto"
                >
                    {
                        vokasiPrograms.map((program) => (
                            <div class="group bg-white dark:bg-gray-800 rounded-xl shadow-lg border border-gray-200 dark:border-gray-700 p-6 hover:shadow-2xl hover:-translate-y-2 transition-all duration-300">
                                <div class="mb-3">
                                    <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-2 group-hover:text-green-600 dark:group-hover:text-green-400 transition-colors">
                                        {program.name}
                                    </h3>
                                    <div class="inline-flex items-center gap-2 bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-400 px-3 py-1 rounded-full text-sm font-semibold">
                                        <svg
                                            class="w-4 h-4"
                                            fill="none"
                                            stroke="currentColor"
                                            viewBox="0 0 24 24"
                                        >
                                            <path
                                                stroke-linecap="round"
                                                stroke-linejoin="round"
                                                stroke-width="2"
                                                d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"
                                            />
                                        </svg>
                                        {program.degree}
                                    </div>
                                </div>
                                <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed">
                                    {program.description}
                                </p>
                            </div>
                        ))
                    }
                </div>
            </div>

            <!-- Catatan Penting -->
            <!-- Catatan Penting -->
            <div class="mb-16">
                <div class="text-center mb-8">
                    <h3
                        class="text-3xl font-bold text-gray-900 dark:text-white mb-3"
                    >
                        Catatan Penting
                    </h3>
                    <p class="text-lg text-gray-600 dark:text-gray-400">
                        Persyaratan pendaftaran yang perlu Anda ketahui
                    </p>
                </div>

                <div
                    class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto"
                >
                    <div
                        class="bg-gradient-to-br from-blue-50 to-indigo-50 dark:from-blue-900/20 dark:to-indigo-900/20 rounded-xl shadow-lg p-6 border-2 border-blue-200 dark:border-blue-800"
                    >
                        <div class="flex items-start gap-4">
                            <div
                                class="flex-shrink-0 w-12 h-12 bg-blue-500 rounded-full flex items-center justify-center text-white font-bold text-xl"
                            >
                                1
                            </div>
                            <div class="flex-1">
                                <h4
                                    class="text-lg font-bold text-gray-900 dark:text-white mb-2"
                                >
                                    Persyaratan Pendidikan
                                </h4>
                                <p class="text-gray-700 dark:text-gray-300">
                                    Lulusan <strong
                                        >SMA/SMK/MA atau paket C sederajat</strong
                                    > bisa mendaftar
                                </p>
                            </div>
                        </div>
                    </div>

                    <div
                        class="bg-gradient-to-br from-green-50 to-emerald-50 dark:from-green-900/20 dark:to-emerald-900/20 rounded-xl shadow-lg p-6 border-2 border-green-200 dark:border-green-800"
                    >
                        <div class="flex items-start gap-4">
                            <div
                                class="flex-shrink-0 w-12 h-12 bg-green-500 rounded-full flex items-center justify-center text-white font-bold text-xl"
                            >
                                2
                            </div>
                            <div class="flex-1">
                                <h4
                                    class="text-lg font-bold text-gray-900 dark:text-white mb-2"
                                >
                                    Batasan Usia
                                </h4>
                                <p class="text-gray-700 dark:text-gray-300">
                                    <strong
                                        >Tidak ada batasan umur maksimal</strong
                                    > untuk mendaftar
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- CTA Section -->
            <div
                class="bg-gradient-to-r from-[#1055C9] to-[#05339C] rounded-2xl shadow-2xl p-12 text-center text-white"
            >
                <h2 class="text-3xl md:text-4xl font-bold mb-4">
                    Siap Memulai Perjalanan Pendidikan Anda?
                </h2>
                <p class="text-lg mb-8 opacity-90 max-w-2xl mx-auto">
                    Jangan tunda lagi! Konsultasikan pilihan program studi yang
                    tepat untuk karir Anda bersama tim kami.
                </p>
                <div class="flex flex-col sm:flex-row gap-4 justify-center">
                    <a
                        href="/hubungi-kami"
                        class="bg-white text-[#1055C9] hover:bg-gray-100 px-8 py-4 rounded-lg font-semibold transition-all duration-300 shadow-lg hover:shadow-xl inline-flex items-center justify-center gap-2"
                    >
                        <svg
                            class="w-5 h-5"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"
                            ></path>
                        </svg>
                        Konsultasi Gratis
                    </a>
                    <a
                        href="/biaya-kuliah-kelas-karyawan"
                        class="bg-transparent border-2 border-white text-white hover:bg-white hover:text-[#1055C9] px-8 py-4 rounded-lg font-semibold transition-all duration-300 inline-flex items-center justify-center gap-2"
                    >
                        <svg
                            class="w-5 h-5"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                            ></path>
                        </svg>
                        Lihat Biaya Kuliah
                    </a>
                </div>
            </div>
        </div>
    </div>
</Layout>
