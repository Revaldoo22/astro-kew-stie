<script define:vars={{ rplCountdownEndDate }}>
    // Parse countdown date (format: "YYYY-MM-DD HH:mm:ss" in WIB/GMT+7)
    const parseDate = (dateStr) => {
        if (!dateStr || dateStr.trim() === "") {
            return new Date().getTime() + 30 * 24 * 60 * 60 * 1000;
        }
        const [datePart, timePart] = dateStr.split(" ");
        const [year, month, day] = datePart.split("-").map(Number);
        const [hours, minutes, seconds] = timePart.split(":").map(Number);
        return new Date(
            Date.UTC(year, month - 1, day, hours - 7, minutes, seconds),
        ).getTime();
    };

    const countdownEnd = parseDate(rplCountdownEndDate);

    function updateRplCountdown() {
        const now = new Date().getTime();
        const distance = countdownEnd - now;

        const daysEl = document.getElementById("rpl-days");
        const hoursEl = document.getElementById("rpl-hours");
        const minutesEl = document.getElementById("rpl-minutes");
        const secondsEl = document.getElementById("rpl-seconds");

        if (distance <= 0) {
            if (daysEl) daysEl.textContent = "00";
            if (hoursEl) hoursEl.textContent = "00";
            if (minutesEl) minutesEl.textContent = "00";
            if (secondsEl) secondsEl.textContent = "00";
            clearInterval(rplInterval);
            return;
        }

        const d = Math.floor(distance / (1000 * 60 * 60 * 24));
        const h = Math.floor(
            (distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60),
        );
        const m = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
        const s = Math.floor((distance % (1000 * 60)) / 1000);

        if (daysEl) daysEl.textContent = String(d).padStart(2, "0");
        if (hoursEl) hoursEl.textContent = String(h).padStart(2, "0");
        if (minutesEl) minutesEl.textContent = String(m).padStart(2, "0");
        if (secondsEl) secondsEl.textContent = String(s).padStart(2, "0");
    }

    const rplInterval = setInterval(updateRplCountdown, 1000);
    updateRplCountdown();
</script>
