---
import Layout from "@layouts/Layout.astro";

// Import New Promo-Focused Home Components

import { websiteInfo } from "@globals/info";

// Reuse the same countdown end date logic as the main promo page
const rplCountdownEndDate = websiteInfo.promo.countdownEndDate;

const metaTags = {
    title: "Promo Kuliah Cepat RPL",
    description:
        "Informasi lengkap seputar promo kuliah cepat RPL seperti biaya, jadwal, jurusan atau program studi di Universitas STEKOM",
    keywords:
        "Kuliah Sambil Kerja, Kelas Karyawan, Kuliah Online, Kuliah Full Online, Promo Kuliah, Daftar 150 Ribu, Gratis SPI, Kuliah Tanpa Skripsi",
    image: "",
};

const recognitionItems = [
    "Pengalaman Kerja",
    "Sertifikasi Kompetensi",
    "Sertifikat Kursus",
    "Sertifikat Narasumber",
    "Kartu Hasil Study (KHS)",
    "Hasil Kerja, Hasil Ciptaan",
    "Catatan Kerja",
    "Prestasi Juara Penilaian Kerja",
    "Penghargaan",
];

const perolehanSKSProdi = [
    { name: "S1 Bisnis", available: true },
    { name: "S1 Sistem Komputer", available: false },
    { name: "S1 Sistem Informasi", available: false },
    { name: "S1 Desain Komunikasi Visual", available: false },
    { name: "S1 Teknik Informatika", available: false },
];

const transferSKSProdi = [
    { name: "S1 Sistem Komputer", available: true },
    { name: "S1 Sistem Informasi", available: true },
    { name: "S1 Desain Komunikasi Visual", available: true },
    { name: "S1 Teknik Informatika", available: true },
    { name: "S1 Bisnis", available: true },
];

const documents = [
    "KTP",
    "Ijazah dan transkrip nilai terakhir",
    "CV atau daftar riwayat kerja",
    "Sertifikat pelatihan/kompetensi",
    "Surat pengalaman kerja (jika ada)",
];

const campusLocations = [
    {
        name: "Kampus Pusat Semarang",
        mapsUrl: "https://maps.app.goo.gl/VNpC3rPLKVgdUepF6",
    },
    {
        name: "Kampus Siliwangi",
        mapsUrl: "https://maps.app.goo.gl/zbp3jqRbsmmyb8gy6",
    },
    {
        name: "Kampus Ungaran",
        mapsUrl: "https://maps.app.goo.gl/yCWGRQWa1U2icRBdA",
    },
    {
        name: "Kampus Kendal Kota",
        mapsUrl: "https://maps.app.goo.gl/fDftWjXJc7wy9o6h9",
    },
    {
        name: "Kampus Sruwen Salatiga",
        mapsUrl: "https://maps.app.goo.gl/84Ka1uSM5fV624bX8",
    },
    {
        name: "Kampus Solo",
        mapsUrl: "https://maps.app.goo.gl/aXPnrKZ4Q9ZgwTBS7",
    },
    {
        name: "Kampus Weleri Batang",
        mapsUrl: "https://maps.app.goo.gl/fxChVNqWCKfpLXUk6",
    },
    {
        name: "Kampus Ambarawa",
        mapsUrl: "https://maps.app.goo.gl/AN9vbQmfrZEknjBs5",
    },
];
---

<Layout metaTags={metaTags}>
    <!-- Hero Section -->
    <section
        id="rpl-hero"
        class="relative bg-gradient-to-br from-[#1055C9] via-[#05339C] to-[#0046FF] text-white py-10 md:py-16 overflow-hidden"
    >
        <!-- Decorative blobs -->
        <div
            class="absolute -top-16 -left-16 w-64 h-64 bg-white/5 rounded-full blur-3xl"
        >
        </div>
        <div
            class="absolute -bottom-16 -right-16 w-80 h-80 bg-white/5 rounded-full blur-3xl"
        >
        </div>

        <div class="relative max-w-screen-xl mx-auto px-4">
            <!-- Brochure Card -->
            <div class="max-w-2xl mx-auto mb-10">
                <div
                    class="bg-white/10 backdrop-blur-sm rounded-2xl p-4 border border-white/20"
                >
                    <div class="rounded-xl overflow-hidden shadow-2xl bg-white w-full">
                        <img
                            src="/assets/brosur/Konten RPL Luar Jateng Landing Page.png"
                            alt="Promo RPL"
                            class="w-full h-auto object-cover"
                            loading="lazy"
                        />
                    </div>
                </div>
            </div>

            <!-- Countdown Timer -->
            <div class="max-w-2xl mx-auto mb-8">
                <p
                    class="text-center text-white/70 text-sm uppercase tracking-widest font-semibold mb-4"
                >
                    ⏳ Promo berlaku hingga
                </p>
                <div
                    id="rpl-countdown"
                    class="grid grid-cols-4 gap-3 text-center"
                >
                    <div
                        class="bg-white/15 backdrop-blur-sm border border-white/20 rounded-xl p-4"
                    >
                        <div
                            id="rpl-days"
                            class="text-3xl md:text-4xl font-bold text-white"
                        >
                            00
                        </div>
                        <div
                            class="text-xs md:text-sm text-white/70 mt-1 uppercase tracking-wider"
                        >
                            Hari
                        </div>
                    </div>
                    <div
                        class="bg-white/15 backdrop-blur-sm border border-white/20 rounded-xl p-4"
                    >
                        <div
                            id="rpl-hours"
                            class="text-3xl md:text-4xl font-bold text-white"
                        >
                            00
                        </div>
                        <div
                            class="text-xs md:text-sm text-white/70 mt-1 uppercase tracking-wider"
                        >
                            Jam
                        </div>
                    </div>
                    <div
                        class="bg-white/15 backdrop-blur-sm border border-white/20 rounded-xl p-4"
                    >
                        <div
                            id="rpl-minutes"
                            class="text-3xl md:text-4xl font-bold text-white"
                        >
                            00
                        </div>
                        <div
                            class="text-xs md:text-sm text-white/70 mt-1 uppercase tracking-wider"
                        >
                            Menit
                        </div>
                    </div>
                    <div
                        class="bg-white/15 backdrop-blur-sm border border-white/20 rounded-xl p-4"
                    >
                        <div
                            id="rpl-seconds"
                            class="text-3xl md:text-4xl font-bold text-yellow-300"
                        >
                            00
                        </div>
                        <div
                            class="text-xs md:text-sm text-white/70 mt-1 uppercase tracking-wider"
                        >
                            Detik
                        </div>
                    </div>
                </div>
            </div>

            <!-- Badge -->
            <div class="flex justify-center mb-4">
                <span
                    class="inline-flex items-center gap-2 bg-yellow-400/20 border border-yellow-400/40 text-yellow-300 text-sm font-semibold px-4 py-1.5 rounded-full"
                >
                    <svg
                        class="w-4 h-4"
                        fill="currentColor"
                        viewBox="0 0 20 20"
                    >
                        <path
                            d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"
                        ></path>
                    </svg>
                    Program Unggulan Universitas STEKOM
                </span>
            </div>

            <!-- Title -->
            <div class="text-center mb-10">
                <h1
                    class="text-3xl md:text-4xl lg:text-5xl font-bold leading-tight"
                >
                    Kuliah Lebih Cepat dengan
                    <span class="text-yellow-300"> RPL</span>
                </h1>
                <p
                    class="mt-4 text-base md:text-lg text-white/85 max-w-3xl mx-auto leading-relaxed"
                >
                    RPL adalah program yang memungkinkan kamu mengubah
                    pengalaman belajar atau kerja menjadi nilai (SKS) kuliah,
                    sehingga kuliah bisa lebih <strong class="text-yellow-300"
                        >cepat</strong
                    > dan
                    <strong class="text-yellow-300">hemat</strong>.
                </p>
            </div>

            <!-- Recognition Items Grid -->
            <div class="max-w-4xl mx-auto">
                <p
                    class="text-center text-white/70 text-sm uppercase tracking-widest font-semibold mb-5"
                >
                    Pengakuan bisa merujuk kepada
                </p>
                <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
                    {
                        recognitionItems.map((item) => (
                            <div class="flex items-center gap-3 bg-white/10 backdrop-blur-sm border border-white/20 rounded-xl px-4 py-3">
                                <div class="flex-shrink-0 w-7 h-7 rounded-full bg-yellow-400/20 flex items-center justify-center">
                                    <svg
                                        class="w-4 h-4 text-yellow-300"
                                        fill="none"
                                        stroke="currentColor"
                                        viewBox="0 0 24 24"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
                                        />
                                    </svg>
                                </div>
                                <span class="text-sm font-medium text-white/90">
                                    {item}
                                </span>
                            </div>
                        ))
                    }
                </div>
            </div>

            <!-- CTA Button -->
            <div class="text-center mt-10">
                <a
                    href={websiteInfo.contactUs}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center justify-center bg-yellow-400 hover:bg-yellow-300 text-gray-900 font-bold px-8 py-4 rounded-xl text-base transition-all duration-300 shadow-2xl hover:shadow-yellow-400/40 hover:scale-105 gap-2"
                >
                    <svg
                        class="w-5 h-5"
                        fill="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
                        ></path>
                    </svg>
                    Konsultasi Gratis via WhatsApp
                </a>
            </div>
        </div>
    </section>

    <!-- Jenis RPL Section -->
    <section class="py-16 bg-gray-50 dark:bg-gray-900">
        <div class="max-w-screen-xl mx-auto px-4">
            <!-- Section Title -->
            <div class="text-center mb-12">
                <h2 class="text-3xl md:text-4xl font-bold mb-3">
                    <span class="text-gray-900 dark:text-white">Jenis </span>
                    <span
                        class="bg-gradient-to-r from-[#1055C9] to-[#05339C] bg-clip-text text-transparent"
                        >RPL</span
                    >
                </h2>
                <p class="text-gray-600 dark:text-gray-400 max-w-xl mx-auto">
                    Pilih jenis RPL yang sesuai dengan latar belakang dan tujuan
                    akademikmu
                </p>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
                <!-- Perolehan SKS Card -->
                <div
                    class="bg-white dark:bg-gray-800 rounded-2xl shadow-lg border border-gray-200 dark:border-gray-700 overflow-hidden hover:shadow-xl transition-all duration-300 group"
                >
                    <!-- Card Header -->
                    <div
                        class="bg-gradient-to-r from-[#1055C9] to-[#05339C] p-6 text-white"
                    >
                        <div class="flex items-center gap-4">
                            <div
                                class="flex-shrink-0 w-14 h-14 bg-white/20 rounded-xl flex items-center justify-center"
                            >
                                <svg
                                    class="w-8 h-8 text-yellow-300"
                                    fill="none"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
                                    ></path>
                                </svg>
                            </div>
                            <div>
                                <h3 class="text-xl md:text-2xl font-bold">
                                    Perolehan SKS
                                </h3>
                                <p class="text-white/80 text-sm mt-1">
                                    Untuk yang belum pernah kuliah
                                </p>
                            </div>
                        </div>
                    </div>

                    <!-- Card Body -->
                    <div class="p-6">
                        <p
                            class="text-gray-700 dark:text-gray-300 leading-relaxed mb-6"
                        >
                            Untuk kamu yang <strong
                                >belum pernah kuliah sebelumnya</strong
                            >, tapi punya pengalaman kerja, sertifikat, atau
                            pelatihan. Pengalaman tersebut bisa diubah jadi SKS
                            yang setara dengan mata kuliah.
                        </p>

                        <h4
                            class="text-sm font-bold uppercase tracking-wider text-gray-500 dark:text-gray-400 mb-3"
                        >
                            Opsi Jurusan Tersedia
                        </h4>
                        <ul class="space-y-2">
                            {
                                perolehanSKSProdi.map((prodi) => (
                                    <li class="flex items-center gap-3">
                                        {prodi.available ? (
                                            <span class="flex-shrink-0 w-6 h-6 rounded-full bg-green-100 dark:bg-green-900/30 flex items-center justify-center">
                                                <svg
                                                    class="w-4 h-4 text-green-600 dark:text-green-400"
                                                    fill="currentColor"
                                                    viewBox="0 0 20 20"
                                                >
                                                    <path
                                                        fill-rule="evenodd"
                                                        d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                                                        clip-rule="evenodd"
                                                    />
                                                </svg>
                                            </span>
                                        ) : (
                                            <span class="flex-shrink-0 w-6 h-6 rounded-full bg-red-100 dark:bg-red-900/30 flex items-center justify-center">
                                                <svg
                                                    class="w-4 h-4 text-red-500 dark:text-red-400"
                                                    fill="currentColor"
                                                    viewBox="0 0 20 20"
                                                >
                                                    <path
                                                        fill-rule="evenodd"
                                                        d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z"
                                                        clip-rule="evenodd"
                                                    />
                                                </svg>
                                            </span>
                                        )}
                                        <span
                                            class={`text-sm font-medium ${prodi.available ? "text-gray-800 dark:text-gray-200" : "text-gray-400 dark:text-gray-500 line-through"}`}
                                        >
                                            {prodi.name}
                                        </span>
                                        {prodi.available && (
                                            <span class="ml-auto text-xs bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400 px-2 py-0.5 rounded-full font-semibold">
                                                Tersedia
                                            </span>
                                        )}
                                    </li>
                                ))
                            }
                        </ul>
                    </div>
                </div>

                <!-- Transfer SKS Card -->
                <div
                    class="bg-white dark:bg-gray-800 rounded-2xl shadow-lg border border-gray-200 dark:border-gray-700 overflow-hidden hover:shadow-xl transition-all duration-300 group"
                >
                    <!-- Card Header -->
                    <div
                        class="bg-gradient-to-r from-[#05339C] to-[#0046FF] p-6 text-white"
                    >
                        <div class="flex items-center gap-4">
                            <div
                                class="flex-shrink-0 w-14 h-14 bg-white/20 rounded-xl flex items-center justify-center"
                            >
                                <svg
                                    class="w-8 h-8 text-yellow-300"
                                    fill="none"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"
                                    ></path>
                                </svg>
                            </div>
                            <div>
                                <h3 class="text-xl md:text-2xl font-bold">
                                    Transfer SKS
                                </h3>
                                <p class="text-white/80 text-sm mt-1">
                                    Untuk yang sudah pernah kuliah
                                </p>
                            </div>
                        </div>
                    </div>

                    <!-- Card Body -->
                    <div class="p-6">
                        <p
                            class="text-gray-700 dark:text-gray-300 leading-relaxed mb-6"
                        >
                            Untuk kamu yang sudah pernah kuliah <strong
                                >(D1/D2/D3/S1)</strong
                            >
                            dan ingin melanjutkan studi. SKS dari kampus lama bisa
                            diakui di Universitas STEKOM.
                        </p>

                        <h4
                            class="text-sm font-bold uppercase tracking-wider text-gray-500 dark:text-gray-400 mb-3"
                        >
                            Opsi Jurusan Tersedia
                        </h4>
                        <ul class="space-y-2">
                            {
                                transferSKSProdi.map((prodi) => (
                                    <li class="flex items-center gap-3">
                                        {prodi.available ? (
                                            <span class="flex-shrink-0 w-6 h-6 rounded-full bg-green-100 dark:bg-green-900/30 flex items-center justify-center">
                                                <svg
                                                    class="w-4 h-4 text-green-600 dark:text-green-400"
                                                    fill="currentColor"
                                                    viewBox="0 0 20 20"
                                                >
                                                    <path
                                                        fill-rule="evenodd"
                                                        d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                                                        clip-rule="evenodd"
                                                    />
                                                </svg>
                                            </span>
                                        ) : (
                                            <span class="flex-shrink-0 w-6 h-6 rounded-full bg-red-100 dark:bg-red-900/30 flex items-center justify-center">
                                                <svg
                                                    class="w-4 h-4 text-red-500 dark:text-red-400"
                                                    fill="currentColor"
                                                    viewBox="0 0 20 20"
                                                >
                                                    <path
                                                        fill-rule="evenodd"
                                                        d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z"
                                                        clip-rule="evenodd"
                                                    />
                                                </svg>
                                            </span>
                                        )}
                                        <span
                                            class={`text-sm font-medium ${prodi.available ? "text-gray-800 dark:text-gray-200" : "text-gray-400 dark:text-gray-500 line-through"}`}
                                        >
                                            {prodi.name}
                                        </span>
                                        {prodi.available && (
                                            <span class="ml-auto text-xs bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400 px-2 py-0.5 rounded-full font-semibold">
                                                Tersedia
                                            </span>
                                        )}
                                    </li>
                                ))
                            }
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Dokumen yang Diperlukan -->
    <section class="py-16 bg-white dark:bg-gray-800">
        <div class="max-w-screen-xl mx-auto px-4">
            <div class="max-w-3xl mx-auto">
                <!-- Title -->
                <div class="text-center mb-10">
                    <h2 class="text-3xl md:text-4xl font-bold mb-3">
                        <span class="text-gray-900 dark:text-white"
                            >Dokumen yang</span
                        >
                        <span
                            class="bg-gradient-to-r from-[#1055C9] to-[#05339C] bg-clip-text text-transparent"
                        >
                            Diperlukan
                        </span>
                    </h2>
                    <p class="text-gray-600 dark:text-gray-400">
                        Siapkan dokumen berikut untuk proses pendaftaran RPL
                    </p>
                </div>

                <!-- Documents List -->
                <div
                    class="bg-gray-50 dark:bg-gray-900 rounded-2xl border border-gray-200 dark:border-gray-700 overflow-hidden shadow-md"
                >
                    {
                        documents.map((doc, index) => (
                            <div
                                class={`flex items-center gap-4 px-6 py-4 ${index !== documents.length - 1 ? "border-b border-gray-200 dark:border-gray-700" : ""}`}
                            >
                                <div class="flex-shrink-0 w-9 h-9 bg-gradient-to-br from-[#1055C9] to-[#05339C] rounded-lg flex items-center justify-center text-white font-bold text-sm">
                                    {index + 1}
                                </div>
                                <div class="flex items-center gap-3 flex-1">
                                    <svg
                                        class="w-5 h-5 text-[#1055C9] flex-shrink-0"
                                        fill="none"
                                        stroke="currentColor"
                                        viewBox="0 0 24 24"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
                                        />
                                    </svg>
                                    <span class="text-gray-800 dark:text-gray-200 font-medium">
                                        {doc}
                                    </span>
                                </div>
                            </div>
                        ))
                    }
                </div>

                <!-- Note -->
                <div
