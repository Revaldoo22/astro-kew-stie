---
import Layout from "@layouts/Layout.astro";

// Import New Promo-Focused Home Components
import PromoHeroSection from "@components/home/PromoHeroSection.astro";
import AboutSection from "@components/home/AboutSection.astro";
import BiayaKuliahSection from "@components/home/BiayaKuliahSection.astro";
import ProgramStudiSection from "@components/home/ProgramStudiSection.astro";
import LokasiKampusSection from "@components/home/LokasiKampusSection.astro";
import PromoTableSection from "@components/home/PromoTableSection.astro";

const metaTags = {
    title: "Kuliah Kelas Karyawan - Daftar Hanya 150 Ribu | STEKOM",
    description:
        "PROMO TERBATAS! Daftar kuliah kelas karyawan hanya 150 ribu. Kuliah cepat lulus bisa tanpa skripsi. Gratis SPI 7 juta untuk jurusan pilihan. Kuliah sambil kerja dengan jadwal fleksibel.",
    keywords:
        "Kuliah Sambil Kerja, Kelas Karyawan, Kuliah Online, Kuliah Full Online, Promo Kuliah, Daftar 150 Ribu, Gratis SPI, Kuliah Tanpa Skripsi",
    image: "",
};
---

<Layout metaTags={metaTags}>
    <PromoHeroSection />
    <AboutSection />
    <BiayaKuliahSection />
    <ProgramStudiSection />
    <LokasiKampusSection />
    <PromoTableSection />
</Layout>
