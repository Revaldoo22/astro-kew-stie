---
import LayoutBlog from "@layouts/LayoutBlog.astro";
import Breadcrumb from "@components/Breadcrumb.astro";
import { BlogApi } from "@/services/blogApi";
import BrochureRequestForm from "@components/blog/BrochureRequestForm.astro";
import BrochureRequestFormModal from "@components/blog/BrochureRequestFormModal.astro";

// Get slug from URL
const { slug } = Astro.params;

// Fetch all posts to find the one with matching slug
const blogApi = new BlogApi();
const projectsResponse = await blogApi.fetchProjects(1, 10, "published");
const allPosts = projectsResponse?.data || [];

// Fetch full content details
const fullContent = await blogApi.fetchContentById(slug || "");

if (!fullContent) {
    return Astro.redirect('/blog');
}

// Fetch categories for sidebar
const categoriesResponse = await blogApi.fetchCategories();
const categories = categoriesResponse?.data || [];

// Get related posts (same category, exclude current post)
const relatedPosts = allPosts
    .filter(p => p.slug !== slug)
    .slice(0, 3);

const breadcrumbs = [
    { label: "Home", href: "/" },
    { label: "Blog", href: "/blog" },
    { label: fullContent.title, href: `/blog/${slug}` },
];

const metaTags = {
    title: fullContent.title || "Blog",
    description: fullContent.metaDescription || (fullContent.content ? fullContent.content.replace(/<[^>]*>/g, '').substring(0, 160) : "Artikel blog"),
    keywords: fullContent.tags || "blog, artikel, " + (fullContent.title || ""),
    image: fullContent.thumbnailUrl || "",
};

---


<LayoutBlog metaTags={metaTags}>
    <!-- Brochure Request Form Modal - Auto Open -->
    <BrochureRequestFormModal autoOpen={true} />
    
    <div class="min-h-screen bg-gray-50 dark:bg-gray-900">
        <!-- Breadcrumb -->
        <div class="bg-white dark:bg-gray-800 border-b border-gray-200 dark:border-gray-700">
            <div class="max-w-screen-xl mx-auto px-4 py-4">
                <Breadcrumb breadcrumbs={breadcrumbs} />
            </div>
        </div>

        <div class="max-w-screen-xl mx-auto px-4 py-12">
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
                <!-- Main Content -->
                <article class="lg:col-span-9">
                    <!-- Featured Image -->
                    {fullContent.thumbnailUrl && (
                        <div class="relative rounded-2xl overflow-hidden mb-8 shadow-2xl">
                            <img
                                src={fullContent.thumbnailUrl}
                                alt={fullContent.title}
                                class="w-full h-full object-cover"
                            />
                        </div>
                    )}

                    <!-- Article Header -->
                    <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-lg p-8 mb-8">
                        <!-- Title -->
                        <h1 class="text-4xl lg:text-5xl font-extrabold text-gray-900 dark:text-white mb-6 leading-tight">
                            {fullContent.title}
                        </h1>

                        <!-- Meta Info -->
                        <div class="flex flex-wrap items-center gap-4 text-sm pb-6 border-b border-gray-200 dark:border-gray-700">
                            <!-- Author -->
                            <div class="flex items-center gap-2 text-gray-600 dark:text-gray-400">
                                <div class="w-8 h-8 rounded-full bg-[#1055C9] flex items-center justify-center flex-shrink-0">
                                    <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 20 20">
                                        <path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd"/>
                                    </svg>
                                </div>
                                <span class="font-medium">Admin</span>
                            </div>

                            <!-- Date -->
                            <div class="flex items-center gap-2 text-gray-600 dark:text-gray-400">
                                <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                                </svg>
                                <span>
                                    {new Date(fullContent.createdAt).toLocaleDateString("id-ID", {
                                        year: "numeric",
                                        month: "long",
                                        day: "numeric",
                                    })}
                                </span>
                            </div>

                            <!-- Reading Time -->
                            <div class="flex items-center gap-2 text-gray-600 dark:text-gray-400">
                                <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                                </svg>
                                <span>{fullContent.content ? Math.ceil(fullContent.content.split(' ').length / 200) : 1} menit baca</span>
                            </div>

                            <!-- Views -->
                            <div class="flex items-center gap-2 text-gray-600 dark:text-gray-400">
                                <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                                </svg>
                                <span>0 views</span>
                            </div>
                        </div>

                        <!-- Content -->
                        <div class="prose prose-lg dark:prose-invert max-w-none mt-8">
                            <Fragment set:html={fullContent.content} />
                        </div>

                        <!-- Share Buttons -->
                        <div class="mt-12 pt-8 border-t border-gray-200 dark:border-gray-700">
                            <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-4">Bagikan Artikel</h3>
                            <div class="flex flex-wrap gap-3">
                                <!-- Facebook -->
                                <a
                                    href={`https://www.facebook.com/sharer/sharer.php?u=${Astro.url.href}`}
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    class="inline-flex items-center gap-2 px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors"
                                >
                                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                                        <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                                    </svg>
                                    Facebook
                                </a>

                                <!-- Twitter -->
                                <a
                                    href={`https://twitter.com/intent/tweet?url=${Astro.url.href}&text=${fullContent.title}`}
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    class="inline-flex items-center gap-2 px-4 py-2 bg-sky-500 text-white rounded-lg hover:bg-sky-600 transition-colors"
                                >
                                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                                        <path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/>
                                    </svg>
                                    Twitter
                                </a>

                                <!-- WhatsApp -->
                                <a
                                    href={`https://wa.me/?text=${fullContent.title} ${Astro.url.href}`}
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    class="inline-flex items-center gap-2 px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 transition-colors"
                                >
                                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                                        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
                                    </svg>
                                    WhatsApp
                                </a>

                                <!-- Copy Link -->
                                <button
                                    onclick={`navigator.clipboard.writeText('${Astro.url.href}'); alert('Link berhasil disalin!')`}
                                    class="inline-flex items-center gap-2 px-4 py-2 bg-gray-600 text-white rounded-lg hover:bg-gray-700 transition-colors"
                                >
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>
                                    </svg>
                                    Salin Link
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- Related Posts -->
                    {relatedPosts.length > 0 && (
                        <div class="mt-12">
                            <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-6">Artikel Terkait</h2>
                            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                                {relatedPosts.map((relatedPost) => (
                                    <article class="group bg-white dark:bg-gray-800 rounded-xl shadow-md overflow-hidden border border-gray-200 dark:border-gray-700 hover:shadow-xl transition-all duration-300 hover:-translate-y-1">
                                        <!-- Thumbnail -->
                                        <div class="relative h-48 overflow-hidden bg-gradient-to-br from-blue-100 to-purple-100 dark:from-gray-700 dark:to-gray-600">
                                            {relatedPost.thumbnailUrl ? (
                                                <img
                                                    src={relatedPost.thumbnailUrl}
                                                    alt={relatedPost.title}
                                                    class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-300"
                                                />
                                            ) : (
                                                <div class="w-full h-full flex items-center justify-center">
                                                    <svg class="w-12 h-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                                                    </svg>
                                                </div>
                                            )}
                                        </div>

                                        <!-- Content -->
                                        <div class="p-5">
                                            <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-2 line-clamp-2 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">
                                                {relatedPost.title}
                                            </h3>
                                            <p class="text-gray-600 dark:text-gray-300 text-sm line-clamp-2 mb-4">
                                                {relatedPost.metaDescription || (relatedPost.content ? relatedPost.content.replace(/<[^>]*>/g, '').substring(0, 100) + "..." : "Baca artikel ini...")}
                                            </p>
                                            <a
                                                href={`/blog/${relatedPost.slug}`}
                                                class="inline-flex items-center text-blue-600 dark:text-blue-400 hover:text-blue-700 dark:hover:text-blue-300 font-semibold text-sm transition-colors group/link"
                                            >
                                                Baca Artikel
                                                <svg class="w-4 h-4 ml-1 group-hover/link:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                                                </svg>
                                            </a>
                                        </div>
                                    </article>
                                ))}
                            </div>
                        </div>
                    )}
                </article>

                <!-- Sidebar -->
                <aside class="lg:col-span-3">
                    <div class="sticky top-4 space-y-6">
                        
                        <!-- Categories Card -->
                        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md border border-gray-200 dark:border-gray-700 overflow-hidden">
                            <div class="bg-[#1055C9] p-4">
                                <h3 class="text-lg font-bold text-white flex items-center gap-2">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/>
                                    </svg>
                                    Kategori
                                </h3>
                            </div>
                            <div class="p-4">
                                {categories.length > 0 ? (
                                    <div class="space-y-1">
                                        {categories.map((category) => (
                                            <a
                                                href={`/blog/kategori/${category.id}`}
                                                class="flex items-center justify-between px-4 py-3 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700/50 transition-colors group"
                                            >
                                                <div class="flex items-center gap-3">
                                                    <div 
                                                        class="w-2.5 h-2.5 rounded-full flex-shrink-0" 
                                                        style={`background-color: ${category.color}`}
                                                    ></div>
                                                    <span class="text-gray-700 dark:text-gray-300 group-hover:text-gray-900 dark:group-hover:text-white font-medium">
                                                        {category.name}
                                                    </span>
                                                </div>
                                                <svg class="w-4 h-4 text-gray-400 group-hover:text-gray-600 dark:group-hover:text-gray-300 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                                                </svg>
                                            </a>
                                        ))}
                                    </div>
                                ) : (
                                    <p class="text-gray-500 dark:text-gray-400 text-sm text-center py-8">
                                        Belum ada kategori
                                    </p>
                                )}
                            </div>
                        </div>
                        
                        <!-- Brochure Request Form -->
                        <BrochureRequestForm />

                        <!-- Back to Blog -->
                        <a
                            href="/blog"
                            class="block w-full px-6 py-3 bg-[#1055C9] text-white font-semibold rounded-xl hover:bg-[#0d4aa8] transition-all duration-300 shadow-lg hover:shadow-xl text-center"
                        >
                            ← Kembali ke Blog
                        </a>
                    </div>
                </aside>
            </div>
        </div>
    </div>

</LayoutBlog>

