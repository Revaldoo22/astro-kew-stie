---
import Layout from "@layouts/Layout.astro";
import Breadcrumb from "@components/Breadcrumb.astro";
import { websiteInfo } from "@globals/info";
import { BlogApi } from "@/services/blogApi";
import PaginationContent from "@components/content/PaginationContent.astro";
import BrochureRequestForm from "@components/blog/BrochureRequestForm.astro";

const breadcrumbs = [
    { label: "Home", href: "/" },
    { label: "Blog", href: "/blog" },
];

const metaTags = {
    title: "Blog",
    description: "Artikel dan berita terbaru dari " + websiteInfo.name,
    keywords: "blog, artikel, berita",
    image: "",
};

// Get page from URL query params
const url = new URL(Astro.request.url);
const currentPage = parseInt(url.searchParams.get("page") || "1");

// Page 1: 10 items (1 featured + 9 grid), Page 2+: 9 items (grid only)
const itemsPerPage = currentPage === 1 ? 10 : 9;


// Fetch blog posts
const blogApi = new BlogApi();
const projectsResponse = await blogApi.fetchProjects(currentPage, itemsPerPage, "published");
const posts = projectsResponse?.data || [];
const totalPosts = projectsResponse?.total || 0;

// Fetch categories
const categoriesResponse = await blogApi.fetchCategories();
const categories = categoriesResponse?.data || [];

// Prepare pagination data
const paginationData = {
    currentPage: projectsResponse?.page || currentPage,
    totalPages: projectsResponse?.totalPages || 0,
    total: totalPosts,
};

---

<Layout metaTags={metaTags}>
    <div class="min-h-screen bg-gray-50 dark:bg-gray-900">
        <div
            class="bg-white dark:bg-gray-800 border-b border-gray-200 dark:border-gray-700"
        >
            <div class="max-w-screen-xl mx-auto px-4 py-4">
                <Breadcrumb breadcrumbs={breadcrumbs} />
            </div>
        </div>

        <div class="max-w-screen-xl mx-auto px-4 py-12">
            <!-- Featured Article (First Post) - Only on Page 1 -->
            {currentPage === 1 && posts.length > 0 && (
                <div class="mb-16 bg-gradient-to-br from-[#1055C9] via-[#05339C] to-[#0046FF] rounded-3xl overflow-hidden shadow-2xl">
                    <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 p-4 lg:p-6">
                        <!-- Left Content -->
                        <div class="flex flex-col justify-center text-white">
                            <!-- Badge -->
                            {/* <div class="mb-6">
                                <span class="inline-flex items-center px-4 py-2 rounded-full text-sm font-bold bg-white text-blue-600 shadow-lg">
                                    BERITA UTAMA
                                </span>
                            </div> */}

                            <!-- Title -->
                            <h1 class="text-3xl lg:text-4xl font-bold mb-6 leading-tight">
                                {posts[0].title}
                            </h1>

                            <!-- Excerpt -->
                            <p class="text-lg mb-6 text-blue-50 leading-relaxed">
                                {posts[0].metaDescription || posts[0].content.replace(/<[^>]*>/g, '').substring(0, 200) + "..."}
                            </p>

                            <!-- Meta Info -->
                            <div class="flex items-center gap-4 mb-8 text-blue-50">
                                <div class="flex items-center gap-2">
                                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                                        <path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd"/>
                                    </svg>
                                    <span>Admin</span>
                                </div>
                                <span>•</span>
                                <div class="flex items-center gap-2">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                                    </svg>
                                    <span>
                                        {new Date(posts[0].createdAt).toLocaleDateString("id-ID", {
                                            year: "numeric",
                                            month: "long",
                                            day: "numeric",
                                        })}
                                    </span>
                                </div>
                                <span>•</span>
                                <div class="flex items-center gap-2">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                                    </svg>
                                    <span>0 Views</span>
                                </div>
                            </div>

                            <!-- CTA Button -->
                            <div>
                                <a
                                    href={`/${posts[0].slug}`}
                                    class="inline-flex items-center px-6 py-3 bg-white text-blue-600 font-bold rounded-lg hover:bg-blue-50 transition-all duration-300 shadow-lg hover:shadow-xl hover:scale-105"
                                >
                                    Baca Selengkapnya
                                    <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                                    </svg>
                                </a>
                            </div>
                        </div>

                        <!-- Right Image -->
                        <div class="flex items-center justify-center">
                            <div class="relative rounded-2xl overflow-hidden shadow-2xl w-full h-80 lg:h-96 border-4 border-white">
                                {posts[0].thumbnailUrl ? (
                                    <img
                                        src={posts[0].thumbnailUrl}
                                        alt={posts[0].title}
                                        class="absolute inset-0 w-full h-full object-cover"
                                    />
                                ) : (
                                    <div class="absolute inset-0 w-full h-full bg-white/20 backdrop-blur-sm flex items-center justify-center">
                                        <svg class="w-24 h-24 text-white/50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                                        </svg>
                                    </div>
                                )}
                            </div>
                        </div>
                    </div>
                </div>
            )}

            <!-- 2 Column Layout or Empty State -->
            {posts.length > 0 ? (
                <!-- 2 Column Layout: Blog List (Left) + Categories (Right) -->
                <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 mt-12">
                    <!-- Left Column: Blog Posts -->
                    <div class="lg:col-span-9">
                        {
                            // Page 1: Show posts 2-10 (skip first for featured), Page 2+: Show all posts
                            (currentPage === 1 ? posts.length > 1 : posts.length > 0) ? (
                                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                                    {(currentPage === 1 ? posts.slice(1) : posts).map((post) => (
                                        <article class="group bg-white dark:bg-gray-800 rounded-2xl shadow-md overflow-hidden border border-gray-200 dark:border-gray-700 hover:shadow-2xl transition-all duration-300 hover:-translate-y-1 flex flex-col h-full">
                                            <!-- Thumbnail Image -->
                                            <a href={`/${post.slug}`} class="block relative h-48 overflow-hidden bg-gradient-to-br from-blue-100 to-purple-100 dark:from-gray-700 dark:to-gray-600 flex-shrink-0">
                                                {post.thumbnailUrl ? (
                                                    <img
                                                        src={post.thumbnailUrl}
                                                        alt={post.title}
                                                        class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-300"
                                                    />
                                                ) : (
                                                    <div class="w-full h-full flex items-center justify-center">
                                                        <svg
                                                            class="w-16 h-16 text-gray-400 dark:text-gray-500"
                                                            fill="none"
                                                            stroke="currentColor"
                                                            viewBox="0 0 24 24"
                                                        >
                                                            <path
                                                                stroke-linecap="round"
                                                                stroke-linejoin="round"
                                                                stroke-width="2"
                                                                d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"
                                                            />
                                                        </svg>
                                                    </div>
                                                )}
                                            </a>

                                            <!-- Content -->
                                            <div class="p-5 flex-grow">
                                                <!-- Author & Date -->
                                                <div class="flex items-center gap-2 mb-3 text-sm text-gray-600 dark:text-gray-400">
                                                    <svg
                                                        class="w-4 h-4"
                                                        fill="currentColor"
                                                        viewBox="0 0 20 20"
                                                    >
                                                        <path
                                                            fill-rule="evenodd"
                                                            d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z"
                                                            clip-rule="evenodd"
                                                        />
                                                    </svg>
                                                    <span class="font-medium">Admin</span>
                                                    <span class="text-gray-400">•</span>
                                                    <span>
                                                        {new Date(
                                                            post.createdAt,
                                                        ).toLocaleDateString("id-ID", {
                                                            year: "numeric",
                                                            month: "long",
                                                            day: "numeric",
                                                        })}
                                                    </span>
                                                </div>

                                                <!-- Title -->
                                                <a href={`/${post.slug}`} class="block">
                                                    <h2 class="text-lg font-bold text-gray-900 dark:text-white mb-3 line-clamp-2 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">
                                                        {post.title}
                                                    </h2>
                                                </a>

                                                <!-- Description/Excerpt -->
                                                <p class="text-gray-600 dark:text-gray-300 text-sm line-clamp-3">
                                                    {post.metaDescription || post.content.replace(/<[^>]*>/g, '').substring(0, 120) + "..."}
                                                </p>
                                            </div>

                                            <!-- Footer: Views & Read More -->
                                            <div class="flex items-center justify-between px-5 py-3 bg-gray-50 dark:bg-gray-700/50 border-t border-gray-100 dark:border-gray-700 mt-auto flex-shrink-0">
                                                <div class="flex items-center gap-1 text-gray-500 dark:text-gray-400 text-sm">
                                                    <svg
                                                        class="w-4 h-4"
                                                        fill="none"
                                                        stroke="currentColor"
                                                        viewBox="0 0 24 24"
                                                    >
                                                        <path
                                                            stroke-linecap="round"
                                                            stroke-linejoin="round"
                                                            stroke-width="2"
                                                            d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"
                                                        />
                                                        <path
                                                            stroke-linecap="round"
                                                            stroke-linejoin="round"
                                                            stroke-width="2"
                                                            d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"
                                                        />
                                                    </svg>
                                                    <span>0</span>
                                                </div>

                                                <a
                                                    href={`/${post.slug}`}
                                                    class="inline-flex items-center text-blue-600 dark:text-blue-400 hover:text-blue-700 dark:hover:text-blue-300 font-semibold text-sm transition-colors group/link"
                                                >
                                                    Baca
                                                    <svg
                                                        class="w-4 h-4 ml-1 group-hover/link:translate-x-1 transition-transform"
                                                        fill="none"
                                                        stroke="currentColor"
                                                        viewBox="0 0 24 24"
                                                    >
                                                        <path
                                                            stroke-linecap="round"
                                                            stroke-linejoin="round"
                                                            stroke-width="2"
                                                            d="M9 5l7 7-7 7"
                                                        />
                                                    </svg>
                                                </a>
                                            </div>
                                        </article>
                                    ))}
                                </div>
                            ) : null
                        }

                        <!-- Pagination -->
                        <div class="mt-8">
                            <PaginationContent 
                                listData={paginationData}
                                isEmptyList={posts.length === 0}
                                baseUrl="/blog"
                            />
                        </div>
                    </div>

                    <!-- Right Column: Categories Sidebar -->
                    <aside class="lg:col-span-3">
                        <div class="sticky top-4 space-y-6">
                            <!-- Brochure Request Form -->
                            <BrochureRequestForm />
                            
                            <!-- Categories Card -->
                            <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md border border-gray-200 dark:border-gray-700 overflow-hidden">
                                <!-- Header -->
                                <div class="bg-[#1055C9] p-4">
                                    <h3 class="text-lg font-bold text-white flex items-center gap-2">
                                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/>
                                        </svg>
                                        Kategori
                                    </h3>
                                </div>
                                
                                <!-- Categories List -->
                                <div class="p-4">
                                    {categories.length > 0 ? (
                                        <div class="space-y-1">
                                            {categories.map((category) => (
                                                <a
                                                    href={`/blog/kategori/${category.slug}`}
                                                    class="flex items-center justify-between px-4 py-3 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700/50 transition-colors group"
                                                >
                                                    <div class="flex items-center gap-3">
                                                        <div 
                                                            class="w-2.5 h-2.5 rounded-full flex-shrink-0" 
                                                            style={`background-color: ${category.color}`}
                                                        ></div>
                                                        <span class="text-gray-700 dark:text-gray-300 group-hover:text-gray-900 dark:group-hover:text-white font-medium">
                                                            {category.name}
                                                        </span>
                                                    </div>
                                                    <svg class="w-4 h-4 text-gray-400 group-hover:text-gray-600 dark:group-hover:text-gray-300 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                                                    </svg>
                                                </a>
                                            ))}
                                        </div>
                                    ) : (
                                        <p class="text-gray-500 dark:text-gray-400 text-sm text-center py-8">
                                            Belum ada kategori
                                        </p>
                                    )}
                                </div>
                            </div>
                        </div>
                    </aside>
                </div>
            ) : (
                <!-- Empty State - Centered, No Sidebar -->
                <div class="flex items-center justify-center min-h-[400px]">
                    <div class="text-center py-12 max-w-md">
                        <svg
                            class="mx-auto h-24 w-24 text-gray-400 mb-6"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
                            />
                        </svg>
                        <h3 class="text-2xl font-bold text-gray-900 dark:text-white mb-2">
                            Belum ada artikel
                        </h3>
                        <p class="text-gray-600 dark:text-gray-400 mb-6">
                            Artikel blog akan segera ditambahkan.
                        </p>
                        <a
                            href="/"
                            class="inline-flex items-center px-6 py-3 bg-blue-600 text-white font-semibold rounded-lg hover:bg-blue-700 transition-colors"
                        >
                            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
                            </svg>
                            Kembali ke Beranda
                        </a>
                    </div>
                </div>
            )}
