---
import { User } from '@lucide/astro';
import Breadcrumb from './Breadcrumb.astro';
const { title, breadcrumbs, date, page, author } = Astro.props;
---

<div class="bg-white dark:bg-gray-900 py-5">
    <div class="max-w-screen-xl mx-auto px-4">
        <!-- Breadcrumbs -->
        <div class="mb-6">
            <Breadcrumb breadcrumbs={breadcrumbs} />
        </div>
        
        <!-- Main Title -->
        <h1 class="text-2xl md:text-3xl lg:text-3xl font-bold text-black dark:text-white mb-4 leading-tight">
            {title}
        </h1>
        
        <!-- Metadata -->
        <div class="text-sm text-gray-500 dark:text-gray-400">
            <span class="uppercase">POSTED ON {date}</span>
            <span class="mx-2">•</span>
            <span class="text-red-500 dark:text-red-400 uppercase">{page}</span>
            <span class="mx-2 hidden md:inline">•</span>
            <span class="text-red-500 dark:text-red-400 uppercase flex items-center gap-1 md:inline">
                <User class="w-3 h-3 md:hidden" />
                BY {author}
            </span>
        </div>
    </div>
</div>
