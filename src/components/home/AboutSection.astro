                            class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M9 5l7 7-7 7"></path>
                        </svg>
                    </div>
                </div>
            </a>

            <!-- Peringkat 8 Nasional -->
            <a
                href="https://www.4icu.org/id/private/"
                target="_blank"
                rel="noopener noreferrer"
                class="group bg-white dark:bg-gray-800 rounded-xl shadow-lg p-8 border-2 border-gray-200 dark:border-gray-700 hover:border-[#1055C9] dark:hover:border-[#1055C9] hover:shadow-2xl transition-all duration-300 transform hover:-translate-y-1"
            >
                <div class="text-center">
                    <h3
                        class="text-xl md:text-2xl font-bold mb-6 text-gray-900 dark:text-white"
                    >
                        PTS Peringkat 8 Nasional 2025
