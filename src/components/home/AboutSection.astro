---
const { websiteInfo } = Astro.props;
import BrochureRequestFormModal from "@components/blog/BrochureRequestFormModal.astro";
---

<!-- Brochure Request Form Modal - placed in modals slot to avoid z-index issues -->
<BrochureRequestFormModal slot="modals" autoOpen={false} />

<section class="py-16 bg-gray-50 dark:bg-gray-900">
    <div class="max-w-screen-xl mx-auto px-4">
        <div class="text-center mb-12">
            <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold mb-4">
                <span class="text-gray-900 dark:text-white">Kelas Karyawan</span
                >
                <span
                    class="bg-gradient-to-r from-[#1055C9] to-[#05339C] bg-clip-text text-transparent"
                    >Kampus Terbaik</span
                >
            </h2>
        </div>

        <!-- YouTube Video Section -->
        <div class="mb-12 max-w-3xl mx-auto">
            <div
                class="bg-white dark:bg-gray-800 rounded-xl p-4 md:p-6 border border-gray-200 dark:border-gray-700"
            >
                <div class="aspect-video rounded-lg overflow-hidden">
                    <iframe
                        width="100%"
                        height="100%"
                        src={websiteInfo.youtubeVideoUrl}
                        title="Profile Universitas STEKOM 2025"
                        frameborder="0"
                        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                        referrerpolicy="strict-origin-when-cross-origin"
                        allowfullscreen
                        class="w-full h-full"></iframe>
                </div>
                <p
                    class="text-center mt-4 text-sm font-semibold text-gray-700 dark:text-gray-300"
                >
                    Profile Universitas STEKOM 2025
                </p>
            </div>
            <div class="text-center mt-6">
                <button
                    id="scroll-to-brochure-form"
                    class="inline-flex items-center justify-center bg-gradient-to-r from-[#1055C9] to-[#05339C] hover:from-[#05339C] hover:to-[#1055C9] text-white px-8 py-4 rounded-lg font-bold text-base transition-all duration-300 shadow-lg hover:shadow-xl transform hover:-translate-y-0.5"
                >
                    <svg
                        class="w-5 h-5 mr-2"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M9 19l3 3m0 0l3-3m-3 3V10"
                        ></path>
                    </svg>
                    Download Brosur
                </button>
            </div>
        </div>

        <script>
            function initScrollButton() {
                const scrollButton = document.getElementById(
                    "scroll-to-brochure-form",
                );

                if (scrollButton) {
                    scrollButton.addEventListener("click", function () {
                        // Open brochure form modal
                        if (
                            typeof window.openBrochureFormModal === "function"
                        ) {
                            window.openBrochureFormModal();
                        } else {
                            console.error(
                                "❌ openBrochureFormModal function not found!",
                            );
                        }
                    });
                }
            }

            // Run initialization when DOM is ready
            if (document.readyState === "loading") {
                document.addEventListener("DOMContentLoaded", initScrollButton);
            } else {
                // DOM already loaded, run immediately
                initScrollButton();
            }
        </script>

        <!-- Info Section -->
        <div class="text-center max-w-3xl mx-auto mt-8">
            <h3 class="text-lg md:text-2xl font-bold leading-relaxed mb-6">
                <span
                    class="bg-gradient-to-r from-[#1055C9] to-[#05339C] bg-clip-text text-transparent"
                >
                    Diselenggarakan Oleh PTS Terbaik Peringkat 1 Jawa Tengah
                    2025
                </span>
            </h3>
            <p
                class="text-lg md:text-xl text-gray-700 dark:text-gray-300 leading-relaxed mb-6"
            >
                Universitas Sains & Teknologi Komputer meraih peringkat 1 PTS
                terbaik di Jawa Tengah dan 5 Besar Nasional tahun 2023 menurut
                Unirank, sebuah lembaga pemeringkatan universitas dunia. Bukti
                klik di bawah ini :
            </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-12">
            <!-- Peringkat 1 Jawa Tengah -->
            <a
                href="https://www.4icu.org/id/central-java/"
                target="_blank"
                rel="noopener noreferrer"
                class="group bg-gradient-to-br from-[#1055C9] to-[#05339C] rounded-xl shadow-lg p-8 hover:shadow-2xl transition-all duration-300 transform hover:-translate-y-1"
            >
                <div class="text-center">
                    <h3 class="text-xl md:text-2xl font-bold mb-6 text-white">
                        PTS Peringkat 1 Jawa Tengah 2025
                    </h3>
                    <div class="mb-6">
                        <span class="text-7xl md:text-8xl font-bold text-white"
                            >#1</span
