---
const { websiteInfo } = Astro.props;
import BrochureRequestFormModal from "@components/blog/BrochureRequestFormModal.astro";

const spotlightRanks = [
  {
    rank: "#1",
    label: "PTS Jawa Tengah",
    source: "UniRank 2026",
    accent: "from-[#FF8C00] to-[#E67300]",
    description:
      "Peringkat 1 PTS Jawa Tengah versi UniRank 2026 yang menguatkan reputasi STEKOM.",
    items: [
      "PTS di Semarang Peringkat 1",
      "PTS di Jawa Tengah Peringkat 1",
      "PTS di Indonesia Peringkat 13",
      "PTN & PTS di Semarang Peringkat 3",
      "PTN & PTS di Jawa Tengah Peringkat 5",
    ],
  },
  {
    rank: "#4",
    label: "PTS Jawa Tengah",
    source: "Webometrics Impact Rank 2026",
    accent: "from-[#FF8C00] to-[#E67300]",
    description:
      "Peringkat 4 PTS Jawa Tengah versi Webometrics 2026 yang menguatkan visibilitas STEKOM.",
    items: [
      "PTS di Semarang Peringkat 2",
      "PTS di Jawa Tengah Peringkat 4",
      "PTS di Indonesia Peringkat 32",
      "PTN & PTS di Semarang Peringkat 4",
      "PTN & PTS di Jawa Tengah Peringkat 8",
    ],
  },
];

const parseRankingItem = (item: string) => {
  const match = item.match(/^(.*)\sPeringkat\s(\d+)$/);

  if (!match) {
    return {
      label: item,
      rank: null,
    };
  }

  return {
    label: match[1].trim(),
    rank: `Peringkat ${match[2]}`,
    rankNumber: Number(match[2]),
  };
};
const getInitialQuotaData = () => {
  const updateDate = new Intl.DateTimeFormat("id-ID", {
    day: "2-digit",
    month: "long",
    year: "numeric",
    timeZone: "Asia/Jakarta",
  })
    .format(new Date())
    .toUpperCase();

  const CAPACITY = 500;
  const BONUS_QUOTA = 500;
  const BASE_REGISTERED = 5;
  const DAILY_INCREMENT = 3;

  const parts = new Intl.DateTimeFormat("en-US", {
    timeZone: "Asia/Jakarta",
    hour12: false,
    hourCycle: "h23",
    day: "numeric",
    hour: "numeric",
  }).formatToParts(new Date());

  const dayPart = parts.find((p) => p.type === "day")?.value;
  const hourPart = parts.find((p) => p.type === "hour")?.value;

  const day = dayPart ? Number(dayPart) : 1;
  const hour = hourPart ? Number(hourPart) : 0;

  const dayIndex = hour >= 8 ? day : day - 1;
  const registered = BASE_REGISTERED + Math.max(0, dayIndex) * DAILY_INCREMENT;
  const available = Math.max(CAPACITY - registered + BONUS_QUOTA, 0);

  return {
    updateDate,
    registered,
    capacity: CAPACITY,
    bonusQuota: BONUS_QUOTA,
    available,
  };
};

const initialQuotaData = getInitialQuotaData();
