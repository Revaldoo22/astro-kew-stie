          id="sticky-quota-daftar"
          href="#promokelaskaryawan"
          class="mt-2.5 inline-flex w-full items-center justify-center rounded-md sm:rounded-lg bg-gradient-to-r from-green-500 to-emerald-600 px-2.5 py-1.5 text-xs sm:text-base lg:text-[0.95rem] font-bold text-white shadow-md transition-all hover:from-green-600 hover:to-emerald-700"
