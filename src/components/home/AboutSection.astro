    <script>
      function initScrollButton() {
        const scrollButton = document.getElementById("scroll-to-brochure-form");

        if (scrollButton) {
          scrollButton.addEventListener("click", function () {
            // Open brochure form modal
            if (typeof window.openBrochureFormModal === "function") {
              window.openBrochureFormModal();
            } else {
              console.error("❌ openBrochureFormModal function not found!");
            }
          });
        }
      }

      function formatIdNumber(value: number) {
        return new Intl.NumberFormat("id-ID").format(
          Math.max(0, Math.round(value)),
        );
      }

      async function initQuotaData() {
        const stickyDate = document.getElementById("sticky-quota-update-date");
        const stickyProgress = document.getElementById("sticky-quota-progress");
        const stickyAvailable = document.getElementById(
          "sticky-quota-available",
        );

        if (!stickyDate || !stickyProgress || !stickyAvailable) {
          return;
        }

        try {
          const response = await fetch("/api/quota");

          if (!response.ok) {
            throw new Error("Failed to fetch quota data");
          }

          const data = await response.json();
          const nextRegistered = Number(data.registered) || 0;
          const nextCapacity = Number(data.capacity) || 500;
          const nextBonusQuota = Number(data.bonusQuota) || 500;
          const nextAvailable = Number(data.available) || 0;

          stickyDate.textContent = data.updateDate;
          stickyProgress.textContent = `${formatIdNumber(
            nextRegistered,
          )} / ${formatIdNumber(nextCapacity)} (+${formatIdNumber(
            nextBonusQuota,
          )})`;
          stickyAvailable.textContent = `Tersedia ${formatIdNumber(
            nextAvailable,
          )}`;
        } catch (error) {
          console.error("Failed to load quota data:", error);
        }
      }

      function startQuotaAutoRefresh() {
        const refreshIntervalMs = 60_000;

        initQuotaData();
        window.setInterval(() => {
          initQuotaData();
        }, refreshIntervalMs);

        document.addEventListener("visibilitychange", () => {
          if (document.visibilityState === "visible") {
            initQuotaData();
          }
        });

        window.addEventListener("focus", () => {
          initQuotaData();
        });
      }

      function initStickyDaftarButton() {
        const stickyDaftarButton = document.getElementById(
          "sticky-quota-daftar",
        );
        if (!stickyDaftarButton) {
          return;
        }

        stickyDaftarButton.addEventListener("click", function (event) {
          event.preventDefault();
          const targetSection = document.getElementById("promokelaskaryawan");
          if (!targetSection) {
            return;
          }

          targetSection.scrollIntoView({
            behavior: "smooth",
            block: "start",
          });
        });
      }

      // Run initialization when DOM is ready
      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", function () {
          initScrollButton();
          initStickyDaftarButton();
          startQuotaAutoRefresh();
        });
      } else {
        // DOM already loaded, run immediately
        initScrollButton();
        initStickyDaftarButton();
        startQuotaAutoRefresh();
      }
    </script>

