---
// Achievements Section Component
---

<section class="py-16 bg-gray-50 dark:bg-gray-900">
    <div class="max-w-screen-xl mx-auto px-4">
        <div class="text-center mb-12">
            <div class="inline-block mb-4">
                <span
                    class="inline-flex items-center px-4 py-2 rounded-full text-sm font-bold bg-gradient-to-r from-[#1055C9] to-[#05339C] text-white shadow-lg"
                >
                    Peringkat 1 Jawa Tengah 2024
                </span>
            </div>
            <h2
                class="text-3xl md:text-4xl lg:text-5xl font-bold mb-4 text-gray-900 dark:text-white"
            >
                Diselenggarakan Oleh <span
                    class="bg-gradient-to-r from-[#1055C9] to-[#05339C] bg-clip-text text-transparent"
                    >PTS Terbaik</span
                >
            </h2>
            <p
                class="text-lg md:text-xl text-gray-600 dark:text-gray-400 max-w-2xl mx-auto"
            >
                Universitas STEKOM meraih prestasi gemilang sebagai Perguruan
                Tinggi Swasta terbaik di Jawa Tengah
            </p>
        </div>

        <!-- YouTube Video Section -->
        <div class="mb-12 max-w-3xl mx-auto">
            <div
                class="bg-white dark:bg-gray-800 rounded-xl p-4 md:p-6 border border-gray-200 dark:border-gray-700"
            >
                <div class="aspect-video rounded-lg overflow-hidden">
                    <iframe
                        width="100%"
                        height="100%"
                        src="https://www.youtube.com/embed/ShrAW2cZi9M?si=2dxuHIdFw1k_UFkO"
                        title="Profile Universitas STEKOM 2025"
                        frameborder="0"
                        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                        referrerpolicy="strict-origin-when-cross-origin"
                        allowfullscreen
                        class="w-full h-full"></iframe>
                </div>
                <p
                    class="text-center mt-4 text-sm font-semibold text-gray-700 dark:text-gray-300"
                >
                    Profile Universitas STEKOM 2025
                </p>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-12">
            <!-- Peringkat 1 Jawa Tengah -->
            <a
                href="https://www.4icu.org/id/central-java/"
                target="_blank"
                rel="noopener noreferrer"
                class="group bg-gradient-to-br from-[#1055C9] to-[#05339C] rounded-xl shadow-lg p-8 hover:shadow-2xl transition-all duration-300 transform hover:-translate-y-1"
            >
                <div class="text-center">
                    <div class="inline-block mb-4">
                        <span class="text-6xl font-bold text-white/90">#1</span>
                    </div>
                    <h3 class="text-2xl md:text-3xl font-bold mb-3 text-white">
                        PTS Peringkat 1 Jawa Tengah 2024
                    </h3>
                    <!-- <p class="text-white/80 text-lg mb-4">Menurut Unirank</p> -->
                    <div
                        class="inline-flex items-center text-white/90 group-hover:text-white transition-colors"
                    >
                        <span class="text-sm font-semibold"
                            >Lihat Peringkat</span
                        >
                        <svg
                            class="w-4 h-4 ml-2 group-hover:translate-x-1 transition-transform"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M9 5l7 7-7 7"></path>
                        </svg>
                    </div>
                </div>
            </a>

            <!-- Peringkat 8 Nasional -->
            <a
                href="https://www.4icu.org/id/private/"
                target="_blank"
                rel="noopener noreferrer"
                class="group bg-white dark:bg-gray-800 rounded-xl shadow-lg p-8 border-2 border-gray-200 dark:border-gray-700 hover:border-[#1055C9] dark:hover:border-[#1055C9] hover:shadow-2xl transition-all duration-300 transform hover:-translate-y-1"
            >
                <div class="text-center">
                    <div class="inline-block mb-4">
                        <span
                            class="text-6xl font-bold bg-gradient-to-r from-[#1055C9] to-[#05339C] bg-clip-text text-transparent"
                            >#8</span
                        >
                    </div>
                    <h3
                        class="text-2xl md:text-3xl font-bold mb-3 text-gray-900 dark:text-white"
                    >
                        PTS Peringkat 8 Nasional 2024
                    </h3>
                    <!-- <p class="text-gray-600 dark:text-gray-400 text-lg mb-4">
                        5 Besar Nasional
                    </p> -->
                    <div
                        class="inline-flex items-center text-[#1055C9] group-hover:text-[#05339C] transition-colors"
                    >
                        <span class="text-sm font-semibold"
                            >Lihat Peringkat</span
                        >
                        <svg
                            class="w-4 h-4 ml-2 group-hover:translate-x-1 transition-transform"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M9 5l7 7-7 7"></path>
                        </svg>
                    </div>
                </div>
            </a>
        </div>

        <!-- Info Section -->
        <div class="text-center max-w-3xl mx-auto mt-8">
            <p
                class="text-lg md:text-xl text-gray-700 dark:text-gray-300 leading-relaxed mb-6"
            >
                Universitas Sains & Teknologi Komputer meraih <strong
                    class="text-[#1055C9]"
                    >peringkat 1 PTS terbaik di Jawa Tengah</strong
                > dan <strong class="text-[#1055C9]">5 Besar Nasional</strong> tahun
                2024 menurut <strong>Unirank</strong>, sebuah lembaga
                pemeringkatan universitas dunia yang terpercaya.
            </p>

            <a
                href="#"
                class="inline-flex items-center justify-center bg-gradient-to-r from-[#1055C9] to-[#05339C] hover:from-[#05339C] hover:to-[#1055C9] text-white px-8 py-4 rounded-lg font-bold text-base transition-all duration-300 shadow-lg hover:shadow-xl transform hover:-translate-y-0.5"
            >
                <svg
                    class="w-5 h-5 mr-2"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M9 19l3 3m0 0l3-3m-3 3V10"
                    ></path>
                </svg>
                Download Brosur
            </a>
        </div>
    </div>
</section>
