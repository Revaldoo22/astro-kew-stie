---
const { websiteInfo } = Astro.props;
---

<section
  class="py-12 bg-white dark:bg-gray-900 transition-colors duration-200 animate-fade-in-up mb-10"
>
  <div class="max-w-7xl mx-auto px-0">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <!-- Left Column - Text Content -->
      <div class="space-y-6">
        <div
          class="relative animate-slide-up-fade"
          style="animation-delay: 0.1s;"
        >
          <h2 class="text-5xl font-black leading-tight mb-1 relative z-10">
            <span class="text-[#1055C9] dark:text-white">
              {websiteInfo.name || ""}
            </span>
          </h2>
        </div>

        <div
          class="space-y-4 text-gray-600 dark:text-gray-300 leading-relaxed transition-colors duration-200 animate-slide-up-fade"
          style="animation-delay: 0.2s;"
        >
          <div class="text-justify" set:html={websiteInfo.aboutDescription} />
        </div>

        <div class="pt-2 animate-slide-up-fade" style="animation-delay: 0.3s;">
          <a
            href={websiteInfo.aboutUrl || "#"}
            class="cursor-pointer font-semibold py-2 px-4 rounded-xl shadow-lg hover:shadow-xl transition-all duration-300 border inline-block"
            style="background: linear-gradient(to right, #1055C9, #b71c3b); border-color: #1055C9; color: #fff;"
            target="_blank"
            rel="noopener noreferrer"
          >
            <span class="flex items-center gap-2">
              <span>Read More</span>
              <svg
                class="w-5 h-5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
              </svg>
            </span>
          </a>
        </div>
      </div>

      <!-- Right Column - Image/Video Content -->
      <div class="relative animate-scale-in" style="animation-delay: 0.4s;">
        <div
          class="relative rounded-2xl overflow-hidden shadow-2xl dark:shadow-gray-900/50 transition-shadow duration-200"
        >
          <!-- University Interior Image -->
          <img
            src={websiteInfo.aboutImage || ""}
            alt={websiteInfo.name || ""}
            class="w-full h-96 object-cover dark:brightness-90 dark:contrast-110 transition-all duration-200"
            onerror="this.src='data:image/svg+xml;base64,'"
          />

          <!-- Dark Overlay untuk mengurangi kecerahan -->
          <div
            class="absolute inset-0 bg-black/20 dark:bg-black/30 transition-all duration-200"
          >
          </div>

          <!-- Video Play Button Overlay -->
          <div class="absolute inset-0 flex items-center justify-center">
            <button
              class="bg-white cursor-pointer dark:bg-gray-800 bg-opacity-90 dark:bg-opacity-90 hover:bg-opacity-100 dark:hover:bg-opacity-100 rounded-full p-6 shadow-lg dark:shadow-gray-900/25 transition-all duration-300"
            >
              <svg
                class="w-8 h-8 text-gray-800 dark:text-white ml-1"
                fill="currentColor"
                viewBox="0 0 24 24"
              >
                <path d="M8 5v14l11-7z"></path>
              </svg>
            </button>
          </div>

          <!-- University Branding Overlay -->
          <!-- <div class="absolute top-4 left-4 bg-white dark:bg-gray-800 bg-opacity-95 dark:bg-opacity-95 backdrop-blur-sm rounded-lg p-2 shadow-lg dark:shadow-gray-900/25 transition-all duration-300 border border-gray-200/30 dark:border-gray-700/30 max-w-xs">
            <div class="flex items-start space-x-3">
              <div class="flex-1 min-w-0">
                <div class="flex items-center mb-1">
                  <div class="w-2 h-2 bg-red-500 dark:bg-red-400 rounded-full mr-2"></div>
                  <h3 class="font-bold text-red-600 dark:text-red-400 text-lg leading-tight transition-colors duration-200 truncate">{websiteInfo.name || ""}</h3>
                </div>
                <p class="text-xs text-gray-600 dark:text-gray-300 font-medium transition-colors duration-200 leading-relaxed">SEHATIKU = STEKOM SAHABAT DISABILITAS!</p>
              </div>
            </div>
          </div> -->
        </div>

        <!-- Decorative Elements -->
        <div
          class="absolute -top-4 -right-4 w-24 h-24 bg-orange-100 dark:bg-orange-900/30 rounded-full opacity-50 transition-colors duration-200"
        >
        </div>
        <div
          class="absolute -bottom-4 -left-4 w-16 h-16 bg-blue-100 dark:bg-blue-900/30 rounded-full opacity-50 transition-colors duration-200"
        >
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* Dark mode image adjustments */
  @media (prefers-color-scheme: dark) {
    img {
      filter: brightness(0.9) contrast(1.1);
    }
  }

  /* Responsive adjustments */
  @media (max-width: 768px) {
    .grid {
      gap: 2rem;
    }

    h2 {
      font-size: 2.5rem;
    }

    /* Mobile button adjustments */
    button {
      padding: 0.75rem 1.5rem;
      font-size: 0.875rem;
    }
  }

  @media (max-width: 480px) {
    h2 {
      font-size: 2rem;
    }

    /* Smaller decorative underline on mobile */
    .relative.h-2.w-32 {
      width: 4rem;
      height: 0.25rem;
    }
  }
</style>
