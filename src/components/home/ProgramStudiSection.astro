---
// Program Studi Section Component
---

<section class="py-16 bg-gray-50 dark:bg-gray-900">
    <div class="max-w-screen-xl mx-auto px-4">
        <!-- Header -->
        <div class="text-center mb-12">
            <h2
                class="text-3xl md:text-4xl lg:text-5xl font-bold mb-4 bg-gradient-to-r from-[#1055C9] to-[#05339C] bg-clip-text text-transparent"
            >
                Program Studi atau Jurusan Kelas Karyawan
            </h2>
            <p
                class="text-lg md:text-xl text-gray-700 dark:text-gray-300 max-w-3xl mx-auto mb-4"
            >
                Tersedia Pilihan Gratis Biaya SPI di Semua Jurusan!
            </p>
            <p
                class="text-base text-gray-600 dark:text-gray-400 max-w-2xl mx-auto"
            >
                Berikut adalah pilihan biaya kuliah (Semua Program Studi):
            </p>
        </div>

        <!-- Program Studi Grid -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 max-w-5xl mx-auto">
            <!-- Program Studi Sarjana -->
