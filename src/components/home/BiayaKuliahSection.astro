                    </span>
                </p>

                <div
                    class="overflow-x-auto rounded-xl border-2 border-gray-200 dark:border-gray-700"
                >
                    <table class="w-full">
                        <thead
                            class="bg-gradient-to-r from-[#FF8C00] to-[#E67300] text-white"
                        >
                            <tr>
                                <th class="px-6 py-4 text-left font-bold">Item</th>
                                <th class="px-6 py-4 text-left font-bold">Biaya</th>
                            </tr>
                        </thead>
                        <tbody class="bg-white dark:bg-gray-800">
                            <tr
