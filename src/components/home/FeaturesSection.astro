---
// Features/Keunggulan Section Component
const features = [
    {
        title: "Kuliah Full Online Hybrid Fleksibel",
        description: "Kuliah dari daerah Anda dengan sistem hybrid learning yang fleksibel.",
    },
    {
        title: "6000+ Mahasiswa Aktif",
        description: "Kuliah sambil kerja merupakan kebanggaan bagi 6000 lebih mahasiswa aktif.",
    },
    {
        title: "90% Sudah Bekerja",
        description: "90% mahasiswa sudah memperoleh pekerjaan dan sukses di dunia kerja sebelum wisuda.",
    },
    {
        title: "Jadwal Fleksibel",
        description: "Kuliah Sabtu Minggu atau Weekend tanpa mengganggu jam kerja.",
    },
    {
        title: "Biaya Fleksibel",
        description: "Bisa dipilih sesuai keinginan dan dapat dicicil sesuai kemampuan.",
    },
    {
        title: "Terakreditasi BAN-PT",
        description: "Institusi dan Program Studi terakreditasi Baik oleh BAN-PT.",
    },
];
---

<section class="py-16 bg-white dark:bg-gray-800">
    <div class="max-w-screen-xl mx-auto px-4">
        <!-- Header -->
        <div class="text-center mb-12">
            <div class="inline-block mb-4">
                <span class="inline-flex items-center px-4 py-2 rounded-full text-sm font-bold bg-gradient-to-r from-[#1055C9] to-[#05339C] text-white">
                    Keunggulan Kami
                </span>
            </div>
            <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold mb-4 text-gray-900 dark:text-white">
                Mengapa Memilih <span class="bg-gradient-to-r from-[#1055C9] to-[#05339C] bg-clip-text text-transparent">Kelas Karyawan?</span>
            </h2>
            <p class="text-lg md:text-xl text-gray-600 dark:text-gray-400 max-w-3xl mx-auto">
                Solusi terbaik untuk Anda yang ingin kuliah sambil bekerja dengan berbagai keunggulan yang kami tawarkan
            </p>
        </div>

        <!-- Features Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {features.map((feature, index) => (
                <div class="group bg-white dark:bg-gray-900 rounded-2xl p-6 border border-gray-200 dark:border-gray-700 hover:border-[#1055C9] dark:hover:border-[#1055C9] transition-all duration-300 hover:-translate-y-1">
                    <!-- Content -->
                    <h3 class="text-xl font-bold mb-3 text-gray-900 dark:text-white group-hover:text-[#1055C9] dark:group-hover:text-[#1055C9] transition-colors">
                        {feature.title}
                    </h3>
                    <p class="text-gray-600 dark:text-gray-400 leading-relaxed">
                        {feature.description}
                    </p>
                </div>
            ))}
        </div>
    </div>
</section>
