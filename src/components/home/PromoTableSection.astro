<script define:vars={{ countdownEndDate: websiteInfo.promo.countdownEndDate }}>
    // Countdown Timer - Configurable from info.ts
    // Parse the countdown end date from config (format: "YYYY-MM-DD HH:mm:ss" in WIB/GMT+7)
    const parseCountdownDate = (dateStr) => {
        // If no date is provided, default to 1 month from now
        if (!dateStr || dateStr.trim() === "") {
            return new Date().getTime() + 30 * 24 * 60 * 60 * 1000; // 30 days
        }

        // Parse date string in format "YYYY-MM-DD HH:mm:ss"
        const [datePart, timePart] = dateStr.split(" ");
        const [year, month, day] = datePart.split("-").map(Number);
        const [hours, minutes, seconds] = timePart.split(":").map(Number);

        // Create date in WIB timezone (GMT+7)
        // JavaScript Date uses local timezone, so we create UTC and adjust
        const date = new Date(
            Date.UTC(year, month - 1, day, hours - 7, minutes, seconds),
        );
        return date.getTime();
    };

    const countdownDate = parseCountdownDate(countdownEndDate);

    function updateCountdown() {
        const now = new Date().getTime();
        const distance = countdownDate - now;

        const days = Math.floor(distance / (1000 * 60 * 60 * 24));
        const hours = Math.floor(
            (distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60),
        );
        const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
        const seconds = Math.floor((distance % (1000 * 60)) / 1000);

        const daysEl = document.getElementById("days-promo");
        const hoursEl = document.getElementById("hours-promo");
        const minutesEl = document.getElementById("minutes-promo");
        const secondsEl = document.getElementById("seconds-promo");

        if (daysEl) daysEl.textContent = String(days).padStart(2, "0");
        if (hoursEl) hoursEl.textContent = String(hours).padStart(2, "0");
        if (minutesEl) minutesEl.textContent = String(minutes).padStart(2, "0");
        if (secondsEl) secondsEl.textContent = String(seconds).padStart(2, "0");

        if (distance < 0) {
            clearInterval(countdownInterval);
            if (daysEl) daysEl.textContent = "00";
            if (hoursEl) hoursEl.textContent = "00";
            if (minutesEl) minutesEl.textContent = "00";
            if (secondsEl) secondsEl.textContent = "00";
        }
    }

    const countdownInterval = setInterval(updateCountdown, 1000);
    updateCountdown();
</script>

<style>
    @keyframes gradient {
        0% {
            background-position: 0% 50%;
        }
        50% {
            background-position: 100% 50%;
        }
        100% {
            background-position: 0% 50%;
        }
    }

    .animate-gradient {
        background-size: 200% 200%;
        animation: gradient 3s ease infinite;
    }

    .countdown-item {
        animation: pulse-scale 2s ease-in-out infinite;
    }

    @keyframes pulse-scale {
        0%,
        100% {
            transform: scale(1);
        }
        50% {
            transform: scale(1.05);
        }
    }

    .table-row-hover:hover {
        background: linear-gradient(
            90deg,
            rgba(16, 85, 201, 0.05) 0%,
            rgba(5, 51, 156, 0.05) 100%
        );
        transform: translateX(4px);
    }

    /* Smooth transitions for all interactive elements */
    * {
        transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
    }
</style>
