<script is:inline>
    // Countdown Timer - target = last day of the CURRENT month at 23:59:59 WIB.
    // Computed in the browser (not at build time) so a static build stays correct
    // after the month rolls over without needing a rebuild.
    const getEndOfMonthWIB = () => {
        const now = new Date();
        // Current date as seen on the WIB (GMT+7) wall clock.
        const wib = new Date(now.getTime() + 7 * 60 * 60 * 1000);
        const year = wib.getUTCFullYear();
        const month = wib.getUTCMonth(); // 0-indexed
        // Day 0 of next month = last day of this month, 23:59:59 WIB -> back to UTC.
        return Date.UTC(year, month + 1, 0, 23 - 7, 59, 59);
    };

    let countdownDate = getEndOfMonthWIB();

    function updateCountdown() {
        const now = new Date().getTime();
        // If we've rolled past the end of the month (e.g. tab left open overnight),
        // recompute the target for the new month instead of showing 00.
        if (now > countdownDate) {
            countdownDate = getEndOfMonthWIB();
        }
        const distance = countdownDate - now;

        const days = Math.floor(distance / (1000 * 60 * 60 * 24));
        const hours = Math.floor(
            (distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60),
        );
        const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
        const seconds = Math.floor((distance % (1000 * 60)) / 1000);

        const daysEl = document.getElementById("days-promo");
        const hoursEl = document.getElementById("hours-promo");
        const minutesEl = document.getElementById("minutes-promo");
        const secondsEl = document.getElementById("seconds-promo");

        if (daysEl) daysEl.textContent = String(days).padStart(2, "0");
        if (hoursEl) hoursEl.textContent = String(hours).padStart(2, "0");
        if (minutesEl) minutesEl.textContent = String(minutes).padStart(2, "0");
        if (secondsEl) secondsEl.textContent = String(seconds).padStart(2, "0");

        if (distance < 0) {
            clearInterval(countdownInterval);
            if (daysEl) daysEl.textContent = "00";
            if (hoursEl) hoursEl.textContent = "00";
            if (minutesEl) minutesEl.textContent = "00";
            if (secondsEl) secondsEl.textContent = "00";
        }
    }

    const countdownInterval = setInterval(updateCountdown, 1000);
    updateCountdown();

    async function buildTrackedLink(buttonName, programName, originalText) {
        const params = new URLSearchParams(window.location.search);
        const hostParts = window.location.hostname.split(".");
        const subdomain = hostParts.length >= 3 ? hostParts[0] : "kew";

        const trackingData = JSON.stringify({
            path: window.location.pathname || "/",
            utm_source: params.get("utm_source") || "",
            utm_medium: params.get("utm_medium") || "",
            utm_campaign: params.get("utm_campaign") || "",
            utm_content: params.get("utm_content") || "",
            utm_term: params.get("utm_term") || "",
            button: buttonName || "promo_table_daftar",
            program: programName || "",
        });

        let coupon = "";
        try {
            const formData = new FormData();
            formData.append("source_page", subdomain);
            formData.append("prefix", "KEWSTIE");
            formData.append("data", trackingData);
            const res = await fetch("https://pmb.stekom.ac.id/api/tracking/generate", {
                method: "POST",
                body: formData,
            });
            if (res.ok) {
                const json = await res.json();
                const extractCode = (payload) => {
                    if (!payload || typeof payload !== "object") return "";
                    return (
                        payload.coupon_code ||
                        payload.couponCode ||
                        payload.code ||
                        payload.kode ||
                        payload.coupon ||
                        payload?.data?.coupon_code ||
                        payload?.data?.couponCode ||
                        payload?.data?.code ||
                        payload?.result?.coupon_code ||
                        payload?.result?.code ||
                        payload?.tracking_code ||
                        ""
                    );
                };
                coupon =
                    extractCode(json) ||
                    (typeof json?.message === "string"
                        ? (json.message.match(/[A-Z0-9-]{6,}/)?.[0] ?? "")
                        : "");
            }
        } catch (_) {
            // Continue to link without coupon
        }

        let message = originalText || `Halo Admin, Saya ingin mendaftar ${programName}`;
        if (coupon) {
            message = `${message.trim().replace(/\.$/, "")}. Kode saya: ${coupon}`;
        }
        return `https://link.stekom.ac.id/ads?text=${encodeURIComponent(message)}`;
    }

    const trackedButtons = document.querySelectorAll('a[data-track-generate="1"]');
    trackedButtons.forEach((anchor) => {
        anchor.addEventListener("click", async (event) => {
            event.preventDefault();
            const buttonName = anchor.getAttribute("data-track-button") || "promo_table_daftar";
            const programName = anchor.getAttribute("data-track-program") || "S1 Hukum (S.H.)";
            
            let originalText = "";
            try {
                const url = new URL(anchor.href);
                originalText = url.searchParams.get("text") || "";
            } catch (_) {}

            const trackedLink = await buildTrackedLink(buttonName, programName, originalText);
            window.location.href = trackedLink;
        });
    });
</script>

