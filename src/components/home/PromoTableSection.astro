---

<section id="promokelaskaryawan" class="py-16 bg-gray-50 dark:bg-gray-900">
    <div class="max-w-screen-xl mx-auto px-4">
        <!-- Header -->
        <div class="text-center mb-12">
            <h2
                class="text-3xl md:text-4xl lg:text-5xl font-bold mb-6 bg-gradient-to-r from-[#1055C9] to-[#05339C] bg-clip-text text-transparent"
            >
                PROMO KELAS KARYAWAN
            </h2>

            <!-- Countdown Box -->
            <div class="max-w-3xl mx-auto mb-8">
                <div
                    class="bg-white rounded-2xl p-6 border-2 border-red-300 dark:border-red-800 shadow-xl"
                >
                    <p class="text-base mb-4 text-center">
                        <span class="text-red-600 font-bold"
                            >Berlaku hingga / sampai kuota penuh :</span
                        >
                    </p>
                    <div
                        id="countdown-promo"
                        class="grid grid-cols-4 gap-3 text-center"
                    >
                        <div
                            class="bg-gradient-to-br from-[#1055C9] to-[#05339C] rounded-lg p-3"
                        >
                            <div
                                class="text-2xl md:text-3xl font-bold text-white"
                                id="days-promo"
                            >
                                00
                            </div>
                            <div class="text-xs md:text-sm text-white/90 mt-1">
                                HARI
                            </div>
                        </div>
                        <div
                            class="bg-gradient-to-br from-[#1055C9] to-[#05339C] rounded-lg p-3"
                        >
                            <div
                                class="text-2xl md:text-3xl font-bold text-white"
                                id="hours-promo"
                            >
                                00
                            </div>
                            <div class="text-xs md:text-sm text-white/90 mt-1">
                                JAM
                            </div>
                        </div>
                        <div
                            class="bg-gradient-to-br from-[#1055C9] to-[#05339C] rounded-lg p-3"
                        >
                            <div
                                class="text-2xl md:text-3xl font-bold text-white"
                                id="minutes-promo"
                            >
                                00
                            </div>
                            <div class="text-xs md:text-sm text-white/90 mt-1">
                                MENIT
                            </div>
                        </div>
                        <div
                            class="bg-gradient-to-br from-[#1055C9] to-[#05339C] rounded-lg p-3"
                        >
                            <div
                                class="text-2xl md:text-3xl font-bold text-white"
                                id="seconds-promo"
                            >
                                00
                            </div>
                            <div class="text-xs md:text-sm text-white/90 mt-1">
                                DETIK
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Promo Features -->
            <div class="max-w-3xl mx-auto mb-8">
                <div
                    class="bg-gradient-to-r from-[#1055C9] to-[#05339C] rounded-2xl p-6 text-white"
                >
                    <ul class="space-y-3 text-left">
                        <li class="flex items-start gap-3">
                            <svg
                                class="w-6 h-6 flex-shrink-0 mt-0.5"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M5 13l4 4L19 7"></path>
                            </svg>
                            <span class="font-bold">GRATIS 7 JUTA</span>
                        </li>
                        <li class="flex items-start gap-3">
                            <svg
                                class="w-6 h-6 flex-shrink-0 mt-0.5"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M5 13l4 4L19 7"></path>
                            </svg>
                            <span
                                >Biaya kuliah hanya <strong
                                    >498 rb / Bulan</strong
                                ></span
                            >
                        </li>
                        <li class="flex items-start gap-3">
                            <svg
                                class="w-6 h-6 flex-shrink-0 mt-0.5"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M5 13l4 4L19 7"></path>
                            </svg>
                            <span
                                >Biaya Kuliah Bisa Dipilih Sesuai Keinginan dan
                                Dicicil Sesuai Kemampuan, Tersedia Pilihan <strong
                                    >GRATIS Biaya SPI/ Uang Pangkal</strong
