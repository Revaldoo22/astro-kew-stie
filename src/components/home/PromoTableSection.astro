                            >
                        </li>
                    </ul>
                </div>
            </div>

            <!-- CTA Text -->
            <div class="max-w-2xl mx-auto mb-8">
                <p
                    class="text-2xl md:text-3xl font-bold text-[#1055C9] dark:text-blue-400 mb-2"
                >
                    AMANKAN SEKARANG !!! DAFTAR HANYA 150 RIBU
                </p>
                <p
                    class="text-xl md:text-2xl font-bold text-gray-900 dark:text-white"
                >
                    KULIAH CEPAT LULUS BISA TANPA SKRIPSI!
                </p>
            </div>
        </div>

        <!-- Programs Table -->
        <div class="max-w-6xl mx-auto">
            <!-- Desktop Table -->
            <div class="hidden md:block overflow-x-auto">
                <div
                    class="rounded-2xl border-2 border-gray-200 dark:border-gray-700 shadow-2xl overflow-hidden"
                >
                    <table class="w-full">
                        <thead
                            class="bg-gradient-to-r from-[#1055C9] to-[#05339C] text-white"
                        >
                            <tr>
                                <th
                                    class="px-4 md:px-6 py-4 text-left font-bold text-sm md:text-base"
                                    >Program Studi / Jurusan</th
                                >
                                <th
                                    class="px-4 md:px-6 py-4 text-center font-bold text-sm md:text-base"
                                    >Status Kuota Daftar</th
                                >
                                <th
                                    class="px-4 md:px-6 py-4 text-center font-bold text-sm md:text-base"
                                >
                                    TERSEDIA<br />
                                    <span class="text-xs font-normal"
                                        >GRATIS SPI</span
                                    >
                                </th>
                                <th
                                    class="px-4 md:px-6 py-4 text-center font-bold text-sm md:text-base"
                                >
                                    KLAIM<br />
                                    <span class="text-xs font-normal"
                                        >Hanya 150rb</span
                                    >
                                </th>
                            </tr>
                        </thead>
                        <tbody
                            class="bg-white dark:bg-gray-800 divide-y divide-gray-200 dark:divide-gray-700"
                        >
                            {
                                programs.map((program, index) => (
                                    <tr
                                        class={
                                            index % 2 === 0
                                                ? ""
                                                : "bg-gray-50 dark:bg-gray-900"
                                        }
                                    >
                                        <td class="px-4 md:px-6 py-4">
                                            <div class="flex items-center gap-2 flex-wrap">
                                                <span class="text-gray-900 dark:text-white font-medium text-sm md:text-base">
                                                    {program.name}
                                                </span>
                                                {program.badge && (
                                                    <span class="inline-block bg-red-600 text-white text-xs font-bold px-3 py-1 rounded-full whitespace-nowrap">
                                                        {program.badge}
                                                    </span>
                                                )}
                                            </div>
                                        </td>
                                        <td class="px-4 md:px-6 py-4 text-center">
                                            <span
                                                class={`font-bold text-sm md:text-base ${
                                                    program.statusColor ===
                                                    "green"
                                                        ? "text-green-600 dark:text-green-400"
                                                        : "text-orange-600 dark:text-orange-400"
                                                }`}
                                            >
                                                {program.status}
                                            </span>
                                        </td>
                                        <td class="px-4 md:px-6 py-4 text-center">
                                            {program.gratisSpI && (
                                                <svg
                                                    class="w-8 h-8 md:w-10 md:h-10 text-green-500 mx-auto"
                                                    fill="none"
                                                    stroke="currentColor"
                                                    viewBox="0 0 24 24"
                                                >
                                                    <path
                                                        stroke-linecap="round"
                                                        stroke-linejoin="round"
                                                        stroke-width="3"
                                                        d="M5 13l4 4L19 7"
                                                    />
                                                </svg>
                                            )}
                                        </td>
                                        <td class="px-4 md:px-6 py-4 text-center">
                                            <a
                                                href={`http://link.stekom.ac.id/ads?text=Halo Admin, Saya ingin mendaftar ${program.name} Dengan Pilihan Biaya Gratis SPI/Uang Pangkal`}
                                                target="_blank"
                                                rel="noopener noreferrer"
                                                class="inline-block bg-gradient-to-r from-[#1055C9] to-[#05339C] hover:from-[#05339C] hover:to-[#1055C9] text-white px-6 md:px-8 py-2 md:py-3 rounded-full font-bold text-sm md:text-base transition-all duration-300 shadow-lg hover:shadow-xl transform hover:-translate-y-0.5"
                                            >
                                                Daftar
                                            </a>
                                        </td>
                                    </tr>
                                ))
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Mobile Cards -->
            <div class="md:hidden space-y-4">
                {
                    programs.map((program) => (
                        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-lg border-2 border-gray-200 dark:border-gray-700 p-4">
                            <div class="mb-3">
                                <div class="flex items-center gap-2 flex-wrap mb-2">
                                    <span class="text-gray-900 dark:text-white font-bold text-base">
                                        {program.name}
                                    </span>
                                    {program.badge && (
                                        <span class="inline-block bg-red-600 text-white text-xs font-bold px-3 py-1 rounded-full">
                                            {program.badge}
                                        </span>
                                    )}
                                </div>
                                <div class="flex items-center justify-between text-sm">
                                    <span class="text-gray-600 dark:text-gray-400">
                                        Status:
                                    </span>
                                    <span
                                        class={`font-bold ${
                                            program.statusColor === "green"
                                                ? "text-green-600 dark:text-green-400"
                                                : "text-orange-600 dark:text-orange-400"
                                        }`}
                                    >
                                        {program.status}
                                    </span>
                                </div>
                            </div>
                            <div class="flex items-center justify-between mb-3">
                                <span class="text-gray-600 dark:text-gray-400 text-sm">
                                    GRATIS SPI:
                                </span>
                                {program.gratisSpI && (
                                    <svg
                                        class="w-8 h-8 text-green-500"
                                        fill="none"
                                        stroke="currentColor"
                                        viewBox="0 0 24 24"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="3"
                                            d="M5 13l4 4L19 7"
                                        />
                                    </svg>
                                )}
                            </div>
                            <a
                                href={`http://link.stekom.ac.id/ads?text=Halo Admin, Saya ingin mendaftar ${program.name} Dengan Pilihan Biaya Gratis SPI/Uang Pangkal`}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="block w-full text-center bg-gradient-to-r from-[#1055C9] to-[#05339C] hover:from-[#05339C] hover:to-[#1055C9] text-white px-6 py-3 rounded-full font-bold text-base transition-all duration-300 shadow-lg hover:shadow-xl transform hover:-translate-y-0.5"
                            >
                                Daftar
                            </a>
                        </div>
                    ))
                }
            </div>
        </div>

        <!-- CTA Button -->
        <div class="text-center pt-6">
            <a
                href={`http://link.stekom.ac.id/ads?text=Halo Admin, Saya ingin mendaftar dengan Pilihan Biaya Gratis SPI/Uang Pangkal`}
                class="inline-flex items-center justify-center bg-gradient-to-r from-[#1055C9] to-[#05339C] hover:from-[#05339C] hover:to-[#1055C9] text-white px-8 py-4 rounded-xl font-bold text-lg transition-all duration-300 shadow-lg hover:shadow-xl transform hover:-translate-y-0.5"
            >
                <svg
                    class="w-6 h-6 mr-2"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"
                    ></path>
                </svg>
                Konsultasi Pendaftaran
            </a>
        </div>
    </div>
</section>

<script define:vars={{ countdownEndDate: websiteInfo.promo.countdownEndDate }}>
    // Countdown Timer - Configurable from info.ts
    // Parse the countdown end date from config (format: "YYYY-MM-DD HH:mm:ss" in WIB/GMT+7)
    const parseCountdownDate = (dateStr) => {
        // If no date is provided, default to 1 month from now
        if (!dateStr || dateStr.trim() === "") {
            return new Date().getTime() + 30 * 24 * 60 * 60 * 1000; // 30 days
        }

        // Parse date string in format "YYYY-MM-DD HH:mm:ss"
        const [datePart, timePart] = dateStr.split(" ");
        const [year, month, day] = datePart.split("-").map(Number);
        const [hours, minutes, seconds] = timePart.split(":").map(Number);

        // Create date in WIB timezone (GMT+7)
        // JavaScript Date uses local timezone, so we create UTC and adjust
        const date = new Date(
            Date.UTC(year, month - 1, day, hours - 7, minutes, seconds),
        );
        return date.getTime();
    };

    const countdownDate = parseCountdownDate(countdownEndDate);

    function updateCountdown() {
        const now = new Date().getTime();
        const distance = countdownDate - now;

        const days = Math.floor(distance / (1000 * 60 * 60 * 24));
        const hours = Math.floor(
            (distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60),
        );
        const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
        const seconds = Math.floor((distance % (1000 * 60)) / 1000);

        const daysEl = document.getElementById("days-promo");
        const hoursEl = document.getElementById("hours-promo");
        const minutesEl = document.getElementById("minutes-promo");
        const secondsEl = document.getElementById("seconds-promo");

        if (daysEl) daysEl.textContent = String(days).padStart(2, "0");
        if (hoursEl) hoursEl.textContent = String(hours).padStart(2, "0");
        if (minutesEl) minutesEl.textContent = String(minutes).padStart(2, "0");
        if (secondsEl) secondsEl.textContent = String(seconds).padStart(2, "0");

        if (distance < 0) {
            clearInterval(countdownInterval);
            if (daysEl) daysEl.textContent = "00";
            if (hoursEl) hoursEl.textContent = "00";
            if (minutesEl) minutesEl.textContent = "00";
            if (secondsEl) secondsEl.textContent = "00";
        }
    }

    const countdownInterval = setInterval(updateCountdown, 1000);
    updateCountdown();
</script>
