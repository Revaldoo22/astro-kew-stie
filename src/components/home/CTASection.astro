---
// CTA Section Component
---

<section class="py-20 bg-gradient-to-r from-[#1055C9] to-[#05339C] text-white">
    <div class="max-w-screen-xl mx-auto px-4 text-center">
        <h2 class="text-3xl md:text-5xl font-bold mb-6">
            Siap Memulai Perjalanan Pendidikan Anda?
        </h2>
        <p class="text-xl mb-8 opacity-90 max-w-2xl mx-auto">
            Jangan tunda lagi! Daftar sekarang dan raih masa depan yang lebih
            cerah bersama Universitas STEKOM.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a
                href="https://stekom.ac.id/hal/promo-pmb-2025-kk"
                class="inline-flex items-center justify-center bg-white text-[#1055C9] hover:bg-gray-100 px-10 py-5 rounded-lg font-bold text-lg transition-all duration-300 shadow-2xl hover:scale-105"
            >
                <svg
                    class="w-6 h-6 mr-3"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
                    ></path>
                </svg>
                PENDAFTARAN KLIK DISINI
            </a>
            <a
                href="/hubungi-kami"
                class="inline-flex items-center justify-center bg-transparent border-2 border-white text-white hover:bg-white hover:text-[#1055C9] px-10 py-5 rounded-lg font-bold text-lg transition-all duration-300"
            >
                <svg
                    class="w-6 h-6 mr-3"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"
                    ></path>
                </svg>
                KONSULTASI KLIK DISINI
            </a>
        </div>
    </div>
</section>
