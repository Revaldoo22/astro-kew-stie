---
import Layout from "@layouts/Layout.astro";
import Breadcrumb from "@components/Breadcrumb.astro";

const { slugGalleryPhoto, categoryGalleryPhoto, enGalleryPhoto } = Astro.props;

// Utility imports
import { GalleryApi } from "@/services/index";
import { validateSlug, hasValue, cleanHTML } from '@/utils/helpers/dataHelpers';

// Initialize API service
const galleryApiService = new GalleryApi();

// Validate and sanitize the slug
const slugValidation = validateSlug(slugGalleryPhoto);

if(!slugValidation.isValid) {    
    // Redirect to 404 if slug is invalid
    Astro.redirect("/404");
}

const slug = slugValidation.sanitizedSlug;

const dataPage  = await galleryApiService.fetchGalleryDetailPhotoCategories(slug || "", categoryGalleryPhoto);

if(dataPage === null) {
    Astro.redirect("/404");
}

// TypeScript assertion after null check
const galleryData = dataPage!;

// Function to normalize image URL format
// Removes /conversions/ path and size suffix like -1200x690
const normalizeImageUrl = (url: string): string => {
    if (!url || typeof url !== 'string') return url;
    
    try {
        // Remove /conversions/ from the path
        let normalizedUrl = url.replace('/conversions/', '/');
        
        // Remove size suffix pattern like -1200x690, -1024x512, etc. before file extension
        // Pattern: -digitsxdigits before .jpg, .png, etc.
        normalizedUrl = normalizedUrl.replace(/-\d+x\d+(?=\.[^.]+$)/, '');
        
        return normalizedUrl;
    } catch (error) {
        console.error('Error normalizing image URL:', error);
        return url;
    }
};

// Prepare gallery images array
// Handle both string array and object array formats
const galleryImages: string[] = Array.isArray(galleryData.gallery) 
    ? galleryData.gallery.map((item: any) => {
        if (typeof item === 'string') {
            return normalizeImageUrl(item);
        } else if (item && typeof item === 'object') {
            const url = item.image_url || item.url || null;
            return url ? normalizeImageUrl(url) : null;
        }
        return null;
      }).filter((url): url is string => Boolean(url) && typeof url === 'string')
    : [];

// Normalize main image URL
const normalizedMainImage = galleryData.image_url ? normalizeImageUrl(galleryData.image_url) : null;

// Combine all images (main + gallery) for lightbox
const allImages = [normalizedMainImage, ...galleryImages].filter(Boolean);

// All images for grid display (including main image)
const displayImages: string[] = [normalizedMainImage, ...galleryImages].filter((url): url is string => Boolean(url) && typeof url === 'string');

// Debug: Log images for debugging
if (typeof console !== 'undefined') {
    console.log('Gallery images:', galleryImages);
    console.log('All images:', allImages);
}

// Format date
const formatDate = (dateString: string) => {
    if (!dateString) return '';
    const date = new Date(dateString);
    return date.toLocaleDateString('id-ID', { 
        year: 'numeric', 
        month: 'long', 
        day: 'numeric' 
    });
};

const breadcrumbs = [
    { label: "Home", href: "/" },
    { label: enGalleryPhoto === 0 ? "Galeri" : "Gallery", href: `/${enGalleryPhoto === 0 ? "galeri/foto" : "en/gallery/photo"}` },
    { label: galleryData.title, href: `/${enGalleryPhoto === 0 ? "galeri/foto/" + slug : "en/gallery/photo/" + slug}` },
];

const metaTags = {
    title: galleryData.title,
    description: galleryData.title,
    keywords: enGalleryPhoto === 0 ? "galeri, foto, dokumentasi, gambar, kegiatan, event" : "gallery, photo, documentation, image, activity, event",
    image: galleryData.image_url || '',
};


---

<Layout metaTags={metaTags}>
    <div class="min-h-screen">

        <div class="bg-white dark:bg-gray-900 py-5">
            <div class="max-w-screen-xl mx-auto px-4">
                <!-- Breadcrumbs -->
                <div class="mb-6">
                    <Breadcrumb breadcrumbs={breadcrumbs} />
                </div>
                
                <!-- Main Title -->
                <!-- <h1 class="text-2xl md:text-3xl lg:text-3xl font-bold text-black dark:text-white mb-4 leading-tight">
                    {enGalleryPhoto === 0 ? "Galeri Foto" : "Gallery Photo"} - {dataPage!.title}
                </h1>

                <p class="text-gray-600 dark:text-gray-300 mt-2">
                    {enGalleryPhoto === 0 ? "Kumpulan foto-foto kegiatan dan aktivitas terbaru." : "Collection of photos of activities and events."}
                </p>                 -->
                
            </div>
        </div>
        <div class="max-w-screen-xl mx-auto px-4 py-6">
            <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 p-6">
                {/* Title and Date */}
                <div class="mb-6 pb-6 border-b border-gray-200 dark:border-gray-700">
                    <h1 class="text-3xl md:text-4xl font-bold text-black dark:text-white mb-4 leading-tight">
                        {galleryData.title}
                    </h1>
                    <div class="flex items-center text-gray-600 dark:text-gray-400 text-sm">
                        <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd"/>
                        </svg>
                        <span>{formatDate(galleryData.post_date)}</span>
                    </div>
                </div>

                {/* Gallery Grid - All Images */}
                {displayImages.length > 0 && (
                    <div class="mb-8">
                        {/* <h2 class="text-2xl font-semibold text-black dark:text-white mb-4">
                            {enGalleryPhoto === 0 ? "Galeri Foto" : "Photo Gallery"}
                        </h2> */}
                        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
                            {displayImages.map((imageUrl: string, index: number) => (
                                <div 
                                    class="relative group overflow-hidden rounded-lg cursor-pointer hover:scale-105 transition-transform duration-300 bg-gray-100 dark:bg-gray-700"
                                    data-gallery-index={index}
                                    style="min-height: 200px; aspect-ratio: 1 / 1;"
                                >
                                    {imageUrl && (
                                        <img 
                                            src={imageUrl} 
                                            alt={`${galleryData.title} - ${index + 1}`}
                                            class="w-full h-full object-cover gallery-image"
                                            loading="lazy"
                                            data-index={index}
                                        />
                                    )}
                                    <div class="absolute inset-0 bg-gray-200 dark:bg-gray-600 hidden items-center justify-center image-error-placeholder z-10">
                                        <svg class="w-12 h-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                                        </svg>
                                    </div>
                                    {/* Hover overlay - only shows on hover */}
                                    <div class="absolute inset-0 bg-black opacity-0 group-hover:opacity-30 transition-opacity duration-300 flex items-center justify-center pointer-events-none z-20">
                                        <svg class="w-8 h-8 text-white opacity-0 group-hover:opacity-100 transition-opacity duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v6m3-3H7"/>
                                        </svg>
                                    </div>
                                </div>
                            ))}
                        </div>
                    </div>
                )}
            </div>
        </div>

        {/* Lightbox Modal */}
        <div 
            id="lightbox-modal" 
            class="fixed inset-0 z-[9999] hidden bg-black bg-opacity-95 items-center justify-center"
        >
            {/* Close Button */}
            <button 
                id="lightbox-close"
                class="absolute top-4 right-4 text-white hover:text-gray-300 transition-colors z-10"
                aria-label="Close lightbox"
            >
                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                </svg>
            </button>

            {/* Previous Button */}
            <button 
                id="lightbox-prev"
                class="absolute left-4 text-white hover:text-gray-300 transition-colors z-10 hidden md:block"
                aria-label="Previous image"
            >
                <svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
                </svg>
            </button>

            {/* Next Button */}
            <button 
                id="lightbox-next"
                class="absolute right-4 text-white hover:text-gray-300 transition-colors z-10 hidden md:block"
                aria-label="Next image"
            >
                <svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
            </button>

            {/* Image Container */}
            <div class="relative max-w-7xl mx-auto px-4 md:px-16 flex items-center justify-center h-full">
                <img 
                    id="lightbox-image"
                    src=""
                    alt=""
                    class="max-h-[90vh] max-w-full object-contain"
                />
            </div>

            {/* Image Counter */}
            <div 
                id="lightbox-counter"
                class="absolute bottom-4 left-1/2 transform -translate-x-1/2 text-white text-sm"
            >
                <span id="current-index">1</span> / <span id="total-count">{allImages.length}</span>
            </div>
        </div>

        <script define:vars={{ images: allImages }}>
            // Lightbox functionality
            let currentIndex = 0;

            const modal = document.getElementById('lightbox-modal');
            const modalImage = document.getElementById('lightbox-image');
            const closeBtn = document.getElementById('lightbox-close');
            const prevBtn = document.getElementById('lightbox-prev');
            const nextBtn = document.getElementById('lightbox-next');
            const currentIndexSpan = document.getElementById('current-index');
            const totalCountSpan = document.getElementById('total-count');

            // Initialize total count
            if (totalCountSpan) {
                totalCountSpan.textContent = images.length.toString();
            }

            // Open lightbox - make it globally accessible
            window.openLightbox = function(index) {
                if (!images || images.length === 0) return;
                
                // Clamp index to valid range
                currentIndex = Math.max(0, Math.min(index, images.length - 1));
                
                if (modal && modalImage && currentIndexSpan) {
                    modal.classList.remove('hidden');
                    modal.classList.add('flex');
                    
                    // Preload image
                    const img = new Image();
                    img.onload = function() {
                        modalImage.src = images[currentIndex];
                    };
                    img.src = images[currentIndex];
                    
                    currentIndexSpan.textContent = (currentIndex + 1).toString();
                    document.body.style.overflow = 'hidden';
                }
            };

            // Close lightbox
            function closeLightbox() {
                if (modal) {
                    modal.classList.add('hidden');
                    modal.classList.remove('flex');
                    document.body.style.overflow = '';
                }
            }

            // Show previous image
            function showPrev() {
                if (!images || images.length === 0) return;
                currentIndex = (currentIndex - 1 + images.length) % images.length;
                if (modalImage && currentIndexSpan) {
                    const img = new Image();
                    img.onload = function() {
                        modalImage.src = images[currentIndex];
                    };
                    img.src = images[currentIndex];
                    currentIndexSpan.textContent = (currentIndex + 1).toString();
                }
            }

            // Show next image
            function showNext() {
                if (!images || images.length === 0) return;
                currentIndex = (currentIndex + 1) % images.length;
                if (modalImage && currentIndexSpan) {
                    const img = new Image();
                    img.onload = function() {
                        modalImage.src = images[currentIndex];
                    };
                    img.src = images[currentIndex];
                    currentIndexSpan.textContent = (currentIndex + 1).toString();
                }
            }

            // Handle image errors
            function handleImageError(img) {
                img.style.opacity = '0';
                const placeholder = img.parentElement?.querySelector('.image-error-placeholder');
                if (placeholder) {
                    placeholder.classList.remove('hidden');
                    placeholder.classList.add('flex');
                }
            }

            // Initialize when DOM is ready
            function initLightbox() {
                // Handle image load errors and success
                const galleryImages = document.querySelectorAll('.gallery-image');
                galleryImages.forEach((img) => {
                    // Set initial opacity to 0 for fade-in effect
                    img.style.opacity = '0';
                    img.style.transition = 'opacity 0.3s ease-in-out';
                    
                    // Handle error
                    img.addEventListener('error', function() {
                        console.error('Image failed to load:', this.src);
                        this.style.opacity = '0';
                        handleImageError(this);
                    });
                    
                    // Handle successful load
                    img.addEventListener('load', function() {
                        console.log('Image loaded successfully:', this.src);
                        this.style.opacity = '1';
                        const placeholder = this.parentElement?.querySelector('.image-error-placeholder');
                        if (placeholder) {
                            placeholder.classList.add('hidden');
                            placeholder.classList.remove('flex');
                        }
                    });
                    
                    // Check if already loaded (from cache)
                    if (img.complete && img.naturalWidth > 0) {
                        console.log('Image already loaded from cache:', img.src);
                        img.style.opacity = '1';
                        const placeholder = img.parentElement?.querySelector('.image-error-placeholder');
                        if (placeholder) {
                            placeholder.classList.add('hidden');
                            placeholder.classList.remove('flex');
                        }
                    } else if (img.complete && img.naturalWidth === 0) {
                        // Image failed to load
                        console.error('Image failed to load (naturalWidth = 0):', img.src);
                        handleImageError(img);
                    }
                });

                // Add click listeners to all gallery images
                const galleryItems = document.querySelectorAll('[data-gallery-index]');
                galleryItems.forEach((item) => {
                    item.addEventListener('click', (e) => {
                        e.preventDefault();
                        e.stopPropagation();
                        const index = parseInt(item.getAttribute('data-gallery-index') || '0');
                        window.openLightbox(index);
                    });
                });

                // Close button
                if (closeBtn) {
                    closeBtn.addEventListener('click', closeLightbox);
                }

                // Previous button
                if (prevBtn) {
                    prevBtn.addEventListener('click', (e) => {
                        e.preventDefault();
                        e.stopPropagation();
                        showPrev();
                    });
                }

                // Next button
                if (nextBtn) {
                    nextBtn.addEventListener('click', (e) => {
                        e.preventDefault();
                        e.stopPropagation();
                        showNext();
                    });
                }

                // Close on background click
                if (modal) {
                    modal.addEventListener('click', (e) => {
                        if (e.target === modal || e.target === modalImage?.parentElement) {
                            closeLightbox();
                        }
                    });
                }

                // Prevent closing when clicking on image
                if (modalImage) {
                    modalImage.addEventListener('click', (e) => {
                        e.stopPropagation();
                    });
                }

                // Keyboard navigation
                document.addEventListener('keydown', (e) => {
                    if (!modal || modal.classList.contains('hidden')) return;

                    if (e.key === 'Escape') {
                        closeLightbox();
                    } else if (e.key === 'ArrowLeft') {
                        e.preventDefault();
                        showPrev();
                    } else if (e.key === 'ArrowRight') {
                        e.preventDefault();
                        showNext();
                    }
                });
            }

            // Wait for DOM to be ready
            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', initLightbox);
            } else {
                initLightbox();
            }
        </script>

        <style>
            #lightbox-modal {
                animation: fadeIn 0.3s ease-in-out;
            }

            #lightbox-modal.hidden {
                animation: fadeOut 0.3s ease-in-out;
            }

            #lightbox-image {
                animation: scaleIn 0.3s ease-in-out;
            }

            @keyframes fadeIn {
                from {
                    opacity: 0;
                }
                to {
                    opacity: 1;
                }
            }

            @keyframes fadeOut {
                from {
                    opacity: 1;
                }
                to {
                    opacity: 0;
                }
            }

            @keyframes scaleIn {
                from {
                    transform: scale(0.9);
                    opacity: 0;
                }
                to {
                    transform: scale(1);
                    opacity: 1;
                }
            }

            /* Mobile touch navigation */
            @media (max-width: 768px) {
                #lightbox-prev,
                #lightbox-next {
                    display: none !important;
                }
            }
        </style>

    </div>
</Layout>