---
import Layout from "@layouts/Layout.astro";
import Breadcrumb from "@components/Breadcrumb.astro";
import CategoryListPost from "@components/content/sidebar/CategoryListPost.astro";
import Newsletter from "@components/content/sidebar/Newsletter.astro";
import PopulerPost from "@components/content/sidebar/PopulerPost.astro";
import CardPostContent from "@components/content/CardPostContent.astro";
import PaginationContent from "@components/content/PaginationContent.astro";
import { getListText } from "@/utils/helpers/textPostHelpers";

// Helper function to format numbers with dot as thousands separator
const formatNumber = (num: number | string): string => {
    const number = typeof num === "string" ? parseInt(num) : num;
    return number.toLocaleString("id-ID");
};

const { titlePost, linkPost, groupPost, enPost, limit, type, orderBy } =
    Astro.props;

const textPost = getListText(groupPost, enPost);

const breadcrumbs = [
    { label: "Home", href: "/" },
    { label: titlePost, href: `/${linkPost}` },
];

// Utility imports
import { cleanHTML } from "@/utils/helpers/dataHelpers";
import { postPageService } from "@/services/index";

// Fetch news data using service
const {
    postList,
    popularPost,
    trendingPost,
    isEmptyPostList,
    isEmptyPopularPost,
    isEmptyTrendingPost,
} = await postPageService.fetchPostPageData(
    Astro.url,
    limit,
    groupPost,
    enPost,
    orderBy,
);

// Page metadata
const pageTitle = `${textPost.listnews.title || ""}`;
const pageDescription = `${textPost.listnews.description || ""}`;

const metaTags = {
    title: pageTitle,
    description: pageDescription,
    keywords: "",
    image: "",
};
---

<Layout metaTags={metaTags}>
    <div class="min-h-screen bg-gray-50 dark:bg-gray-900">
        <!-- Breadcrumb Section -->
        <div
            class="bg-white dark:bg-gray-800 border-b border-gray-200 dark:border-gray-700"
        >
            <div class="max-w-screen-xl mx-auto px-4 py-4">
                <Breadcrumb breadcrumbs={breadcrumbs} />
            </div>
        </div>

        <!-- Hero Section with Featured News -->
        {
            !isEmptyPopularPost && type === "latest" && (
                <section class="py-12 bg-[#1055C9]">
                    <div class="max-w-screen-xl mx-auto px-4">
                        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-center">
                            <div class="text-white">
                                <div class="inline-flex items-center px-3 py-1 rounded-full text-xs font-bold bg-white uppercase text-[#1055C9] mb-4">
                                    <span class="w-2 h-2 bg-[#1055C9] rounded-full mr-2 animate-pulse" />
                                    {titlePost}{" "}
                                    {enPost === 0 ? "UTAMA" : "MAIN"}
                                </div>
                                <h1 class="text-4xl lg:text-5xl font-bold mb-4 leading-tight">
                                    {popularPost[0].title}
                                </h1>
                                <p class="text-xl text-blue-100 mb-6 line-clamp-3">
                                    {cleanHTML(popularPost[0].content || "")}
                                </p>
                                <div class="flex items-center space-x-4 text-blue-100 mb-6">
                                    <span class="flex items-center">
                                        <svg
                                            class="w-4 h-4 mr-1"
                                            fill="currentColor"
                                            viewBox="0 0 20 20"
                                        >
                                            <path
                                                fill-rule="evenodd"
                                                d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z"
                                                clip-rule="evenodd"
                                            />
                                        </svg>
                                        {popularPost[0].author || "Admin"}
                                    </span>
                                    <span class="flex items-center">
                                        <svg
                                            class="w-4 h-4 mr-1"
                                            fill="currentColor"
                                            viewBox="0 0 20 20"
                                        >
                                            <path
                                                fill-rule="evenodd"
                                                d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z"
                                                clip-rule="evenodd"
                                            />
                                        </svg>
                                        {new Date(
                                            popularPost[0].date,
                                        ).toLocaleDateString("id-ID")}
                                    </span>
                                </div>
                                <a
                                    href={`/${linkPost}/${popularPost[0].slug}`}
                                    class="inline-flex items-center px-6 py-3 bg-white text-blue-600 font-semibold rounded-lg hover:bg-gray-100 transition-colors duration-200"
                                >
                                    {enPost === 0
                                        ? "Baca Selengkapnya"
                                        : "Read More"}
                                    <svg
                                        class="w-4 h-4 ml-2"
                                        fill="none"
                                        stroke="currentColor"
                                        viewBox="0 0 24 24"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M9 5l7 7-7 7"
                                        />
                                    </svg>
                                </a>
                            </div>
                            <div class="relative">
                                <div class="aspect-video rounded-2xl overflow-hidden shadow-2xl">
                                    <img
                                        src={popularPost[0].image_1200_690}
                                        alt={popularPost[0].title}
                                        class="w-full h-full object-cover"
                                    />
                                </div>
                                <div class="absolute -bottom-4 -right-4 bg-white dark:bg-gray-800 rounded-lg p-4 shadow-lg">
                                    {/* <div class="flex items-center space-x-2">
                                    <svg class="w-5 h-5 text-red-500" fill="currentColor" viewBox="0 0 20 20">
                                        <path d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z"></path>
                                    </svg>
                                    <span class="text-sm font-medium text-gray-700 dark:text-gray-300">
                                        100.000 {enPost === 0 ? 'Suka' : 'Like'}
                                    </span>
                                </div> */}
                                    <div class="flex items-center space-x-2">
                                        <svg
                                            class="w-3 h-3"
                                            fill="currentColor"
                                            viewBox="0 0 20 20"
                                        >
                                            <path d="M10 12a2 2 0 100-4 2 2 0 000 4z" />
                                            <path
                                                fill-rule="evenodd"
                                                d="M.458 10C1.732 5.943 5.522 3 10 3s8.268 2.943 9.542 7c-1.274 4.057-5.064 7-9.542 7S1.732 14.057.458 10zM14 10a4 4 0 11-8 0 4 4 0 018 0z"
                                                clip-rule="evenodd"
                                            />
                                        </svg>
                                        <span class="text-sm font-medium text-gray-700 dark:text-gray-300">
                                            {formatNumber(
                                                popularPost[0].views || 0,
                                            )}{" "}
                                            Views
                                        </span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>
            )
        }

        <!-- Main Content -->
        <div class="max-w-screen-xl mx-auto px-4 py-8">
            <!-- News Categories Tabs -->
            <!-- <div class="mb-8">
                <div class="border-b border-gray-200 dark:border-gray-700">
                    <nav class="-mb-px flex space-x-8 overflow-x-auto">
                        <button class="category-tab active whitespace-nowrap py-4 px-1 border-b-2 border-blue-500 font-medium text-sm text-blue-600 dark:text-blue-400" data-category="">
                            Semua {titlePost}
                        </button>
                        {categoryPost.map((category) => (
                            <button class="cursor-pointer category-tab whitespace-nowrap py-4 px-1 border-b-2 border-transparent font-medium text-sm text-gray-500 hover:text-gray-700 hover:border-gray-300 dark:text-gray-400 dark:hover:text-gray-300" data-category={category.categorySlug}>
                                {category.categoryName}
                                <span class="ml-2 bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300 py-0.5 px-2 rounded-full text-xs">
                                    0
                                </span>
                            </button>
                        ))}
                    </nav>
                </div>
            </div> -->

            <div class="grid grid-cols-1 lg:grid-cols-4 gap-8">
                <!-- Main Content Area -->
                <div class="lg:col-span-3">
                    <!-- Search and Filter Bar -->
                    <div
                        class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6 mb-8"
                    >
                        <div class="flex flex-col md:flex-row gap-4">
                            <div class="flex-1">
                                <label for="search" class="sr-only"
                                    >{
                                        enPost === 0 ? "Pencarian" : "Search"
                                    }</label
                                >
                                <div class="relative">
                                    <div
                                        class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none"
                                    >
                                        <svg
                                            class="w-5 h-5 text-gray-400"
                                            fill="currentColor"
                                            viewBox="0 0 20 20"
                                        >
                                            <path
                                                fill-rule="evenodd"
                                                d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z"
                                                clip-rule="evenodd"></path>
                                        </svg>
                                    </div>
                                    <input
                                        type="text"
                                        id="search"
                                        placeholder={enPost === 0
                                            ? "Cari berita, artikel, atau topik..."
                                            : "Search news, articles, or topics..."}
                                        class="bg-gray-50 dark:bg-gray-700 border border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-transparent block w-full pl-12 pr-4 py-3 text-sm dark:placeholder-gray-400 transition-all duration-200"
                                    />
                                </div>
                            </div>
                            <!-- <div class="md:w-48">
                            </div> -->
                        </div>
                    </div>

                    {
                        !isEmptyTrendingPost && type !== "trending" && (
                            <div class="mb-8">
                                <div class="flex items-center justify-between mb-6">
                                    <h2 class="text-2xl font-bold text-gray-900 dark:text-white flex items-center">
                                        <svg
                                            class="w-6 h-6 text-red-500 mr-2"
                                            fill="currentColor"
                                            viewBox="0 0 20 20"
                                        >
                                            <path
                                                fill-rule="evenodd"
                                                d="M12.395 2.553a1 1 0 00-1.45-.385c-.345.23-.614.558-.822.88-.214.33-.403.713-.57 1.116-.334.804-.614 1.768-.84 2.734a31.365 31.365 0 00-.613 3.58 2.64 2.64 0 01-.945-1.067c-.328-.68-.398-1.534-.398-2.654A1 1 0 005.05 6.05 6.981 6.981 0 003 11a7 7 0 1011.95-4.95c-.592-.591-.98-.985-1.348-1.467-.363-.476-.724-1.063-1.207-2.03zM12.12 15.12A3 3 0 017 13s.879.5 2.5.5c0-1 .5-4 1.25-4.5.5 1 .786 1.293 1.371 1.879A2.99 2.99 0 0113 13a2.99 2.99 0 01-.879 2.121z"
                                                clip-rule="evenodd"
                                            />
                                        </svg>
                                        {titlePost} Trending
                                    </h2>
                                    <a
                                        href={`/${linkPost}/trending`}
                                        class="text-blue-600 hover:text-blue-700 font-medium text-sm flex items-center"
                                    >
                                        {enPost === 0
                                            ? "Lihat Semua"
                                            : "View All"}
                                        <svg
                                            class="w-4 h-4 ml-1"
                                            fill="none"
                                            stroke="currentColor"
                                            viewBox="0 0 24 24"
                                        >
                                            <path
                                                stroke-linecap="round"
                                                stroke-linejoin="round"
                                                stroke-width="2"
                                                d="M9 5l7 7-7 7"
                                            />
                                        </svg>
                                    </a>
                                </div>
                                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                                    {trendingPost.map((article: any) => (
                                        <article class="group bg-white dark:bg-gray-800 rounded-xl shadow-sm hover:shadow-lg transition-all duration-300 overflow-hidden border border-gray-200 dark:border-gray-700">
                                            <CardPostContent
                                                article={article}
                                                link={`/${linkPost}`}
                                            />
                                        </article>
                                    ))}
                                </div>
                            </div>
                        )
                    }

                    <!-- Latest News Section -->
                    <div class="mb-8">
                        <div class="flex items-center justify-between mb-6">
                            <h2
                                class="text-2xl font-bold text-gray-900 dark:text-white flex items-center"
                            >
                                {
                                    type === "latest" ? (
                                        <svg
                                            class="w-6 h-6 text-blue-500 mr-2"
                                            fill="currentColor"
                                            viewBox="0 0 20 20"
                                            aria-hidden="true"
                                        >
                                            <path d="M6 2a2 2 0 00-2 2v12a2 2 0 002 2h8a2 2 0 002-2V4a2 2 0 00-2-2H6zm1 2a1 1 0 000 2h6a1 1 0 100-2H7zm6 7a1 1 0 01-1 1H8a1 1 0 110-2h4a1 1 0 011 1zm-1 4a1 1 0 100-2H8a1 1 0 100 2h4z" />
                                        </svg>
                                    ) : (
                                        <svg
                                            class="w-6 h-6 text-red-500 mr-2"
                                            fill="currentColor"
                                            viewBox="0 0 20 20"
                                            aria-hidden="true"
                                        >
                                            <path d="M12.395 2.553a1 1 0 00-1.45-.385c-.345.23-.614.558-.822.88-.214.33-.403.713-.57 1.116-.334.804-.614 1.768-.84 2.734a31.365 31.365 0 00-.613 3.58 2.64 2.64 0 01-.945-1.067c-.328-.68-.398-1.534-.398-2.654A1 1 0 005.05 6.05 6.981 6.981 0 003 11a7 7 0 1011.95-4.95c-.592-.591-.98-.985-1.348-1.467-.363-.476-.724-1.063-1.207-2.03zM12.12 15.12A3 3 0 017 13s.879.5 2.5.5c0-1 .5-4 1.25-4.5.5 1 .786 1.293 1.371 1.879A2.99 2.99 0 0113 13a2.99 2.99 0 01-.879 2.121z" />
                                        </svg>
                                    )
                                }
                                {titlePost}
                                {enPost === 0 ? "Terbaru" : "Latest"}
                            </h2>
                            <!-- <div class="flex items-center space-x-2">
                                <button class="view-toggle active" data-view="grid">
                                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                                        <path d="M5 3a2 2 0 00-2 2v2a2 2 0 002 2h2a2 2 0 002-2V5a2 2 0 00-2-2H5zM5 11a2 2 0 00-2 2v2a2 2 0 002 2h2a2 2 0 002-2v-2a2 2 0 00-2-2H5zM11 5a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V5zM11 13a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"></path>
                                    </svg>
                                </button>
                                <button class="view-toggle" data-view="list">
                                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                                        <path fill-rule="evenodd" d="M3 4a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm0 4a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm0 4a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm0 4a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1z" clip-rule="evenodd"></path>
                                    </svg>
                                </button>
                            </div> -->
                        </div>

                        <div
                            id="articles-container"
                            class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6"
                        >
                            {
                                postList.posts.map((article: any) => (
                                    <article class="group bg-white dark:bg-gray-800 rounded-xl shadow-sm hover:shadow-lg transition-all duration-300 overflow-hidden border border-gray-200 dark:border-gray-700">
                                        <CardPostContent
                                            article={article}
                                            link={`/${linkPost}`}
                                        />
                                    </article>
                                ))
                            }
                        </div>
                    </div>
                </div>

                <!-- Enhanced Sidebar -->
                <div class="lg:col-span-1">
                    <div class="sticky top-8 space-y-6">
                        {/* Popular Articles */}
                        <PopulerPost limit={3} group={groupPost} en={enPost} />
                        <!-- Categories Widget -->
                        <CategoryListPost group={groupPost} en={enPost} />
                        <!-- Newsletter Widget -->
                        <Newsletter en={enPost} />
                    </div>
                </div>
            </div>

            <!-- Pagination -->
            <div class="mt-12">
                <PaginationContent
                    listData={postList}
                    isEmptyList={isEmptyPostList}
                />
            </div>
        </div>
    </div>
</Layout>

<style>
    .line-clamp-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .line-clamp-3 {
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
</style>
