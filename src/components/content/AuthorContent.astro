---
// Utility imports
import { PostApi } from "@/services/index";
import {
    validateSlug,
    hasValue,
    formatNumber,
} from "@/utils/helpers/dataHelpers";
import type { AuthorPostsType } from "@/types/index";

const { author, en } = Astro.props;

// Initialize API service
const postApiService = new PostApi();

// Validate and sanitize the slug
const slugValidation = validateSlug(author);

let isEmptypopularPost = true;
let authorPosts: AuthorPostsType | null = null;
let totalArticle = 0;

if (slugValidation.isValid) {
    const slug = slugValidation.sanitizedSlug;

    const authorPostsData = await postApiService.fetchAuthorPosts(slug);

    if (hasValue(authorPostsData) && authorPostsData !== null) {
        isEmptypopularPost = false;
        authorPosts = authorPostsData;
        totalArticle =
            (authorPostsData?.statistik?.totalArticle || 0) +
            (authorPostsData?.statistik?.totalNews || 0);
    }
}
---

{
    !isEmptypopularPost && (
        <div class="mt-12 border-t border-gray-200 dark:border-gray-700 pt-8">
            <div class="mb-6">
                <div class="flex items-center space-x-3">
                    <div
                        class="w-1 h-8 rounded-full"
                        style="background-color: #1055C9;"
                    />
                    <h2 class="text-2xl font-bold text-gray-900 dark:text-white">
                        {en === 0 ? "Tentang Penulis" : "About Author"}
                    </h2>
                </div>
                <p class="text-gray-600 dark:text-gray-400 mt-2 ml-4">
                    {en === 0
                        ? "Kenali lebih dekat penulis artikel ini"
                        : "Get to know the author of this article"}
                </p>
            </div>

            <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 p-6">
                <div class="flex flex-col md:flex-row items-start md:items-center space-y-4 md:space-y-0 md:space-x-6">
                    <div class="flex-shrink-0">
                        {authorPosts?.avatar ? (
                            <img
                                src={authorPosts.avatar}
                                alt={`Foto ${authorPosts?.fullName || ""}`}
                                class="w-24 h-24 rounded-full object-cover border-4 border-gray-200 dark:border-gray-600"
                            />
                        ) : (
                            <div class="w-24 h-24 rounded-full bg-gray-200 dark:bg-gray-700 flex items-center justify-center border-4 border-gray-200 dark:border-gray-600">
                                <svg
                                    class="w-12 h-12 text-gray-400"
                                    fill="currentColor"
                                    viewBox="0 0 24 24"
                                >
                                    <path
                                        fill-rule="evenodd"
                                        d="M12 12c2.485 0 4.5-2.015 4.5-4.5S14.485 3 12 3 7.5 5.015 7.5 7.5 9.515 12 12 12zm0 1.5c-2.485 0-7.5 1.243-7.5 3.75V21h15v-3.75c0-2.507-5.015-3.75-7.5-3.75z"
                                        clip-rule="evenodd"
                                    />
                                </svg>
                            </div>
                        )}
                    </div>

                    {/* Author Info */}
                    <div class="flex-grow">
                        <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-2">
                            {authorPosts?.fullName || ""}
                        </h3>
                        <p class="text-gray-600 dark:text-gray-300 text-sm mb-3">
                            <span class="font-medium capitalize">
                                {authorPosts?.job || ""}
                            </span>{" "}
                            •<span style="color: #1055C9;">Disabilitas ID</span>
                        </p>
                        <p class="text-gray-700 dark:text-gray-300 leading-relaxed">
                            {en === 0
                                ? "Berdedikasi untuk menyebarkan informasi yang akurat dan bermanfaat tentang disabilitas, inklusi, dan aksesibilitas. Percaya bahwa setiap individu memiliki potensi luar biasa yang dapat dikembangkan dengan dukungan yang tepat."
                                : "Dedicated to spreading accurate and useful information about disabilities, inclusion, and accessibility. Believes that every individual has extraordinary potential that can be developed with the right support."}
                        </p>

                        {/* Author Stats */}
                        <div class="flex items-center space-x-6 mt-4 pt-4 border-t border-gray-200 dark:border-gray-700">
                            <div class="text-center">
                                <div class="text-lg font-bold text-gray-900 dark:text-white">
                                    {formatNumber(totalArticle)} +
                                </div>
                                <div class="text-xs text-gray-500 dark:text-gray-400">
                                    Articles
                                </div>
                            </div>
                            <div class="text-center">
                                <div class="text-lg font-bold text-gray-900 dark:text-white">
                                    {formatNumber(
                                        authorPosts?.statistik?.totalView ||
                                            "0",
                                    )}{" "}
                                    +
                                </div>
                                <div class="text-xs text-gray-500 dark:text-gray-400">
                                    views
                                </div>
                            </div>
                            {/* <div class="text-center">
                        <div class="text-lg font-bold text-gray-900 dark:text-white">{authorPosts?.statistik?.totalLike || '0'} +</div>
                        <div class="text-xs text-gray-500 dark:text-gray-400">Likes</div>
                    </div> */}
                        </div>
                    </div>

                    {/* Social Links */}
                    <div class="flex-shrink-0">
                        <div class="flex flex-col space-y-2">
                            <a
                                href="#"
                                class="flex items-center justify-center w-10 h-10 text-white rounded-full transition-colors duration-200"
                                style="background-color: #1055C9;"
                                onmouseover="this.style.backgroundColor='#b8254a'"
                                onmouseout="this.style.backgroundColor='#1055C9'"
                            >
                                <svg
                                    class="w-5 h-5"
                                    fill="currentColor"
                                    viewBox="0 0 24 24"
                                >
                                    <path d="M24 4.557c-.883.392-1.832.656-2.828.775 1.017-.609 1.798-1.574 2.165-2.724-.951.564-2.005.974-3.127 1.195-.897-.957-2.178-1.555-3.594-1.555-3.179 0-5.515 2.966-4.797 6.045-4.091-.205-7.719-2.165-10.148-5.144-1.29 2.213-.669 5.108 1.523 6.574-.806-.026-1.566-.247-2.229-.616-.054 2.281 1.581 4.415 3.949 4.89-.693.188-1.452.232-2.224.084.626 1.956 2.444 3.379 4.6 3.419-2.07 1.623-4.678 2.348-7.29 2.04 2.179 1.397 4.768 2.212 7.548 2.212 9.142 0 14.307-7.721 13.995-14.646.962-.695 1.797-1.562 2.457-2.549z" />
                                </svg>
                            </a>
                            <a
                                href="#"
                                class="flex items-center justify-center w-10 h-10 text-white rounded-full transition-colors duration-200"
                                style="background-color: #a01f3e;"
                                onmouseover="this.style.backgroundColor='#8a1a35'"
                                onmouseout="this.style.backgroundColor='#a01f3e'"
                            >
                                <svg
                                    class="w-5 h-5"
                                    fill="currentColor"
                                    viewBox="0 0 24 24"
                                >
                                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
                                </svg>
                            </a>
                            <a
                                href="#"
                                class="flex items-center justify-center w-10 h-10 bg-gray-800 hover:bg-gray-900 text-white rounded-full transition-colors duration-200"
                            >
                                <svg
                                    class="w-5 h-5"
                                    fill="currentColor"
                                    viewBox="0 0 24 24"
                                >
                                    <path d="M12.017 0C5.396 0 .029 5.367.029 11.987c0 5.079 3.158 9.417 7.618 11.174-.105-.949-.199-2.403.041-3.439.219-.937 1.406-5.957 1.406-5.957s-.359-.72-.359-1.781c0-1.663.967-2.911 2.168-2.911 1.024 0 1.518.769 1.518 1.688 0 1.029-.653 2.567-.992 3.992-.285 1.193.6 2.165 1.775 2.165 2.128 0 3.768-2.245 3.768-5.487 0-2.861-2.063-4.869-5.008-4.869-3.41 0-5.409 2.562-5.409 5.199 0 1.033.394 2.143.889 2.741.099.12.112.225.085.345-.09.375-.293 1.199-.334 1.363-.053.225-.172.271-.402.165-1.495-.69-2.433-2.878-2.433-4.646 0-3.776 2.748-7.252 7.92-7.252 4.158 0 7.392 2.967 7.392 6.923 0 4.135-2.607 7.462-6.233 7.462-1.214 0-2.357-.629-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24.009 12.017 24.009c6.624 0 11.99-5.367 11.99-11.988C24.007 5.367 18.641.001.012.001z" />
                                </svg>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    )
}
