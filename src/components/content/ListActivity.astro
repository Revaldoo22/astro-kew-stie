---
import Layout from "@layouts/Layout.astro";
import Breadcrumb from "@components/Breadcrumb.astro";

const { titleActivity, linkActivity, enActivity } = Astro.props;

const breadcrumbs = [
    { label: "Home", href: "/" },
    { label: titleActivity, href: `/${linkActivity}` },
];

import { EventApi } from "@/services/index";
const eventApiService = new EventApi();
const totalEvents = await eventApiService.fetchTotalEvents();

const metaTags = {
    title: enActivity === 0 ? "Aktivitas" : "Activities",
    description:
        enActivity === 0
            ? "Temukan aktivitas-aktivitas terbaru seputar disabilitas, teknologi asistif, dan inklusi"
            : "Find the latest activities about disabilities, assistive technology, and inclusion",
    keywords: "",
    image: "",
};

// Generate year cards dynamically
const currentYear = new Date().getFullYear();
const minYearsToShow = 3; // Minimal 3 tahun terakhir
let totalAllEvents = 0;

// Generate array tahun dari API dan tambahkan tahun yang belum ada
const yearsFromApi = totalEvents ? Object.keys(totalEvents).map(Number) : [];
const yearsToShow = new Set<number>();

// Tambahkan minimal 3 tahun terakhir (2025, 2024, 2023)
for (let i = 0; i < minYearsToShow; i++) {
    yearsToShow.add(currentYear - i);
}

// Tambahkan tahun lain dari API jika ada
yearsFromApi.forEach((year) => yearsToShow.add(year));

// Convert ke array dan sort descending
const years = Array.from(yearsToShow).sort((a, b) => b - a);

const yearCards = years.map((year, index) => {
    const count = totalEvents?.[year] || 0;
    totalAllEvents += count;

    let label, labelEn;
    if (year === currentYear) {
        label = "Tahun Berjalan";
        labelEn = "Current Year";
    } else if (year === currentYear - 1) {
        label = "Tahun Lalu";
        labelEn = "Last Year";
    } else {
        const yearDiff = currentYear - year;
        label = `${yearDiff} Tahun Lalu`;
        labelEn = `${yearDiff} Years Ago`;
    }

    return {
        year,
        href: `/${linkActivity}/${year}`,
        label: { id: label, en: labelEn },
        count: { id: `${count} Kegiatan`, en: `${count} Activities` },
        borderColor:
            year === currentYear
                ? "border-[#1055C9]"
                : "border-gray-200 dark:border-gray-700",
        textColor:
            year === currentYear
                ? "text-[#1055C9]"
                : "text-gray-900 dark:text-white",
        isAllYears: false,
        ...(year === currentYear && { badge: { id: "Baru", en: "New" } }),
    };
});

// Add "All Years" card at the end
yearCards.push({
    year: 0,
    isAllYears: true,
    href: `/${linkActivity}/semua`,
    label: { id: "Semua Tahun", en: "All Years" },
    count: {
        id: `${totalAllEvents} Kegiatan`,
        en: `${totalAllEvents} Activities`,
    },
    borderColor: "border-gray-200 dark:border-gray-700",
    textColor: "text-gray-900 dark:text-white",
});

const calendarIcon = `<path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd"></path>`;

const archiveIcon = `<path d="M9 2a1 1 0 000 2h2a1 1 0 100-2H9z"></path><path fill-rule="evenodd" d="M4 5a2 2 0 012-2 3 3 0 003 3h2a3 3 0 003-3 2 2 0 012 2v11a2 2 0 01-2 2H6a2 2 0 01-2-2V5zm3 4a1 1 0 000 2h.01a1 1 0 100-2H7zm3 0a1 1 0 000 2h3a1 1 0 100-2h-3zm-3 4a1 1 0 100 2h.01a1 1 0 100-2H7zm3 0a1 1 0 100 2h3a1 1 0 100-2h-3z" clip-rule="evenodd"></path>`;
---

<Layout metaTags={metaTags}>
    <div class="min-h-screen">
        <div class="bg-white dark:bg-gray-900 py-5">
            <div class="max-w-screen-xl mx-auto px-4">
                <!-- Breadcrumbs -->
                <div class="mb-6">
                    <Breadcrumb breadcrumbs={breadcrumbs} />
                </div>

                <!-- Main Title -->
                <h1
                    class="text-2xl md:text-3xl lg:text-3xl font-bold text-black dark:text-white mb-4 leading-tight"
                >
                    {
                        enActivity === 0
                            ? "Pilih Tahun Aktivitas"
                            : "Select Activity Year"
                    }
                </h1>

                <p class="text-gray-600 dark:text-gray-300 mt-2">
                    {
                        enActivity === 0
                            ? "Lihat berbagai aktivitas dan kegiatan yang telah kami laksanakan berdasarkan tahun"
                            : "View various activities and events we have carried out by year"
                    }
                </p>
            </div>
        </div>

        <!-- Main Content -->
        <div class="max-w-screen-xl mx-auto px-4 py-8">
            <!-- Year Grid -->
            <div
                class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-8"
            >
                {
                    yearCards.map((card) => (
                        <a
                            href={card.href}
                            class={`group relative bg-white dark:bg-gray-800 border-2 ${card.borderColor} rounded-lg p-6 text-center hover:shadow-lg transition-all duration-200`}
                        >
                            {card.isAllYears ? (
                                <>
                                    <div
                                        class={`text-4xl font-bold mb-3 ${card.textColor}`}
                                    >
                                        <svg
                                            class="w-10 h-10 mx-auto"
                                            fill="currentColor"
                                            viewBox="0 0 20 20"
                                        >
                                            <Fragment set:html={archiveIcon} />
                                        </svg>
                                    </div>
                                    <div class="text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
                                        {enActivity === 0
                                            ? card.label.id
                                            : card.label.en}
                                    </div>
                                    {card.count && (
                                        <div class="inline-flex items-center gap-1 px-3 py-1 bg-gray-100 dark:bg-gray-700 rounded-full">
                                            <svg
                                                class="w-3.5 h-3.5 text-gray-500 dark:text-gray-400"
                                                fill="currentColor"
                                                viewBox="0 0 20 20"
                                            >
                                                <Fragment
                                                    set:html={calendarIcon}
                                                />
                                            </svg>
                                            <span class="text-xs font-medium text-gray-600 dark:text-gray-400">
                                                {enActivity === 0
                                                    ? card.count.id
                                                    : card.count.en}
                                            </span>
                                        </div>
                                    )}
                                </>
                            ) : (
                                <>
                                    <div
                                        class={`text-4xl font-bold mb-3 ${card.textColor}`}
                                    >
                                        {card.year}
                                    </div>
                                    <div class="text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
                                        {enActivity === 0
                                            ? card.label.id
                                            : card.label.en}
                                    </div>
                                    {card.count && (
                                        <div class="inline-flex items-center gap-1 px-3 py-1 bg-gray-100 dark:bg-gray-700 rounded-full">
                                            <svg
                                                class="w-3.5 h-3.5 text-gray-500 dark:text-gray-400"
                                                fill="currentColor"
                                                viewBox="0 0 20 20"
                                            >
                                                <Fragment
                                                    set:html={calendarIcon}
                                                />
                                            </svg>
                                            <span class="text-xs font-medium text-gray-600 dark:text-gray-400">
                                                {enActivity === 0
                                                    ? card.count.id
                                                    : card.count.en}
                                            </span>
                                        </div>
                                    )}
                                </>
                            )}

                            {card.badge && (
                                <div class="absolute -top-2 -right-2 bg-yellow-400 text-yellow-900 text-xs font-bold px-3 py-1 rounded-full shadow-lg">
                                    {enActivity === 0
                                        ? card.badge.id
                                        : card.badge.en}
                                </div>
                            )}
                        </a>
                    ))
                }
            </div>

            <!-- Deskripsi Aktivitas -->
            <div
                class="bg-white dark:bg-gray-800 rounded-lg p-6 border border-gray-200 dark:border-gray-700"
            >
                <h3
                    class="text-xl font-bold text-gray-900 dark:text-white mb-4"
                >
                    {
                        enActivity === 0
                            ? "Tentang Aktivitas Kami"
                            : "About Our Activities"
                    }
                </h3>
                <div class="prose dark:prose-invert max-w-none">
                    <p class="text-gray-600 dark:text-gray-400 mb-4">
                        {
                            enActivity === 0
                                ? "Kami secara konsisten menyelenggarakan berbagai aktivitas dan kegiatan yang bertujuan untuk meningkatkan kesadaran, memberikan dukungan, dan memberdayakan penyandang disabilitas. Setiap tahun, kami mengadakan berbagai program inklusif yang dirancang khusus untuk memenuhi kebutuhan dan mengembangkan potensi para penyandang disabilitas."
                                : "We consistently organize various activities and events aimed at raising awareness, providing support, and empowering persons with disabilities. Each year, we conduct various inclusive programs specifically designed to meet the needs and develop the potential of persons with disabilities."
                        }
                    </p>
                    <p class="text-gray-600 dark:text-gray-400 mb-4">
                        {
                            enActivity === 0
                                ? "Program unggulan kami meliputi Program Kakak–Adik Asuh Inklusif yang memberikan pendampingan intensif kepada mahasiswa difabel untuk membantu mereka beradaptasi dan sukses dalam lingkungan akademik. Kami juga menyelenggarakan Pelatihan Bahasa Isyarat Indonesia (BISINDO) secara berkala untuk meningkatkan kemampuan komunikasi dan membangun jembatan pemahaman antara komunitas tuli dan masyarakat umum."
                                : "Our flagship programs include the Inclusive Mentorship Program which provides intensive mentoring to students with disabilities to help them adapt and succeed in academic environments. We also regularly conduct Indonesian Sign Language (BISINDO) training to improve communication skills and build bridges of understanding between the deaf community and the general public."
                        }
                    </p>
                    <p class="text-gray-600 dark:text-gray-400 mb-4">
                        {
                            enActivity === 0
                                ? "Selain itu, kami aktif dalam program Job Canvassing dan Rekrutmen Inklusif yang bertujuan menghubungkan penyandang disabilitas dengan peluang kerja yang sesuai dengan kemampuan mereka. Melalui berbagai kegiatan ini, kami berkomitmen untuk menciptakan masyarakat yang lebih inklusif dan memberikan kesempatan yang setara bagi semua individu, terlepas dari keterbatasan fisik yang mereka miliki."
                                : "Additionally, we are active in the Inclusive Job Canvassing and Recruitment program which aims to connect persons with disabilities with job opportunities that match their abilities. Through these various activities, we are committed to creating a more inclusive society and providing equal opportunities for all individuals, regardless of their physical limitations."
                        }
                    </p>
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-6">
                        <div
                            class="bg-gray-50 dark:bg-gray-700/50 rounded-lg p-4 border border-gray-200 dark:border-gray-600"
                        >
                            <div class="mb-3 text-center">
                                <img
                                    src="/assets/icons/handshake.png"
                                    alt="Handshake"
                                    class="w-12 h-12 mx-auto dark:brightness-0 dark:invert"
                                />
                            </div>
                            <p
                                class="text-sm font-semibold text-gray-900 dark:text-white text-center mb-2"
                            >
                                {
                                    enActivity === 0
                                        ? "Program Kakak–Adik Asuh Inklusif"
                                        : "Inclusive Mentorship Program"
                                }
                            </p>
                            <p
                                class="text-xs text-gray-500 dark:text-gray-400 text-center"
                            >
                                {
                                    enActivity === 0
                                        ? "Pendampingan mahasiswa difabel"
                                        : "Student mentorship for persons with disabilities"
                                }
                            </p>
                        </div>
                        <div
                            class="bg-gray-50 dark:bg-gray-700/50 rounded-lg p-4 border border-gray-200 dark:border-gray-600"
                        >
                            <div class="mb-3 text-center">
                                <img
                                    src="/assets/icons/hello.png"
                                    alt="Sign Language"
                                    class="w-12 h-12 mx-auto dark:brightness-0 dark:invert"
                                />
                            </div>
                            <p
                                class="text-sm font-semibold text-gray-900 dark:text-white text-center mb-2"
                            >
                                {
                                    enActivity === 0
                                        ? "Pelatihan Bahasa Isyarat"
                                        : "Sign Language Training"
                                }
                            </p>
                            <p
                                class="text-xs text-gray-500 dark:text-gray-400 text-center"
                            >
                                {
                                    enActivity === 0
                                        ? "Bahasa Isyarat Indonesia (BISINDO)"
                                        : "Indonesian Sign Language (BISINDO)"
                                }
                            </p>
                        </div>
                        <div
                            class="bg-gray-50 dark:bg-gray-700/50 rounded-lg p-4 border border-gray-200 dark:border-gray-600"
                        >
                            <div class="mb-3 text-center">
                                <img
                                    src="/assets/icons/job-offer.png"
                                    alt="Job Canvassing"
                                    class="w-12 h-12 mx-auto dark:brightness-0 dark:invert"
                                />
                            </div>
                            <p
                                class="text-sm font-semibold text-gray-900 dark:text-white text-center mb-2"
                            >
                                {
                                    enActivity === 0
                                        ? "Job Canvassing Inklusif"
                                        : "Inclusive Job Canvassing"
                                }
                            </p>
                            <p
                                class="text-xs text-gray-500 dark:text-gray-400 text-center"
                            >
                                {
                                    enActivity === 0
                                        ? "Rekrutmen bagi penyandang disabilitas"
                                        : "Recruitment for persons with disabilities"
                                }
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</Layout>

<style>
    .line-clamp-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .line-clamp-3 {
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
</style>
