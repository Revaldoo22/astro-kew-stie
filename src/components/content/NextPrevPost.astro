---
export interface Props {
    nextPost: {
        title: string;
        slug: string;
        image: string;
    } | null;
    prevPost: {
        title: string;
        slug: string;
        image: string;
    } | null;
}

const { nextPost, prevPost } = Astro.props;
---

<div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 p-6">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- Previous Post -->
        <div class="flex flex-col">
            {prevPost ? (
                <a href={`/artikel/${prevPost.slug}`} class="group flex items-start space-x-4 p-4 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors duration-200">
                    <div class="flex-shrink-0">
                        <div class="w-16 h-16 bg-gray-200 dark:bg-gray-600 rounded-lg overflow-hidden">
                            {prevPost.image ? (
                                <img 
                                    src={prevPost.image} 
                                    alt={prevPost.title}
                                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-200"
                                />
                            ) : (
                                <div class="w-full h-full bg-gray-300 dark:bg-gray-600 flex items-center justify-center">
                                    <svg class="w-6 h-6 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
                                        <path fill-rule="evenodd" d="M4 3a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V5a2 2 0 00-2-2H4zm12 12H4l4-8 3 6 2-4 3 6z" clip-rule="evenodd"/>
                                    </svg>
                                </div>
                            )}
                        </div>
                    </div>
                    <div class="flex-grow min-w-0">
                        <div class="flex items-center text-xs text-gray-500 dark:text-gray-400 mb-1">
                            <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z" clip-rule="evenodd"/>
                            </svg>
                            <span>Artikel Sebelumnya</span>
                        </div>
                        <h3 class="text-sm font-semibold text-gray-900 dark:text-white line-clamp-2 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors duration-200">
                            {prevPost.title}
                        </h3>
                    </div>
                </a>
            ) : (
                <div class="flex items-center justify-center p-8 text-gray-400 dark:text-gray-500">
                    <div class="text-center">
                        <svg class="w-8 h-8 mx-auto mb-2 opacity-50" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z" clip-rule="evenodd"/>
                        </svg>
                        <p class="text-sm">Tidak ada artikel sebelumnya</p>
                    </div>
                </div>
            )}
        </div>

        <!-- Next Post -->
        <div class="flex flex-col">
            {nextPost ? (
                <a href={`/artikel/${nextPost.slug}`} class="group flex items-start space-x-4 p-4 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors duration-200">
                    <div class="flex-grow min-w-0">
                        <div class="flex items-center justify-end text-xs text-gray-500 dark:text-gray-400 mb-1">
                            <span>Artikel Selanjutnya</span>
                            <svg class="w-3 h-3 ml-1" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/>
                            </svg>
                        </div>
                        <h3 class="text-sm font-semibold text-gray-900 dark:text-white line-clamp-2 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors duration-200 text-right">
                            {nextPost.title}
                        </h3>
                    </div>
                    <div class="flex-shrink-0">
                        <div class="w-16 h-16 bg-gray-200 dark:bg-gray-600 rounded-lg overflow-hidden">
                            {nextPost.image ? (
                                <img 
                                    src={nextPost.image} 
                                    alt={nextPost.title}
                                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-200"
                                />
                            ) : (
                                <div class="w-full h-full bg-gray-300 dark:bg-gray-600 flex items-center justify-center">
                                    <svg class="w-6 h-6 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
                                        <path fill-rule="evenodd" d="M4 3a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V5a2 2 0 00-2-2H4zm12 12H4l4-8 3 6 2-4 3 6z" clip-rule="evenodd"/>
                                    </svg>
                                </div>
                            )}
                        </div>
                    </div>
                </a>
            ) : (
                <div class="flex items-center justify-center p-8 text-gray-400 dark:text-gray-500">
                    <div class="text-center">
                        <svg class="w-8 h-8 mx-auto mb-2 opacity-50" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/>
                        </svg>
                        <p class="text-sm">Tidak ada artikel selanjutnya</p>
                    </div>
                </div>
            )}
        </div>
    </div>
</div>
