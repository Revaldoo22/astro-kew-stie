---
const { category, limit, group, en } = Astro.props;
import { getRelatedText } from "@/utils/helpers/textPostHelpers";

// Utility imports
import { PostApi } from "@/services/index";
import { validateSlug, hasValue } from "@/utils/helpers/dataHelpers";
import type { PostListType } from "@/types/index";
import CardPostContent from "@components/content/CardPostContent.astro";

// Initialize API service
const postApiService = new PostApi();

// Validate and sanitize the slug
const slugValidation = validateSlug(category);

let isEmptycategoryPosts = true;
let categoryPosts: PostListType[] = [];

if (slugValidation.isValid) {
    const categorySlug = slugValidation.sanitizedSlug;

    const categoryPostsData = await postApiService.fetchCategoryPosts(
        `?category=${categorySlug}&limit=${limit}`,
    );

    if (hasValue(categoryPostsData) && categoryPostsData !== null) {
        isEmptycategoryPosts = false;
        categoryPosts = categoryPostsData;
    }
}

const textPost = getRelatedText(group, en);
---

{
    !isEmptycategoryPosts && (
        <div class="mt-12 border-t border-gray-200 dark:border-gray-700 pt-8">
            <div class="mb-6">
                <div class="flex items-center space-x-3">
                    <div
                        class="w-1 h-8 rounded-full"
                        style="background-color: #1055C9;"
                    />
                    <h2 class="text-2xl font-bold text-gray-900 dark:text-white">
                        {textPost.related.title || ""}
                    </h2>
                </div>
                <p class="text-gray-600 dark:text-gray-400 mt-2 ml-4">
                    {textPost.related.description || ""}
                </p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 xl:grid-cols-4 gap-6">
                {categoryPosts.map((article) => (
                    <article class="w-full sm:max-w-sm bg-white dark:bg-gray-800 rounded-2xl shadow-lg hover:shadow-2xl transition-all duration-300 overflow-hidden border border-gray-100 dark:border-gray-700 hover-lift">
                        <CardPostContent
                            article={article}
                            link={textPost.related.link}
                        />
                    </article>
                ))}
            </div>
        </div>
    )
}
