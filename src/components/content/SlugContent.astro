---
import Layout from "@layouts/Layout.astro";
import HeroSection from "@components/HeroSection.astro";
import SocialShare from "@components/SocialShare.astro";
import CategoryListPost from "@components/content/sidebar/CategoryListPost.astro";
import RecentPost from "@components/content/sidebar/RecentPost.astro";
import PopulerPost from "@components/content/sidebar/PopulerPost.astro";
import Newsletter from "@components/content/sidebar/Newsletter.astro";
import NextPrevPost from "@components/content/NextPrevPost.astro";
import RelatedPost from "@components/content/RelatedPost.astro";
import AuthorContent from "@components/content/AuthorContent.astro";

// Utility imports
import { PostApi } from '@/services/index';
import { validateSlug, hasValue, cleanHTML } from '@/utils/helpers/dataHelpers';

const { titlePost, linkPost, groupPost, enPost, slugContent } = Astro.props;

// Initialize API service
const postApiService = new PostApi();

// Validate and sanitize the slug
const slugValidation = validateSlug(slugContent);

if(!slugValidation.isValid) {    
    // Redirect to 404 if slug is invalid
    Astro.redirect("/404");
}

const slug = slugValidation.sanitizedSlug;

const dataPage  = await postApiService.fetchDetailPosts(slug || "");

if(dataPage === null) {
    Astro.redirect("/404");
}


// TypeScript now knows dataPage is not null after the check above
const title = dataPage!.title || "";
const description = cleanHTML(dataPage!.content);

const truncateDescription = (text: string, maxLength: number = 150): string => {
    if (text.length <= maxLength) return text;
    
    // Mencari titik terakhir dalam batas maksimal
    const truncated = text.substring(0, maxLength);
    const lastPeriodIndex = truncated.lastIndexOf('.');
    
    // Jika menemukan titik dan tidak terlalu dekat ke awal, gunakan itu
    if (lastPeriodIndex > 50) {
        return truncated.substring(0, lastPeriodIndex + 1);
    }
    
    // Jika tidak, gunakan pemotongan biasa
    return truncated;
};

const metaTags = {
    title: title,
    description: truncateDescription(description),
    keywords: '',
    image: dataPage!.image || '',
};

const breadcrumbs = [
    { label: "Home", href: "/" },
    { label: titlePost, href: `/${linkPost}` },
    { label: dataPage!.title, href: `/${linkPost}/${dataPage!.slug}` },
];

const date = dataPage!.date || "";
const page = titlePost;
const author = dataPage!.author || "";
const category = dataPage!.categories[0]?.toLowerCase()?.replace(/ /g, "-") || "";
---

<Layout metaTags={metaTags}>
    <div class="min-h-screen">
        <!-- Hero Section -->
        <HeroSection title={title} breadcrumbs={breadcrumbs} date={date} page={page} author={author} />

        <!-- Main Content -->
        <div class="max-w-screen-xl mx-auto px-4 py-5">
            <div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
                <!-- Main Content -->
                <div class="lg:col-span-3">
                    <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 p-6">
                        
                        {hasValue(dataPage!.image) && (
                        <div class="mb-4">
                            <img src={dataPage!.image} alt={dataPage!.title} class="w-full h-auto rounded-lg">
                        </div>
                        )}
                        
                        {/* Article Meta Information */}
                        <div class="mb-6 pb-4 border-b border-gray-200 dark:border-gray-700">
                            <div class="flex flex-wrap items-center justify-between gap-4 text-sm text-gray-500 dark:text-gray-400">
                                <div class="flex items-center space-x-4">
                                    <span class="flex items-center">
                                        <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                                            <path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd"/>
                                        </svg>
                                        By {author}
                                    </span>
                                    <span class="flex items-center">
                                        <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                                            <path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd"/>
                                        </svg>
                                        {date}
                                    </span>
                                </div>
                                <div class="flex items-center space-x-4">
                                    <span class="flex items-center">
                                        <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                                            <path d="M10 12a2 2 0 100-4 2 2 0 000 4z"/>
                                            <path fill-rule="evenodd" d="M.458 10C1.732 5.943 5.522 3 10 3s8.268 2.943 9.542 7c-1.274 4.057-5.064 7-9.542 7S1.732 14.057.458 10zM14 10a4 4 0 11-8 0 4 4 0 018 0z" clip-rule="evenodd"/>
                                        </svg>
                                        {dataPage?.views || 0} views
                                    </span>
                                    {/* <span class="flex items-center">
                                        <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                                            <path fill-rule="evenodd" d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z" clip-rule="evenodd"/>
                                        </svg>
                                        0 likes
                                    </span> */}
                                </div>
                            </div>
                        </div>
                        
                        {/* Social Share Buttons */}
                        <SocialShare title={title} />                        
                        
                        {/* Content */}
                        <div class="space-y-4 text-gray-700 text-base leading-relaxed dark:text-white">
                            <div class="text-justify content-image" set:html={dataPage!.content} />
                        </div>
                    </div>
                    
                    {/* Next dan Previous Post */}
                    <div class="mt-8">
                        <NextPrevPost nextPost={dataPage?.nextPost || null} prevPost={dataPage?.prevPost || null} />
                    </div>
                    
                    {/* author section */}
                    <AuthorContent author={dataPage?.authorUsername || dataPage?.authorUUID} en={enPost} />
                    
                </div>

                {/* Sidebar */}
                <div class="lg:col-span-1">
                    <div class="space-y-6">
                        {/* Popular Articles */}
                        <PopulerPost limit={3} group={groupPost} en={enPost} />
                        {/* Categories */}
                        <CategoryListPost  group={groupPost} en={enPost} />
                        {/* Recent Articles */}
                        <RecentPost limit={6} group={groupPost} en={enPost} />
                        {/* Newsletter Signup */}
                        <Newsletter en={enPost} />
                    </div>
                </div>
            </div>
            

            {/* Related Posts Section */}
            <RelatedPost category={category} limit={4} group={groupPost} en={enPost} />
             
        </div>
    </div>
</Layout>
