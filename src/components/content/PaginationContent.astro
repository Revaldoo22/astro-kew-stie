---
interface Props {
    listData: any;
    isEmptyList: boolean;
    baseUrl?: string;
}

const { listData, isEmptyList, baseUrl = "" } = Astro.props;

if (isEmptyList) {
    return;
}

// Pastikan data dan totalPages ada sebelum mengaksesnya
const totalPages = listData?.totalPages ?? 0;
const currentPageData = listData?.currentPage ?? 1;

// Konfigurasi jumlah halaman yang terlihat
const visiblePages = 5; // Jumlah halaman yang ingin ditampilkan

// Hitung start dan end page dengan memastikan current page selalu di tengah
let startPage = Math.max(1, currentPageData - Math.floor(visiblePages / 2));
let endPage = Math.min(totalPages, startPage + visiblePages - 1);

// Koreksi jika endPage mencapai totalPages, sesuaikan startPage
if (endPage === totalPages && startPage > 1) {
    startPage = Math.max(1, endPage - visiblePages + 1);
}

// Pastikan current page selalu dalam range yang ditampilkan
if (currentPageData < startPage) {
    startPage = currentPageData;
    endPage = Math.min(totalPages, startPage + visiblePages - 1);
} else if (currentPageData > endPage) {
    endPage = currentPageData;
    startPage = Math.max(1, endPage - visiblePages + 1);
}

// Helper function untuk membuat URL pagination
const createPageUrl = (page: number) => {
    const url = new URL(baseUrl, Astro.url);
    url.searchParams.set("page", page.toString());
    return url.search; // Mengembalikan string query parameters
};

// Generate page numbers with ellipsis logic
const generatePageNumbers = () => {
    const pages = [];

    if (totalPages <= 7) {
        // Show all pages if total is 7 or less
        for (let i = 1; i <= totalPages; i++) {
            pages.push(i);
        }
    } else {
        // Always show first page
        pages.push(1);

        // Add ellipsis if there's a gap between first page and start page
        if (startPage > 3) {
            pages.push("...");
        } else if (startPage === 3) {
            pages.push(2);
        }

        // Show visible pages around current page
        for (let i = startPage; i <= endPage; i++) {
            if (i !== 1 && i !== totalPages) {
                pages.push(i);
            }
        }

        // Add ellipsis if there's a gap between end page and last page
        if (endPage < totalPages - 2) {
            pages.push("...");
        } else if (endPage === totalPages - 2) {
            pages.push(totalPages - 1);
        }

        // Always show last page
        if (totalPages > 1) {
            pages.push(totalPages);
        }
    }

    return pages;
};

const pageNumbers = generatePageNumbers();

// Debug log untuk memastikan logika bekerja dengan benar
// console.log('Pagination Debug:', {
//     currentPage: currentPageData,
//     totalPages,
//     startPage,
//     endPage,
//     pageNumbers,
//     listData: listData
// });
---

<div class="mt-12 flex justify-center">
    <nav aria-label="Pagination Navigation" class="flex items-center space-x-1">
        {/* Previous Button */}
        {
            currentPageData > 1 ? (
                <a
                    href={createPageUrl(currentPageData - 1)}
                    class="flex items-center justify-center w-10 h-10 text-gray-500 dark:text-gray-400 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 hover:text-gray-700 dark:hover:text-white transition-all duration-200 hover:scale-105"
                    aria-label="Previous page"
                >
                    <svg
                        class="w-4 h-4"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M15 19l-7-7 7-7"
                        />
                    </svg>
                </a>
            ) : (
                <span class="flex items-center justify-center w-10 h-10 text-gray-300 dark:text-gray-600 bg-gray-100 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg cursor-not-allowed">
                    <svg
                        class="w-4 h-4"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M15 19l-7-7 7-7"
                        />
                    </svg>
                </span>
            )
        }

        {/* Page Numbers */}
        <div class="flex items-center space-x-1">
            {
                pageNumbers.map((page) =>
                    page === "..." ? (
                        <span class="flex items-center justify-center w-10 h-10 text-gray-400 dark:text-gray-500">
                            <svg
                                class="w-4 h-4"
                                fill="currentColor"
                                viewBox="0 0 20 20"
                            >
                                <path d="M6 10a2 2 0 11-4 0 2 2 0 014 0zM12 10a2 2 0 11-4 0 2 2 0 014 0zM16 12a2 2 0 100-4 2 2 0 000 4z" />
                            </svg>
                        </span>
                    ) : (
                        <a
                            href={createPageUrl(page as number)}
                            class={`flex items-center justify-center w-10 h-10 text-sm font-medium rounded-lg transition-all duration-200 hover:scale-105 ${
                                currentPageData === page
                                    ? "text-white shadow-lg hover:opacity-90"
                                    : "text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-700 hover:text-gray-900 dark:hover:text-white"
                            }`}
                            style={
                                currentPageData === page
                                    ? "background-color: #1055C9; box-shadow: 0 10px 15px -3px rgba(217, 44, 84, 0.25);"
                                    : ""
                            }
                            aria-current={
                                currentPageData === page ? "page" : undefined
                            }
                            aria-label={`Go to page ${page}`}
                        >
                            {page}
                        </a>
                    ),
                )
            }
        </div>

        {/* Next Button */}
        {
            currentPageData < totalPages ? (
                <a
                    href={createPageUrl(currentPageData + 1)}
                    class="flex items-center justify-center w-10 h-10 text-gray-500 dark:text-gray-400 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 hover:text-gray-700 dark:hover:text-white transition-all duration-200 hover:scale-105"
                    aria-label="Next page"
                >
                    <svg
                        class="w-4 h-4"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M9 5l7 7-7 7"
                        />
                    </svg>
                </a>
            ) : (
                <span class="flex items-center justify-center w-10 h-10 text-gray-300 dark:text-gray-600 bg-gray-100 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg cursor-not-allowed">
                    <svg
                        class="w-4 h-4"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M9 5l7 7-7 7"
                        />
                    </svg>
                </span>
            )
        }
    </nav>
</div>
