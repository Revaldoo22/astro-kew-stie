---
import Layout from "@layouts/Layout.astro";
import Breadcrumb from "@components/Breadcrumb.astro";
import { MapPin, CalendarDays } from "@lucide/astro";

// Get year from URL params
const { year, groupActivity, enActivity } = Astro.props;

let yearFilter = year;

if (year === "semua") {
    yearFilter = "";
}

// Utility imports
import { eventPageService } from "@/services/index";

const { eventList, isEmptyEventList } =
    await eventPageService.fetchEventPageData(
        Astro.url,
        12,
        "event",
        0,
        yearFilter,
    );

// Validate year
const currentYear = new Date().getFullYear();
const isValidYear =
    year === "semua" ||
    (year &&
        /^\d{4}$/.test(year) &&
        parseInt(year) >= 2019 &&
        parseInt(year) <= currentYear);

if (!isValidYear) {
    return Astro.redirect("/404");
}

const titleActivity =
    year === "semua"
        ? enActivity === 0
            ? "Semua Tahun Aktivitas"
            : "All Years Activities"
        : enActivity === 0
          ? "Aktivitas " + year
          : "Activities " + year;
const linkActivity = enActivity === 0 ? "aktivitas" : "activity";

const breadcrumbs = [
    { label: "Home", href: "/" },
    {
        label: enActivity === 0 ? "Aktivitas" : "Activities",
        href: `/${linkActivity}`,
    },
    {
        label:
            year === "semua"
                ? enActivity === 0
                    ? "Semua Tahun"
                    : "All Years"
                : enActivity === 0
                  ? "Tahun " + year
                  : "Year " + year,
        href: `/${linkActivity}/${year}`,
    },
];

const metaTags = {
    title: titleActivity,
    description:
        enActivity === 0
            ? `Lihat berbagai aktivitas dan kegiatan yang kami selenggarakan pada tahun ${year}`
            : `View various activities and events we have carried out in the year ${year}`,
    keywords:
        enActivity === 0
            ? "aktivitas, kegiatan, event, workshop, seminar, disabilitas"
            : "activities, events, workshop, seminar, disabilities",
    image: "",
};
---

<Layout metaTags={metaTags}>
    <div class="min-h-screen bg-gray-50 dark:bg-gray-900">
        <!-- Breadcrumb Section -->
        <div
            class="bg-white dark:bg-gray-800 border-b border-gray-200 dark:border-gray-700"
        >
            <div class="max-w-screen-xl mx-auto px-4 py-4">
                <Breadcrumb breadcrumbs={breadcrumbs} />
            </div>
        </div>

        <!-- Main Content -->
        <div class="max-w-screen-xl mx-auto px-4 py-8">
            <!-- Back Button -->
            <div class="mb-6">
                <a
                    href={`/${linkActivity}`}
                    class="back-button inline-flex items-center text-[#1055C9] hover:text-[#b8244a] font-medium transition-all duration-300"
                >
                    <svg
                        class="w-5 h-5 mr-2"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M15 19l-7-7 7-7"></path>
                    </svg>
                    {
                        enActivity === 0
                            ? "Kembali ke Pilihan Tahun"
                            : "Back to Year Selection"
                    }
                </a>
            </div>

            <!-- Activities Grid -->
            <div class="mb-8">
                <div
                    class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 sm:gap-4 mb-6"
                >
                    <h2
                        class="text-xl sm:text-2xl font-bold text-gray-900 dark:text-white flex items-center flex-wrap gap-2"
                    >
                        <CalendarDays
                            class="w-5 h-5 sm:w-6 sm:h-6 text-[#1055C9] flex-shrink-0"
                        />
                        <span class="break-words">
                            {
                                enActivity === 0
                                    ? year === "semua"
                                        ? "Semua Aktivitas"
                                        : "Semua Aktivitas " + year
                                    : year === "semua"
                                      ? "All Activities"
                                      : "All Activities " + year
                            }
                        </span>
                    </h2>
                    <span
                        class="text-xs sm:text-sm text-gray-600 dark:text-gray-400 whitespace-nowrap sm:whitespace-normal"
                    >
                        {
                            enActivity === 0
                                ? "Menampilkan " +
                                  eventList.total +
                                  " aktivitas"
                                : "Showing " + eventList.total + " activities"
                        }
                    </span>
                </div>

                {
                    !isEmptyEventList && (
                        <div class="relative max-w-7xl mx-auto">
                            {/* Timeline Line - Center */}
                            <div class="timeline-line hidden md:block absolute left-1/2 top-0 bottom-0 w-0.5 bg-gradient-to-b from-[#1055C9] via-pink-400 to-pink-300 dark:from-[#1055C9] dark:via-pink-600 dark:to-pink-700 -ml-px" />

                            {/* Timeline Items */}
                            <div class="space-y-6 md:space-y-0">
                                {eventList.events.map((event, index) => (
                                    <div
                                        class={`timeline-item relative flex flex-col md:flex-row gap-6 md:gap-8 ${index % 2 === 0 ? "" : "md:flex-row-reverse"} ${index > 0 ? "md:-mt-20" : ""}`}
                                        style={`z-index: ${10 + index}; animation-delay: ${index * 0.15}s;`}
                                    >
                                        {/* Zigzag Connector Line to Next Card */}
                                        {index <
                                            eventList.events.length - 1 && (
                                            <svg
                                                class="zigzag-connector hidden md:block absolute left-0 right-0 top-0 pointer-events-none z-[1]"
                                                style={`width: 100%; height: 180px; overflow: visible; animation-delay: ${index * 0.15 + 0.5}s;`}
                                            >
                                                <defs>
                                                    <linearGradient
                                                        id={`gradient-${index}`}
                                                        x1="0%"
                                                        y1="0%"
                                                        x2="100%"
                                                        y2="100%"
                                                    >
                                                        <stop
                                                            offset="0%"
                                                            style="stop-color:#1055C9;stop-opacity:0.5"
                                                        />
                                                        <stop
                                                            offset="50%"
                                                            style="stop-color:#ec4899;stop-opacity:0.4"
                                                        />
                                                        <stop
                                                            offset="100%"
                                                            style="stop-color:#1055C9;stop-opacity:0.5"
                                                        />
                                                    </linearGradient>
                                                </defs>
                                                {/* Diagonal zigzag line connecting cards */}
                                                <path
                                                    class="zigzag-path"
                                                    d={
                                                        index % 2 === 0
                                                            ? `M 5% 60 Q 50% 95, 95% 130`
                                                            : `M 95% 60 Q 50% 95, 5% 130`
                                                    }
                                                    stroke={`url(#gradient-${index})`}
                                                    stroke-width="2"
                                                    fill="none"
                                                    stroke-dasharray="8,6"
                                                    stroke-linecap="round"
                                                    style={`animation-delay: ${index * 0.15 + 0.5}s;`}
                                                />
                                            </svg>
                                        )}

                                        {/* Timeline Dot - Center */}
                                        <div
                                            class="timeline-dot hidden md:block absolute left-1/2 top-12 w-4 h-4 -ml-2 bg-[#1055C9] rounded-full border-4 border-white dark:border-gray-900 shadow-lg"
                                            style={`z-index: 100; animation-delay: ${index * 0.15 + 0.3}s;`}
                                        />

                                        {/* Connecting Line from card to dot */}
                                        <div
                                            class={`connector-line hidden md:block absolute h-0.5 bg-gradient-to-r ${index % 2 === 0 ? "from-transparent via-[#1055C9]/30 to-[#1055C9] right-1/2" : "from-[#1055C9] via-[#1055C9]/30 to-transparent left-1/2"}`}
                                            style={`top: calc(3rem + 6px); width: calc(50% - 48px); z-index: 5; animation-delay: ${index * 0.15 + 0.2}s;`}
                                        />

                                        {/* Content Side */}
                                        <div
                                            class={`md:w-1/2 ${index % 2 === 0 ? "md:pr-12" : "md:pl-12"} relative z-10`}
                                        >
                                            {/* Content Card */}
                                            {event.link &&
                                            event.link.trim() !== "" ? (
                                                <a
                                                    href={event.link}
                                                    class="block"
                                                >
                                                    <article class="group bg-white dark:bg-gray-800 rounded-xl shadow-md hover:shadow-xl transition-all duration-300 overflow-hidden border border-gray-200 dark:border-gray-700 cursor-pointer">
                                                        {/* 2 Column Layout: Image Left, Content Right */}
                                                        <div class="flex flex-col sm:flex-row h-full">
                                                            {/* Image Column - Left */}
                                                            <div class="relative overflow-hidden sm:w-2/5 aspect-video sm:aspect-auto">
                                                                <img
                                                                    src={
                                                                        event.image_1200_690
                                                                    }
                                                                    alt={
                                                                        event.title
                                                                    }
                                                                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                                                                />
                                                            </div>

                                                            {/* Content Column - Right */}
                                                            <div class="flex-1 p-5 flex flex-col">
                                                                <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-2 line-clamp-2 group-hover:text-[#1055C9] transition-colors">
                                                                    {
                                                                        event.title
                                                                    }
                                                                </h3>

                                                                {/* Date - Inside Card */}
                                                                <div class="flex items-center gap-2 text-[#1055C9] mb-3">
                                                                    <CalendarDays class="w-4 h-4 text-[#1055C9] flex-shrink-0" />
                                                                    <span class="text-sm font-semibold">
                                                                        {
                                                                            event.start_time
                                                                        }
                                                                    </span>
                                                                </div>

                                                                <p class="text-gray-600 dark:text-gray-400 text-sm mb-4 line-clamp-3">
                                                                    {
                                                                        event.content
                                                                    }
                                                                </p>

                                                                {/* Footer - Bottom */}
                                                                <div class="flex items-center justify-between pt-4 mt-auto border-t border-gray-200 dark:border-gray-700">
                                                                    <div class="flex items-center gap-2 min-w-0 flex-1 mr-2">
                                                                        <MapPin class="w-4 h-4 text-gray-400 flex-shrink-0" />
                                                                        <span class="text-xs text-gray-600 dark:text-gray-400 truncate">
                                                                            {
                                                                                event.location
                                                                            }
                                                                        </span>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </article>
                                                </a>
                                            ) : (
                                                <article class="group bg-white dark:bg-gray-800 rounded-xl shadow-md hover:shadow-xl transition-all duration-300 overflow-hidden border border-gray-200 dark:border-gray-700">
                                                    {/* 2 Column Layout: Image Left, Content Right */}
                                                    <div class="flex flex-col sm:flex-row h-full">
                                                        {/* Image Column - Left */}
                                                        <div class="relative overflow-hidden sm:w-2/5 aspect-video sm:aspect-auto">
                                                            <img
                                                                src={
                                                                    event.image_1200_690
                                                                }
                                                                alt={
                                                                    event.title
                                                                }
                                                                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                                                            />
                                                        </div>

                                                        {/* Content Column - Right */}
                                                        <div class="flex-1 p-5 flex flex-col">
                                                            <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-2 line-clamp-2 group-hover:text-[#1055C9] transition-colors">
                                                                {event.title}
                                                            </h3>

                                                            {/* Date - Inside Card */}
                                                            <div class="flex items-center gap-2 text-[#1055C9] mb-3">
                                                                <CalendarDays class="w-4 h-4 text-[#1055C9] flex-shrink-0" />
                                                                <span class="text-sm font-semibold">
                                                                    {
                                                                        event.start_time
                                                                    }
                                                                </span>
                                                            </div>

                                                            <p class="text-gray-600 dark:text-gray-400 text-sm mb-4 line-clamp-3">
                                                                {event.content}
                                                            </p>

                                                            {/* Footer - Bottom */}
                                                            <div class="flex items-center justify-between pt-4 mt-auto border-t border-gray-200 dark:border-gray-700">
                                                                <div class="flex items-center gap-2 min-w-0 flex-1 mr-2">
                                                                    <MapPin class="w-4 h-4 text-gray-400 flex-shrink-0" />
                                                                    <span class="text-xs text-gray-600 dark:text-gray-400 truncate">
                                                                        {
                                                                            event.location
                                                                        }
                                                                    </span>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </article>
                                            )}
                                        </div>

                                        {/* Empty Space on Other Side */}
                                        <div class="hidden md:block md:w-1/2" />
                                    </div>
                                ))}
                            </div>
                        </div>
                    )
                }

                {
                    isEmptyEventList && (
                        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-12 text-center">
                            <svg
                                class="w-16 h-16 mx-auto mb-4 text-gray-400"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"
                                />
                            </svg>
                            <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-2">
                                {enActivity === 0
                                    ? "Belum Ada Aktivitas"
                                    : "No Activities"}
                            </h3>
                            <p class="text-gray-600 dark:text-gray-400 mb-6">
                                {enActivity === 0
                                    ? "Belum ada aktivitas yang terdaftar untuk tahun " +
                                      year
                                    : "No activities registered for the year " +
                                      year}
                            </p>
                            <a
                                href={`/${linkActivity}`}
                                class="inline-flex items-center px-6 py-3 bg-[#1055C9] text-white font-semibold rounded-lg hover:bg-[#b8244a] transition-colors duration-200"
                            >
                                {enActivity === 0
                                    ? "Lihat Tahun Lain"
                                    : "View Other Years"}
                                <svg
                                    class="w-4 h-4 ml-2"
                                    fill="none"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M9 5l7 7-7 7"
                                    />
                                </svg>
                            </a>
                        </div>
                    )
                }
            </div>
        </div>
    </div>
</Layout>

<style>
    .line-clamp-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .line-clamp-3 {
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    /* Timeline Animations */
    @keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @keyframes fadeInLeft {
        from {
            opacity: 0;
            transform: translateX(-50px);
        }
        to {
            opacity: 1;
            transform: translateX(0);
        }
    }

    @keyframes fadeInRight {
        from {
            opacity: 0;
            transform: translateX(50px);
        }
        to {
            opacity: 1;
            transform: translateX(0);
        }
    }

    @keyframes scaleIn {
        from {
            opacity: 0;
            transform: scale(0);
        }
        to {
            opacity: 1;
            transform: scale(1);
        }
    }

    @keyframes pulse {
        0%,
        100% {
            box-shadow: 0 0 0 0 rgba(217, 44, 84, 0.7);
        }
        50% {
            box-shadow: 0 0 0 10px rgba(217, 44, 84, 0);
        }
    }

    .timeline-item {
        opacity: 0;
        animation: fadeInUp 0.6s ease-out forwards;
    }

    @media (min-width: 768px) {
        .timeline-item:nth-child(odd) {
            animation: fadeInRight 0.6s ease-out forwards;
        }

        .timeline-item:nth-child(even) {
            animation: fadeInLeft 0.6s ease-out forwards;
        }
    }

    .timeline-dot {
        opacity: 0;
        animation:
            scaleIn 0.4s ease-out forwards,
            pulse 2s ease-out infinite;
        animation-delay: inherit;
    }

    /* Smooth entrance for cards */
    .timeline-item article {
        transition: all 0.3s ease;
    }

    .timeline-item:hover article {
        transform: translateY(-5px);
    }

    /* Image zoom effect */
    .timeline-item article img {
        transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .timeline-item article:hover img {
        transform: scale(1.08);
    }

    /* Timeline Line Animation */
    @keyframes drawLine {
        from {
            height: 0;
        }
        to {
            height: 100%;
        }
    }

    .timeline-line {
        height: 0;
        animation: drawLine 1.5s ease-out forwards;
    }

    /* Connector Line Animation */
    @keyframes expandWidth {
        from {
            width: 0;
            opacity: 0;
        }
        to {
            width: calc(50% - 48px);
            opacity: 1;
        }
    }

    .connector-line {
        opacity: 0;
        animation: expandWidth 0.5s ease-out forwards;
        animation-delay: inherit;
    }

    /* Back button hover animation */
    .back-button:hover {
        transform: translateX(-5px);
    }

    .back-button:hover svg {
        transform: translateX(-3px);
        transition: transform 0.3s ease;
    }

    /* Zigzag path animation */
    @keyframes drawPath {
        from {
            stroke-dashoffset: 300;
            opacity: 0;
        }
        to {
            stroke-dashoffset: 0;
            opacity: 1;
        }
    }

    .zigzag-connector {
        opacity: 0;
        animation: fadeIn 0.6s ease-out forwards;
        animation-delay: inherit;
    }

    .zigzag-path {
        stroke-dashoffset: 300;
        animation: drawPath 0.8s ease-out forwards;
        animation-delay: inherit;
    }

    /* Header fade in animation */
    @keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(-10px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    h2 {
        animation: fadeIn 0.5s ease-out;
    }
</style>
