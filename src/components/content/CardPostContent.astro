---
import type { PostListType } from "@/types/index";
import { cleanHTML } from "@/utils/helpers/dataHelpers";

// Helper function to format numbers with dot as thousands separator
const formatNumber = (num: number | string): string => {
    const number = typeof num === 'string' ? parseInt(num) : num;
    return number.toLocaleString('id-ID');
};
export interface Props {
    article: PostListType;
    link: string;
    imagePosition?: 'left' | 'top' | 'none';
    size?: 'small' | 'medium' | 'large';
    showContent?: boolean;
    showMeta?: boolean;
    showActions?: boolean;
    noLineClamp?: boolean;
}

const { 
    article, 
    link,
    imagePosition = 'top', 
    size = 'medium',
    showContent = true,
    showMeta = true,
    showActions = true,
    noLineClamp = false
} = Astro.props;

// Size configurations
const sizeConfig = {
    small: {
        card: 'rounded-lg',
        image: 'h-32',
        padding: 'p-4',
        title: 'text-sm',
        excerpt: `text-xs ${noLineClamp ? '' : 'line-clamp-2'}`,
        meta: 'text-xs'
    },
    medium: {
        card: 'rounded-xl',
        image: 'h-48',
        padding: 'p-5',
        title: 'text-base',
        excerpt: `text-sm ${noLineClamp ? '' : 'line-clamp-3'}`,
        meta: 'text-sm'
    },
    large: {
        card: 'rounded-2xl',
        image: 'h-64',
        padding: 'p-6',
        title: 'text-lg',
        excerpt: `text-sm ${noLineClamp ? '' : 'line-clamp-3'}`,
        meta: 'text-sm'
    }
};

const config = sizeConfig[size];
---

{imagePosition === 'top' && (
    
        // Image Top Layout
        <div class="relative">
            <a href={`${link}/${article.slug}`}>
                <img 
                    src={article.image_1200_690} 
                    alt={article.title}
                    class={`w-full object-cover transition-transform duration-300 group-hover:scale-105 ${config.image}`}
                />
            </a>        
            { article.categories && article.categories.map((category) => (
                <div class="absolute top-3 left-3">
                    <span class="text-white text-xs font-semibold px-2 py-1 rounded-full shadow-lg" style="background-color: #1055C9;">
                        {category}
                    </span>
                </div>  
            ))}
        </div>
        
        <div class={config.padding}>
            {showMeta && (
                <div class="flex items-center justify-between mb-2 text-gray-500 dark:text-gray-400">
                    <span class={`flex items-center space-x-1 ${config.meta} max-w-[60%]`}>
                        <svg class="w-3 h-3 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd"></path>
                        </svg>
                        <span class="truncate">{article.author}</span>
                    </span>
                    <span class={`${config.meta} flex-shrink-0`}>{article.date}</span>
                </div>
            )}
            
            <a href={`${link}/${article.slug}`}>
                <h4 class={`font-bold text-gray-900 dark:text-white mb-2 group-hover:text-[#1055C9] dark:group-hover:text-[#1055C9] transition-colors line-clamp-2 ${config.title}`}>
                    {article.title}
                </h4>
            </a>
            
            { article.content && showContent && (
            <p class={`text-gray-600 dark:text-gray-300 mb-3 ${config.excerpt}`}>
                {cleanHTML(article.content)}
            </p>
            )}
            
            {showActions && (
                <div class="flex items-center justify-between">
                    <div class="flex items-center space-x-3 text-gray-500 dark:text-gray-400">
                        <span class={`flex items-center space-x-1 ${config.meta}`}>
                            <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                                <path d="M10 12a2 2 0 100-4 2 2 0 000 4z"></path>
                                <path fill-rule="evenodd" d="M.458 10C1.732 5.943 5.522 3 10 3s8.268 2.943 9.542 7c-1.274 4.057-5.064 7-9.542 7S1.732 14.057.458 10zM14 10a4 4 0 11-8 0 4 4 0 018 0z" clip-rule="evenodd"></path>
                            </svg>
                            <span>{formatNumber(article.views || 0)}</span>
                        </span>
                        {/* <span class={`flex items-center space-x-1 ${config.meta}`}>
                            <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z" clip-rule="evenodd"></path>
                            </svg>
                            <span>0</span>
                        </span> */}
                    </div>
                    <a href={`${link}/${article.slug}`} class="text-[#1055C9] dark:text-[#1055C9] hover:text-[#b8244a] dark:hover:text-[#b8244a] font-medium flex items-center space-x-1 transition-colors">
                        <span class={config.meta}>Baca</span>
                        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                        </svg>
                    </a>
                </div>
            )}
        </div>
    )}

{imagePosition === 'left' && (
        // Image Left Layout
        <div class="flex flex-col md:flex-row h-full">
            <div class="relative md:w-1/3">
                <a href={`${link}/${article.slug}`}>
                    <img 
                        src={article.image_1200_690} 
                        alt={article.title}
                        class="w-full h-48 lg:h-full object-cover transition-transform duration-300 group-hover:scale-105"
                    />
                </a>              
                { article.categories && article.categories.map((category) => (
                    <div class="absolute top-3 left-3">
                        <span class="text-white text-xs font-semibold px-2 py-1 rounded-full shadow-lg" style="background-color: #1055C9;">
                            {category}
                        </span>
                    </div>
                ))}
            </div>
            
            <div class={`${config.padding} md:w-2/3 flex flex-col justify-between`}>
                <div>
                    {showMeta && (
                        <div class="flex items-center justify-between mb-3 text-gray-500 dark:text-gray-400">
                            <span class={`flex items-center space-x-1 ${config.meta} max-w-[50%]`}>
                                <svg class="w-4 h-4 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                                    <path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd"></path>
                                </svg>
                                <span class="truncate">{article.author}</span>
                            </span>
                            <span class={`flex items-center space-x-1 ${config.meta} flex-shrink-0`}>
                                <svg class="w-4 h-4 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                                    <path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd"></path>
                                </svg>
                                <span>{article.date}</span>
                            </span>
                        </div>
                    )}
                    
                    <a href={`${link}/${article.slug}`}>
                        <h4 class={`font-bold text-gray-900 dark:text-white mb-3 group-hover:text-[#1055C9] dark:group-hover:text-[#1055C9] transition-colors line-clamp-2 ${config.title}`}>
                            {article.title}
                        </h4>
                    </a>
                    
                    { article.content && showContent && (
                    <p class={`text-gray-600 dark:text-gray-300 mb-4 ${config.excerpt}`}>
                        {cleanHTML(article.content)}
                    </p>
                    )}
                </div>
                
                {showActions && (
                    <div class="flex items-center justify-between">
                        <div class="flex items-center space-x-4 text-gray-500 dark:text-gray-400">
                            <span class={`flex items-center space-x-1 ${config.meta}`}>
                                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                                    <path d="M10 12a2 2 0 100-4 2 2 0 000 4z"></path>
                                    <path fill-rule="evenodd" d="M.458 10C1.732 5.943 5.522 3 10 3s8.268 2.943 9.542 7c-1.274 4.057-5.064 7-9.542 7S1.732 14.057.458 10zM14 10a4 4 0 11-8 0 4 4 0 018 0z" clip-rule="evenodd"></path>
                                </svg>
                                <span>{formatNumber(article.views || 0)}</span>
                            </span>
                            {/* <span class={`flex items-center space-x-1 ${config.meta}`}>
                                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                                    <path fill-rule="evenodd" d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z" clip-rule="evenodd"></path>
                                </svg>
                                <span>0</span>
                            </span> */}
                        </div>
                        <a href={`${link}/${article.slug}`} class="text-[#1055C9] dark:text-[#1055C9] hover:text-[#b8244a] dark:hover:text-[#b8244a] font-medium flex items-center space-x-1 transition-colors">
                            <span class={config.meta}>Baca</span>
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                            </svg>
                        </a>
                    </div>
                )}
            </div>
        </div>
    )}

{imagePosition === 'none' && (
        // Text Only Layout
        <div class={config.padding}>
            {showMeta && (
                <div class="flex items-center justify-between mb-3 text-gray-500 dark:text-gray-400">
                    <div class="flex items-center space-x-4 min-w-0 flex-1">
                        <span class={`flex items-center space-x-1 ${config.meta} max-w-[200px]`}>
                            <svg class="w-4 h-4 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd"></path>
                            </svg>
                            <span class="truncate">{article.author}</span>
                        </span>
                        <span class={`flex items-center space-x-1 ${config.meta} flex-shrink-0`}>
                            <svg class="w-4 h-4 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd"></path>
                            </svg>
                            <span>{article.date}</span>
                        </span>
                    </div>

                    <div class="flex items-center space-x-3"> 

                        { article.categories && article.categories.map((category) => (
                            <span class="text-white text-xs font-semibold px-2 py-1 rounded-full" style="background-color: #1055C9;">
                                {category}
                            </span>
                        ))}

                    </div>
                </div>
            )}
            
            <a href={`${link}/${article.slug}`}>
                <h4 class={`font-bold text-gray-900 dark:text-white mb-3 group-hover:text-[#1055C9] dark:group-hover:text-[#1055C9] transition-colors line-clamp-2 ${config.title}`}>
                    {article.title}
                </h4>
            </a>
            
            { article.content && showContent && (
            <p class={`text-gray-600 dark:text-gray-300 mb-4 ${config.excerpt}`}>
                {cleanHTML(article.content)}
            </p>
            )}

            {showActions && (
                <div class="flex items-center justify-between">
                    <div class="flex items-center space-x-4 text-gray-500 dark:text-gray-400">
                        <span class={`flex items-center space-x-1 ${config.meta}`}>
                            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                                <path d="M10 12a2 2 0 100-4 2 2 0 000 4z"></path>
                                <path fill-rule="evenodd" d="M.458 10C1.732 5.943 5.522 3 10 3s8.268 2.943 9.542 7c-1.274 4.057-5.064 7-9.542 7S1.732 14.057.458 10zM14 10a4 4 0 11-8 0 4 4 0 018 0z" clip-rule="evenodd"></path>
                            </svg>
                            <span>{formatNumber(article.views || 0)}</span>
                        </span>
                        {/* <span class={`flex items-center space-x-1 ${config.meta}`}>
                            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z" clip-rule="evenodd"></path>
                            </svg>
                            <span>0</span>
                        </span> */}
                    </div>
                    <a href={`${link}/${article.slug}`} class="text-[#1055C9] dark:text-[#1055C9] hover:text-[#b8244a] dark:hover:text-[#b8244a] font-medium flex items-center space-x-1 transition-colors">
                        <span class={config.meta}>Baca</span>
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                        </svg>
                    </a>
                </div>
            )}
        </div>
    )}

<style>
    .line-clamp-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
    
    .line-clamp-3 {
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
    
    .hover-lift {
        transform: translateY(0);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    
    .hover-lift:hover {
        transform: translateY(-2px);
    }
</style>
