---
const { limit, group, en } = Astro.props;
import { getPopularText } from '@/utils/helpers/textPostHelpers';

// Utility imports
import { PostApi } from '@/services/index';
import { hasValue } from '@/utils/helpers/dataHelpers';
import type { PostListType } from '@/types/index';

// Initialize API service
const postApiService = new PostApi();

let isEmptypopularPost = true;
let popularPost: PostListType[] = [];

const popularPostData = await postApiService.fetchPopularPosts(`?limit=${limit}&skip=0&group=${group}&en=${en}`);

if(hasValue(popularPostData) && popularPostData !== null){
    isEmptypopularPost = false;
    popularPost = popularPostData;
}

const textPost = getPopularText(group, en);
console.log("POPULAR POST =>", popularPost);
---
{!isEmptypopularPost && (
<div class="w-full sm:max-w-sm bg-gradient-to-br from-red-50 to-red-50 dark:from-gray-800 dark:to-gray-900 border border-red-200 dark:border-gray-700 rounded-xl shadow-lg overflow-hidden">
    <div class="bg-gradient-to-r from-red-500 to-red-500 px-6 py-4">
        <div class="flex items-center justify-between">
            <h5 class="text-lg font-bold text-white">{textPost.popular.title || ''}</h5>
            <div class="w-8 h-8 bg-white/20 rounded-full flex items-center justify-center">
                <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15.362 5.214A8.252 8.252 0 0112 21 8.25 8.25 0 016.038 7.048 8.287 8.287 0 009 9.6a8.983 8.983 0 013.361-6.867 8.21 8.21 0 003 2.48z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 18a3.75 3.75 0 00.495-7.467 5.99 5.99 0 00-1.925 3.547 5.975 5.975 0 01-2.133-1A3.75 3.75 0 0012 18z"/>
                </svg>
            </div>
        </div>
    </div>
    
    <div class="p-6">
        <div class="space-y-4">
            {popularPost.map((article: any, index: number) => (
                <div class="group relative bg-white dark:bg-gray-800 rounded-lg p-4 border border-gray-100 dark:border-gray-700 hover:shadow-md hover:border-red-200 dark:hover:border-red-600 transition-all duration-300 hover:-translate-y-1">

                    <div class="absolute -top-2 -left-2 w-8 h-8 bg-gradient-to-r from-red-500 to-red-500 text-white text-sm font-bold rounded-full flex items-center justify-center shadow-lg">
                        {index + 1}
                    </div>
                    
                    <div class="ml-4">
                        <a 
                            href={`${textPost.popular.link}/${article.slug}`}
                            class="block group-hover:text-red-600 dark:group-hover:text-red-400 transition-colors duration-200"
                        >
                            <h6 class="text-sm font-semibold text-gray-900 dark:text-white line-clamp-2 leading-tight mb-2">
                                {article.title}
                            </h6>
                        </a>
                        
                        <div class="flex items-center justify-between text-xs text-gray-500 dark:text-gray-400">
                            <span class="flex items-center">
                                <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 20 20">
                                    <path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd"/>
                                </svg>
                                {article.date}
                            </span>
                            
                            <div class="flex items-center space-x-3">
                                <span class="flex items-center">
                                    <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 20 20">
                                        <path d="M10 12a2 2 0 100-4 2 2 0 000 4z"/>
                                        <path fill-rule="evenodd" d="M.458 10C1.732 5.943 5.522 3 10 3s8.268 2.943 9.542 7c-1.274 4.057-5.064 7-9.542 7S1.732 14.057.458 10zM14 10a4 4 0 11-8 0 4 4 0 018 0z" clip-rule="evenodd"/>
                                    </svg>
                                    {article.views || '0'}
                                </span>
                                
                                {/* <span class="flex items-center">
                                    <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 20 20">
                                        <path fill-rule="evenodd" d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z" clip-rule="evenodd"/>
                                    </svg>
                                    {article.likes || '0'}
                                </span> */}
                            </div>
                        </div>
                        
                        {article.category && (
                            <div class="mt-2">
                                <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-300">
                                    {article.category}
                                </span>
                            </div>
                        )}
                    </div>
                </div>
            ))}
        </div>
        
        <div class="mt-6 pt-4 border-t border-red-200 dark:border-gray-700">
            <a 
                href={`/${textPost.popular.link}`} 
                class="inline-flex items-center justify-center w-full px-4 py-2 text-sm font-medium text-white bg-gradient-to-r from-red-500 to-red-500 rounded-lg hover:from-red-600 hover:to-red-600 transition-all duration-200 shadow-md hover:shadow-lg"
            >
                {en === 0 ? `Lihat semua ${textPost.popular.title || ''}` : `View all ${textPost.popular.title || ''}`}
            </a>
        </div>
    </div>
</div>
)}