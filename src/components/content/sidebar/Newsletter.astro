---
const { en } = Astro.props;
---

<div
    class="w-full sm:max-w-sm bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg shadow"
>
    <div class="p-4">
        <h5 class="mb-3 text-lg font-semibold text-gray-900 dark:text-white">
            Newsletter
        </h5>
        <p class="text-sm text-gray-600 dark:text-gray-400 mb-4">
            {
                en === 0
                    ? "Dapatkan artikel terbaru langsung di inbox Anda"
                    : "Get the latest articles directly in your inbox"
            }
        </p>
        <form class="space-y-3">
            <div>
                <label
                    for="email"
                    class="block mb-2 text-sm font-medium text-gray-900 dark:text-white"
                    >Email</label
                >
                <input
                    type="email"
                    id="email"
                    placeholder="name@example.com"
                    class="bg-gray-50 dark:bg-gray-700 border border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white text-sm rounded-lg focus:ring-[#1055C9] focus:border-[#1055C9] block w-full p-2.5 dark:placeholder-gray-400"
                    required
                />
            </div>
            <button
                type="submit"
                class="w-full cursor-pointer text-white bg-[#1055C9] dark:bg-[#1055C9] hover:bg-[#b8254a] dark:hover:bg-[#b8254a] focus:ring-4 focus:outline-none focus:ring-[#1055C9]/30 dark:focus:ring-[#1055C9]/30 font-medium rounded-lg text-sm px-5 py-2.5 text-center"
            >
                {en === 0 ? "Berlangganan" : "Subscribe"}
            </button>
        </form>
    </div>
</div>
