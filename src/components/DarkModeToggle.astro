---
// Dark Mode Toggle Component
export interface Props {
  instanceId?: string;
}

const { instanceId = 'default' } = Astro.props;
---

<button 
  id={`theme-toggle-${instanceId}`} 
  type="button" 
  class="text-gray-500 cursor-pointer dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-700 focus:outline-none focus:ring-4 focus:ring-gray-200 dark:focus:ring-gray-700 rounded-lg text-sm p-2.5 transition-all duration-200 disabled:opacity-50 disabled:cursor-not-allowed"
  aria-label="Toggle dark mode"
  title="Toggle dark/light mode"
>
  <svg id={`theme-toggle-dark-icon-${instanceId}`} class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
    <path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"></path>
  </svg>
  <svg id={`theme-toggle-light-icon-${instanceId}`} class="hidden w-5 h-5" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
    <path d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z" fill-rule="evenodd" clip-rule="evenodd"></path>
  </svg>
</button>

<script is:inline define:vars={{ instanceId }}>
  // Improved dark mode toggle with better error handling and immediate execution
  (function() {
    'use strict';
    
    function initializeDarkModeToggle() {
      try {
        const themeToggleDarkIcon = document.getElementById(`theme-toggle-dark-icon-${instanceId}`);
        const themeToggleLightIcon = document.getElementById(`theme-toggle-light-icon-${instanceId}`);
        const themeToggleBtn = document.getElementById(`theme-toggle-${instanceId}`);

        // Validate elements exist
        if (!themeToggleDarkIcon || !themeToggleLightIcon || !themeToggleBtn) {
          console.warn('Dark mode toggle elements not found');
          return;
        }

        // Function to update icons based on current theme
        function updateIcons() {
          if (themeToggleDarkIcon && themeToggleLightIcon) {
            const isDark = document.documentElement.classList.contains('dark');
            if (isDark) {
              themeToggleLightIcon.classList.remove('hidden');
              themeToggleDarkIcon.classList.add('hidden');
            } else {
              themeToggleDarkIcon.classList.remove('hidden');
              themeToggleLightIcon.classList.add('hidden');
            }
          }
        }

        // Function to toggle theme
        function toggleTheme() {
          const isDark = document.documentElement.classList.contains('dark');
          
          if (isDark) {
            document.documentElement.classList.remove('dark');
            localStorage.setItem('color-theme', 'light');
          } else {
            document.documentElement.classList.add('dark');
            localStorage.setItem('color-theme', 'dark');
          }
          
          // Update icons after theme change
          updateIcons();
          
          // Dispatch custom event for any other components that need to know about theme changes
          window.dispatchEvent(new CustomEvent('themeChanged', { 
            detail: { darkMode: !isDark } 
          }));
        }

        // Initialize icons immediately
        updateIcons();

        // Remove any existing event listeners to prevent duplicates
        themeToggleBtn.replaceWith(themeToggleBtn.cloneNode(true));
        const newThemeToggleBtn = document.getElementById(`theme-toggle-${instanceId}`);
        
        // Add click event listener
        if (newThemeToggleBtn) {
          newThemeToggleBtn.addEventListener('click', toggleTheme);
        }
        
        // Listen for theme changes from other sources
        const observer = new MutationObserver(function(mutations) {
          mutations.forEach(function(mutation) {
            if (mutation.type === 'attributes' && mutation.attributeName === 'class') {
              updateIcons();
            }
          });
        });
        
        observer.observe(document.documentElement, {
          attributes: true,
          attributeFilter: ['class']
        });
        
        // console.log(`Dark mode toggle initialized successfully for instance: ${instanceId}`);
        
      } catch (error) {
        console.error('Error initializing dark mode toggle:', error);
      }
    }

    // Initialize immediately if DOM is ready, otherwise wait for DOMContentLoaded
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initializeDarkModeToggle);
    } else {
      initializeDarkModeToggle();
    }
  })();
</script>
