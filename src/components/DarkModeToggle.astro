---
export interface Props {
  instanceId?: string;
}

const { instanceId = 'default' } = Astro.props;
---

<button
  id={`theme-toggle-${instanceId}`}
  type="button"
  class="relative inline-flex flex-shrink-0 items-center w-11 h-6 rounded-full border
    bg-gray-200 dark:bg-slate-700
    border-gray-300 dark:border-slate-500
    cursor-pointer
    transition-colors duration-300 ease-in-out
    hover:bg-gray-300 dark:hover:bg-slate-600
    focus:outline-none focus:ring-2 focus:ring-[#FF8C00]/50 focus:ring-offset-1 dark:focus:ring-offset-gray-800
    disabled:opacity-50 disabled:cursor-not-allowed"
  aria-label="Toggle dark mode"
  title="Toggle dark/light mode"
>
  <span
    class="absolute left-0.5 w-5 h-5 rounded-full shadow-sm
      bg-white dark:bg-slate-900
      transition-all duration-300 ease-in-out
      translate-x-0 dark:translate-x-5
      flex items-center justify-center"
  >
    <!-- Sun icon (light mode) -->
    <svg
      class="absolute w-3 h-3 text-amber-500 transition-all duration-200 opacity-100 scale-100 dark:opacity-0 dark:scale-50"
      fill="currentColor"
      viewBox="0 0 20 20"
      xmlns="http://www.w3.org/2000/svg"
    >
      <path
        fill-rule="evenodd"
        d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z"
        clip-rule="evenodd"
      ></path>
    </svg>
    <!-- Moon icon (dark mode) -->
    <svg
      class="absolute w-3 h-3 text-yellow-300 transition-all duration-200 opacity-0 scale-50 dark:opacity-100 dark:scale-100"
      fill="currentColor"
      viewBox="0 0 20 20"
      xmlns="http://www.w3.org/2000/svg"
    >
      <path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"
      ></path>
    </svg>
  </span>
</button>

<script is:inline define:vars={{ instanceId }}>
  (function () {
    'use strict';

    function initializeDarkModeToggle() {
      try {
        const themeToggleBtn = document.getElementById(`theme-toggle-${instanceId}`);
        if (!themeToggleBtn) return;

        // Clone to remove any existing duplicate listeners
        themeToggleBtn.replaceWith(themeToggleBtn.cloneNode(true));
        const newBtn = document.getElementById(`theme-toggle-${instanceId}`);
        if (!newBtn) return;

        newBtn.addEventListener('click', function () {
          const isDark = document.documentElement.classList.contains('dark');
          if (isDark) {
            document.documentElement.classList.remove('dark');
            localStorage.setItem('color-theme', 'light');
          } else {
            document.documentElement.classList.add('dark');
            localStorage.setItem('color-theme', 'dark');
          }
          window.dispatchEvent(
            new CustomEvent('themeChanged', { detail: { darkMode: !isDark } })
          );
        });
      } catch (error) {
        console.error('Error initializing dark mode toggle:', error);
      }
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initializeDarkModeToggle);
    } else {
      initializeDarkModeToggle();
    }
  })();
</script>
