---
// Brochure Request Form Component
import { websiteInfo } from "@globals/info";

const studyPrograms = [
    "S2 Manajemen dan Kewirausahaan (M.Bns)",
    "S1 Manajemen (S.M.)",
    "S1 Akuntansi (S.Ak.)",
    "S1 Bisnis (S.Bns.)",
    "S1 Hukum (S.H.)",
    "S1 Teknik Sipil (S.T.)",
    "S1 Teknik Informatika (S.Kom.)",
    "S1 Desain Komunikasi Visual (S.Ds.)",
    "S1 Sistem Komputer (S.Kom.)",
    "S1 Sistem Informasi (S.Kom.)",
    "D4 Akuntansi Perpajakan (S.Tr.Ak.)",
    "D3 Teknik Informatika (A.Md.Kom.)",
    "Lainnya",
];

const studyMethods = ["Full Online", "Online Offline (Hybrid)", "Offline"];
const brochureLink = websiteInfo.brosur.pmb;
---

<div
    class="bg-white dark:bg-gray-800 rounded-xl shadow-md border border-gray-200 dark:border-gray-700 overflow-hidden"
>
    <!-- Header -->
    <div class="bg-gradient-to-r from-orange-500 to-orange-600 p-3">
        <h3 class="text-base font-bold text-white">Permintaan Brosur STIE STEKOM</h3>
    </div>

    <!-- Form -->
    <div class="p-4">
        <form id="brochure-form" class="space-y-3">
            <!-- Nama Lengkap -->
            <div>
                <label
                    for="fullName"
                    class="block text-xs font-semibold text-[#FF8C00] dark:text-blue-400 mb-1"
                >
                    Nama Lengkap <span class="text-red-500">*</span>
                </label>
                <input
                    type="text"
                    id="fullName"
                    name="fullName"
                    class="w-full px-3 py-2 text-sm border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-[#FF8C00] focus:border-transparent dark:bg-gray-700 dark:text-white transition-all"
                    placeholder="Masukkan nama lengkap (min. 5 karakter)"
                />
                <p id="fullName-error" class="hidden text-xs text-red-500 mt-1">
                </p>
            </div>

            <!-- Email -->
            <div>
                <label
                    for="email"
                    class="block text-xs font-semibold text-[#FF8C00] dark:text-blue-400 mb-1"
                >
                    Email <span class="text-red-500">*</span>
                </label>
                <input
                    type="text"
                    id="email"
                    name="email"
                    class="w-full px-3 py-2 text-sm border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-[#FF8C00] focus:border-transparent dark:bg-gray-700 dark:text-white transition-all"
                    placeholder="email@example.com"
                />
                <p id="email-error" class="hidden text-xs text-red-500 mt-1">
                </p>
            </div>

            <!-- No HP -->
            <div>
                <label
                    for="phone"
                    class="block text-xs font-semibold text-[#FF8C00] dark:text-blue-400 mb-1"
                >
                    No HP Anda <span class="text-red-500">*</span>
                </label>
                <input
                    type="text"
                    id="phone"
                    name="phone"
                    class="w-full px-3 py-2 text-sm border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-[#FF8C00] focus:border-transparent dark:bg-gray-700 dark:text-white transition-all"
                    placeholder="Contoh: 6281234567890 atau 081234567890"
                />
                <p id="phone-error" class="hidden text-xs text-red-500 mt-1">
                </p>
            </div>

            <!-- Alamat Domisili -->
            <div>
                <label
                    for="address"
                    class="block text-xs font-semibold text-[#FF8C00] dark:text-blue-400 mb-1"
                >
                    Alamat Domisili <span class="text-red-500">*</span>
                </label>
                <textarea
                    id="address"
                    name="address"
                    rows="2"
                    class="w-full px-3 py-2 text-sm border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-[#FF8C00] focus:border-transparent dark:bg-gray-700 dark:text-white transition-all resize-none"
                    placeholder="Masukkan alamat lengkap (min. 10 karakter)"
                ></textarea>
                <p id="address-error" class="hidden text-xs text-red-500 mt-1">
                </p>
            </div>

            <!-- Pilihan Jurusan -->
            <div>
                <label
                    for="studyProgram"
                    class="block text-xs font-semibold text-[#FF8C00] dark:text-blue-400 mb-1"
                >
                    Pilihan Jurusan <span class="text-red-500">*</span>
                </label>
                <select
                    id="studyProgram"
                    name="studyProgram"
                    class="w-full px-3 py-2 text-sm border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-[#FF8C00] focus:border-transparent dark:bg-gray-700 dark:text-white transition-all appearance-none bg-no-repeat bg-right pr-8"
                    style="background-image: url('data:image/svg+xml;charset=UTF-8,%3csvg xmlns=%27http://www.w3.org/2000/svg%27 viewBox=%270 0 24 24%27 fill=%27none%27 stroke=%27currentColor%27 stroke-width=%272%27 stroke-linecap=%27round%27 stroke-linejoin=%27round%27%3e%3cpolyline points=%276 9 12 15 18 9%27%3e%3c/polyline%3e%3c/svg%3e'); background-size: 1.2em;"
                >
                    <option value="" disabled selected>Pilih jurusan</option>
                    {
                        studyPrograms.map((program) => (
                            <option value={program}>{program}</option>
                        ))
                    }
                </select>
                <p
                    id="studyProgram-error"
                    class="hidden text-xs text-red-500 mt-1"
                >
                </p>
            </div>

            <!-- Minat Metode Perkuliahan -->
            <div>
                <label
                    for="studyMethod"
                    class="block text-xs font-semibold text-[#FF8C00] dark:text-blue-400 mb-1"
                >
                    Minat Metode Perkuliahan <span class="text-red-500">*</span>
                </label>
                <select
                    id="studyMethod"
                    name="studyMethod"
                    class="w-full px-3 py-2 text-sm border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-[#FF8C00] focus:border-transparent dark:bg-gray-700 dark:text-white transition-all appearance-none bg-no-repeat bg-right pr-8"
                    style="background-image: url('data:image/svg+xml;charset=UTF-8,%3csvg xmlns=%27http://www.w3.org/2000/svg%27 viewBox=%270 0 24 24%27 fill=%27none%27 stroke=%27currentColor%27 stroke-width=%272%27 stroke-linecap=%27round%27 stroke-linejoin=%27round%27%3e%3cpolyline points=%276 9 12 15 18 9%27%3e%3c/polyline%3e%3c/svg%3e'); background-size: 1.2em;"
                >
                    <option value="" disabled selected>Pilih metode</option>
                    {
                        studyMethods.map((method) => (
                            <option value={method}>{method}</option>
                        ))
                    }
                </select>
                <p
                    id="studyMethod-error"
                    class="hidden text-xs text-red-500 mt-1"
                >
                </p>
            </div>

            <!-- Submit Button -->
            <button
                id="submit-button"
                type="submit"
                class="w-full px-4 py-2.5 bg-green-600 hover:bg-green-700 text-white font-bold text-sm rounded-lg transition-all duration-300 shadow-lg hover:shadow-xl transform hover:-translate-y-0.5 disabled:opacity-50 disabled:cursor-not-allowed disabled:transform-none"
            >
                <span id="submit-text">KIRIM</span>
                <span id="submit-loading" class="hidden">
                    <svg
                        class="animate-spin inline-block w-4 h-4 mr-2"
                        xmlns="http://www.w3.org/2000/svg"
                        fill="none"
                        viewBox="0 0 24 24"
                    >
                        <circle
                            class="opacity-25"
                            cx="12"
                            cy="12"
                            r="10"
                            stroke="currentColor"
                            stroke-width="4"></circle>
                        <path
                            class="opacity-75"
                            fill="currentColor"
                            d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"
                        ></path>
                    </svg>
                    Mengirim...
                </span>
            </button>

            <!-- Error Message -->
            <p
                id="submit-error"
                class="hidden text-xs text-red-500 text-center mt-2"
            >
            </p>
        </form>
    </div>
</div>

<!-- Success Modal -->
<div id="brochure-modal" class="hidden fixed inset-0 z-[9999] overflow-y-auto">
    <!-- Backdrop -->
    <div class="fixed inset-0 bg-black/50 backdrop-blur-sm transition-opacity">
    </div>

    <!-- Modal Content -->
    <div class="flex min-h-full items-center justify-center p-4">
        <div
            class="relative bg-white dark:bg-gray-800 rounded-2xl shadow-2xl max-w-md w-full p-6 transform transition-all"
        >
            <!-- Success Icon -->
            <div
                class="mx-auto flex items-center justify-center h-16 w-16 rounded-full bg-green-100 dark:bg-green-900/30 mb-4"
            >
                <svg
                    class="h-10 w-10 text-green-600 dark:text-green-400"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M5 13l4 4L19 7"></path>
                </svg>
            </div>

            <!-- Title -->
            <h3
                class="text-xl font-bold text-center text-gray-900 dark:text-white mb-2"
            >
                Terima Kasih!
            </h3>

            <!-- Message -->
            <p class="text-center text-gray-600 dark:text-gray-300 mb-6">
                Silakan klik tombol di bawah untuk
                meminta brosur via WhatsApp.
            </p>

            <!-- Manual Download Button (backup) -->
            <a
                id="brochure-link-backup"
                href="http://link.stekom.ac.id/brosur-kew"
                target="_blank"
                rel="noopener noreferrer"
                class="block w-full px-6 py-3 bg-gradient-to-r from-orange-500 to-orange-600 hover:from-orange-600 hover:to-orange-700 text-white font-bold text-center rounded-lg transition-all duration-300 shadow-lg hover:shadow-xl mb-3"
            >
                <span class="flex items-center justify-center gap-2">
                    <svg
                        class="w-5 h-5"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
                        ></path>
                    </svg>
                    Minta Brosur
                </span>
            </a>

            <!-- Close Button -->
            <button
                id="close-modal"
                class="w-full px-6 py-2.5 bg-gray-200 dark:bg-gray-700 hover:bg-gray-300 dark:hover:bg-gray-600 text-gray-800 dark:text-gray-200 font-semibold rounded-lg transition-all duration-300"
            >
                Tutup
            </button>
        </div>
    </div>
</div>

<script>
    // Type declarations for window functions
    declare global {
        interface Window {
            showBrochureSuccessModal?: () => void;
        }
    }
    document.addEventListener("DOMContentLoaded", () => {
        // Handle form submission
        const form = document.getElementById(
            "brochure-form",
        ) as HTMLFormElement;
        const modal = document.getElementById("brochure-modal");
        const closeModalBtn = document.getElementById("close-modal");
        const brochureLink =
            document.getElementById("brochure-link")?.getAttribute("href") ||
            "";

        // Get form fields
        const fullNameInput = document.getElementById(
            "fullName",
        ) as HTMLInputElement;
        const emailInput = document.getElementById("email") as HTMLInputElement;
        const phoneInput = document.getElementById("phone") as HTMLInputElement;
        const addressInput = document.getElementById(
            "address",
        ) as HTMLTextAreaElement;
        const studyProgramSelect = document.getElementById(
            "studyProgram",
        ) as HTMLSelectElement;
        const studyMethodSelect = document.getElementById(
            "studyMethod",
        ) as HTMLSelectElement;

        // Get error message elements
        const fullNameError = document.getElementById("fullName-error");
        const emailError = document.getElementById("email-error");
        const phoneError = document.getElementById("phone-error");
        const addressError = document.getElementById("address-error");
        const studyProgramError = document.getElementById("studyProgram-error");
        const studyMethodError = document.getElementById("studyMethod-error");


        // Validation functions
        function validateFullName(): boolean {
            const value = fullNameInput.value.trim();
            if (value.length < 5) {
                showError(
                    fullNameInput,
                    fullNameError,
                    "Nama harus minimal 5 karakter",
                );
                return false;
            }
            clearError(fullNameInput, fullNameError);
            return true;
        }

        function validateAddress(): boolean {
            const value = addressInput.value.trim();
            if (value.length < 10) {
                showError(
                    addressInput,
                    addressError,
                    "Alamat harus minimal 10 karakter",
                );
                return false;
            }
            clearError(addressInput, addressError);
            return true;
        }

        function validateEmail(): boolean {
            const value = emailInput.value.trim();

            // Check if empty
            if (value.length === 0) {
                showError(emailInput, emailError, "Email harus diisi");
                return false;
            }

            // Check email format
            const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
            if (!emailRegex.test(value)) {
                showError(emailInput, emailError, "Format email tidak valid");
                return false;
            }

            clearError(emailInput, emailError);
            return true;
        }

        function validateStudyProgram(): boolean {
            const value = studyProgramSelect.value;

            if (!value || value === "") {
                showError(
                    studyProgramSelect,
                    studyProgramError,
                    "Pilih jurusan terlebih dahulu",
                );
                return false;
            }

            clearError(studyProgramSelect, studyProgramError);
            return true;
        }

        function validateStudyMethod(): boolean {
            const value = studyMethodSelect.value;

            if (!value || value === "") {
                showError(
                    studyMethodSelect,
                    studyMethodError,
                    "Pilih metode perkuliahan terlebih dahulu",
                );
                return false;
            }

            clearError(studyMethodSelect, studyMethodError);
            return true;
        }

        function validatePhone(): boolean {
            const value = phoneInput.value.trim();

            // Check if it's all numbers
            if (!/^\d+$/.test(value)) {
                showError(
                    phoneInput,
                    phoneError,
                    "Nomor HP harus berupa angka",
                );
                return false;
            }

            // Check if starts with 62 or 08
            if (!value.startsWith("62") && !value.startsWith("08")) {
                showError(
                    phoneInput,
                    phoneError,
                    "Nomor HP harus diawali dengan 62 atau 08",
                );
                return false;
            }

            // Check minimum length based on prefix
            // Format 62: min 11 digits (62 + 9 digits) - e.g., 62812345678
            // Format 08: min 10 digits (08 + 8 digits) - e.g., 0812345678
            if (value.startsWith("62") && value.length < 11) {
                showError(
                    phoneInput,
                    phoneError,
                    "Nomor HP dengan awalan 62 harus minimal 11 digit",
                );
                return false;
            }

            if (value.startsWith("08") && value.length < 10) {
                showError(
                    phoneInput,
                    phoneError,
                    "Nomor HP dengan awalan 08 harus minimal 10 digit",
                );
                return false;
            }

            clearError(phoneInput, phoneError);
            return true;
        }

        function normalizePhone(value: string): string {
            const phone = value.trim();
            if (phone.startsWith("08")) {
                return `62${phone.slice(1)}`;
            }
            return phone;
        }

        function buildSourcePage(hostname: string): string {
            const params = new URLSearchParams(window.location.search);
            const source = (params.get("utm_source") || "").trim();
            const medium = (params.get("utm_medium") || "").trim();

            const readableSource =
                source.length > 0
                    ? source
                          .split(/[-_ ]+/)
                          .map(
                              (part) =>
                                  part.charAt(0).toUpperCase() +
                                  part.slice(1).toLowerCase(),
                          )
                          .join(" ")
                    : "Direct";

            const brand = hostname.includes("pmb.stekom.ac.id")
                ? "Kew STIE"
                : hostname;

            return medium
                ? `${readableSource} (${medium}), ${brand}`
                : `${readableSource}, ${brand}`;
        }

        function showError(
            input: HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement,
            errorElement: HTMLElement | null,
            message: string,
        ) {
            input.classList.add("border-red-500", "dark:border-red-500");
            input.classList.remove("border-gray-300", "dark:border-gray-600");
            if (errorElement) {
                errorElement.textContent = message;
                errorElement.classList.remove("hidden");
            }
        }

        function clearError(
            input: HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement,
            errorElement: HTMLElement | null,
        ) {
            input.classList.remove("border-red-500", "dark:border-red-500");
            input.classList.add("border-gray-300", "dark:border-gray-600");
            if (errorElement) {
                errorElement.textContent = "";
                errorElement.classList.add("hidden");
            }
        }

        // Real-time validation
        if (fullNameInput) {
            fullNameInput.addEventListener("blur", validateFullName);
            fullNameInput.addEventListener("input", () => {
                if (fullNameInput.value.length >= 5) {
                    clearError(fullNameInput, fullNameError);
                }
            });
        }

        if (phoneInput) {
            phoneInput.addEventListener("blur", validatePhone);
            phoneInput.addEventListener("input", () => {
                // Clear error as user types if validation passes
                const value = phoneInput.value.trim();
                const isValidFormat =
                    /^\d+$/.test(value) &&
                    (value.startsWith("62") || value.startsWith("08"));
                const isValidLength =
                    (value.startsWith("62") && value.length >= 11) ||
                    (value.startsWith("08") && value.length >= 10);

                if (isValidFormat && isValidLength) {
                    clearError(phoneInput, phoneError);
                }
            });
        }

        if (addressInput) {
            addressInput.addEventListener("blur", validateAddress);
            addressInput.addEventListener("input", () => {
                if (addressInput.value.trim().length >= 10) {
                    clearError(addressInput, addressError);
                }
            });
        }

        if (emailInput) {
            emailInput.addEventListener("blur", validateEmail);
            emailInput.addEventListener("input", () => {
                const value = emailInput.value.trim();
                const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
                if (value.length > 0 && emailRegex.test(value)) {
                    clearError(emailInput, emailError);
                }
            });
        }

        if (studyProgramSelect) {
            studyProgramSelect.addEventListener("change", validateStudyProgram);
        }

        if (studyMethodSelect) {
            studyMethodSelect.addEventListener("change", validateStudyMethod);
        }

        if (form && modal) {
            form.addEventListener("submit", async (e) => {
                e.preventDefault();

                // Validate all fields
                const isFullNameValid = validateFullName();
                const isEmailValid = validateEmail();
                const isPhoneValid = validatePhone();
                const isAddressValid = validateAddress();
                const isStudyProgramValid = validateStudyProgram();
                const isStudyMethodValid = validateStudyMethod();

                if (
                    !isFullNameValid ||
                    !isEmailValid ||
                    !isPhoneValid ||
                    !isAddressValid ||
                    !isStudyProgramValid ||
                    !isStudyMethodValid
                ) {
                    return;
                }

                // Get form data
                const formData = new FormData(form);
                const data = Object.fromEntries(formData.entries());

                // Get UI elements for loading state
                const submitButton = document.getElementById(
                    "submit-button",
                ) as HTMLButtonElement;
                const submitText = document.getElementById("submit-text");
                const submitLoading = document.getElementById("submit-loading");
                const submitError = document.getElementById("submit-error");

                // Show loading state
                if (submitButton && submitText && submitLoading) {
                    submitButton.disabled = true;
                    submitText.classList.add("hidden");
                    submitLoading.classList.remove("hidden");
                }

                // Hide previous errors
                if (submitError) {
                    submitError.classList.add("hidden");
                    submitError.textContent = "";
                }

                try {
                    // Send data to Google Sheets
                    // Get API URL from meta tag (set in Layout.astro)
                    const apiUrl =
                        document
                            .querySelector('meta[name="google-sheets-api"]')
                            ?.getAttribute("content") || "";

                    if (!apiUrl) {
                        // console.warn("Google Sheets API URL not configured");
                        throw new Error(
                            "Konfigurasi Google Sheets belum diatur. Silakan hubungi administrator.",
                        );
                    }

                    // Get current URL for slug and hostname for source
                    const currentUrl =
                        window.location.origin +
                        window.location.pathname +
                        window.location.search;
                    const hostname = window.location.hostname;

                    // Convert data to URL parameters for Google Apps Script
                    const params = new URLSearchParams();
                    params.append("fullName", data.fullName as string);
                    params.append("email", data.email as string);
                    params.append("phone", data.phone as string);
                    params.append("address", data.address as string);
                    params.append("studyProgram", data.studyProgram as string);
                    params.append("studyMethod", data.studyMethod as string);
                    params.append("slug", currentUrl);
                    params.append("source", "Permintaan Brosur KEW STIE");

                    // Send as GET request with parameters (Google Apps Script friendly)
                    const urlWithParams = `${apiUrl}?${params.toString()}`;
                    // console.log("Request URL:", urlWithParams);

                    const response = await fetch(urlWithParams, {
                        method: "GET",
                        redirect: "follow",
                    });
                    if (!response.ok) {
                        throw new Error(
                            "Pengiriman data gagal. Silakan coba beberapa saat lagi.",
                        );
                    }

                    // Send lead to tracking database (non-blocking)
                    const trackingPayload = {
                        source_page: buildSourcePage(hostname),
                        nama: (data.fullName as string) || "",
                        email: (data.email as string) || "",
                        phone: normalizePhone((data.phone as string) || ""),
                        data: JSON.stringify({
                            form: "Permintaan Brosur KEW STIE",
                            studyProgram: (data.studyProgram as string) || "",
                            studyMethod: (data.studyMethod as string) || "",
                            address: (data.address as string) || "",
                            slug: currentUrl,
                            source: "Permintaan Brosur KEW STIE",
                            timestamp: new Date().toISOString(),
                        }),
                    };

                    const trackingUrl =
                        "https://pmb.stekom.ac.id/api/tracking/submit-direct";
                    fetch(trackingUrl, {
                        method: "POST",
                        headers: {
                            "Content-Type": "application/json",
                        },
                        body: JSON.stringify(trackingPayload),
                    }).catch(() => {
                        // Intentionally ignore tracking errors to keep brochure flow successful
                    });

                    // console.log("Response received:", response);
                    // console.log("Data sent to Google Sheets successfully");

                    // Don't close the parent form modal yet - let success modal show first
                    // The success modal close button will handle closing both modals
                    // const formModal = document.getElementById(
                    //     "brochure-form-modal",
                    // );
                    // if (formModal) {
                    //     formModal.classList.add("hidden");
                    //     console.log("Form modal closed");
                    // } else {
                    //     console.log("Form modal not found");
                    // }

                    // Check if we're inside BrochureRequestFormModal (external modal exists)
                    const externalSuccessModal = document.getElementById(
                        "brochure-modal-external",
                    );

                    if (externalSuccessModal) {
                        // We're inside BrochureRequestFormModal, use external success modal
                        // console.log("Using external success modal");
                        if (
                            typeof window.showBrochureSuccessModal ===
                            "function"
                        ) {
                            window.showBrochureSuccessModal();
                        }

                        // Close the form modal
                        const formModal = document.getElementById(
                            "brochure-form-modal",
                        );
                        if (formModal) {
                            formModal.classList.add("hidden");
                        }
                    } else {
                        
                        if (modal) {
                            modal.classList.remove("hidden");
                            // Ensure body can scroll to show modal
                            document.body.style.overflow = "";
                        } 
                    }

                    // Reset form
                    form.reset();

                    // Clear all errors
                    clearError(fullNameInput, fullNameError);
                    clearError(emailInput, emailError);
                    clearError(phoneInput, phoneError);
                    clearError(addressInput, addressError);
                    clearError(studyProgramSelect, studyProgramError);
                    clearError(studyMethodSelect, studyMethodError);

                    // Dispatch custom event for BrochureRequestFormModal
                    document.dispatchEvent(
                        new CustomEvent("brochure-form-submitted"),
                    );
                } catch (error) {
                    // console.error("Error sending to Google Sheets:", error);

                    // Show error message
                    if (submitError) {
                        submitError.textContent =
                            error instanceof Error
                                ? error.message
                                : "Terjadi kesalahan saat mengirim data. Silakan coba lagi.";
                        submitError.classList.remove("hidden");
                    }
                } finally {
                    // Reset loading state
                    if (submitButton && submitText && submitLoading) {
                        submitButton.disabled = false;
                        submitText.classList.remove("hidden");
                        submitLoading.classList.add("hidden");
                    }
                }
            });
        } else {
            console.error("Form or modal not found!", { form, modal });
        }

        // Close modal handlers
        if (closeModalBtn && modal) {
            const closeSuccessModal = () => {
                modal.classList.add("hidden");

                // Also close the parent form modal if it exists
                const formModal = document.getElementById(
                    "brochure-form-modal",
                );
                if (formModal) {
                    formModal.classList.add("hidden");
                    document.body.style.overflow = ""; // Restore scroll
                }
            };

            closeModalBtn.addEventListener("click", closeSuccessModal);

            // Close on backdrop click
            modal.addEventListener("click", (e) => {
                if (e.target === modal) {
                    closeSuccessModal();
                }
            });

            // Close on Escape key
            document.addEventListener("keydown", (e) => {
                if (e.key === "Escape" && !modal.classList.contains("hidden")) {
                    closeSuccessModal();
                }
            });
        }
    });
</script>

